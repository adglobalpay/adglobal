---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import TransactionDetailPage from '../../../components/admin/TransactionDetailPage';

export async function getStaticPaths() {
  // Astro static output needs at least one path.
  // The React component reads the actual ID from window.location at runtime.
  return [
    { params: { id: 'placeholder' } }
  ];
}
---

<AdminLayout>
  <TransactionDetailPage client:load txId={Astro.params.id} />
</AdminLayout>
