---
import AdminLayout from '../../../layouts/AdminLayout.astro';

// --- 1. FUNCIÓN getStaticPaths: GENERA UNA RUTA POR CADA TRANSACCIÓN ---
export async function getStaticPaths() {
  // Los datos DEBEN estar DENTRO de la función
  const todasLasTransacciones = [
    {
      id: 1,
      fecha: '14/03/26',
      remitente: { nombre: 'Jose Garcia', telefono: '' },
      destinatario: { nombre: 'Yolimar Mosqueda', telefono: '4243107776', banco: '' },
      montos: {
        ingreso_usd: 110.00,
        salida_usdt: 94.91,
        ingreso_efectivo: 0,
        salida_efectivo: 0,
        monto_ves_entregado: 58850.00
      },
      tasa: 535.00,
      metodo: 'USDT',
      profit: { usd: 15.09, ves: 0 },
      admin_comision: 110.00,
      // NUEVOS CAMPOS PARA VERIFICACIÓN
      comprobante_pago: 'comprobante_pago_1.pdf',
      comprobante_admin: 'comprobante_admin_1.pdf',
      estado: 'pending', // pending, verificando, completado, rechazado
      fecha_verificacion: null,
      verificador: null,
      notas_admin: ''
    },
    {
      id: 2,
      fecha: '14/03/26',
      remitente: { nombre: 'Carlos Perez', telefono: '4121234567' },
      destinatario: { nombre: 'Maria Lopez', telefono: '4147654321', banco: 'Banco Mercantil' },
      montos: {
        ingreso_usd: 250.00,
        salida_usdt: 240.00,
        ingreso_efectivo: 0,
        salida_efectivo: 0,
        monto_ves_entregado: 120000.00
      },
      tasa: 500.00,
      metodo: 'TRANSFERENCIA',
      profit: { usd: 10.00, ves: 0 },
      admin_comision: 250.00,
      // NUEVOS CAMPOS PARA VERIFICACIÓN
      comprobante_pago: 'comprobante_pago_2.pdf',
      comprobante_admin: 'comprobante_admin_2.pdf',
      estado: 'completado',
      fecha_verificacion: '15/03/26 10:30',
      verificador: 'AD Gomez',
      notas_admin: 'Todo correcto, fondos entregados'
    }
  ];

  return todasLasTransacciones.map((tx) => ({
    params: { id: tx.id.toString() },
    props: { transaccion: tx }
  }));
}

// --- 2. LA PÁGINA RECIBE LOS DATOS DE LA TRANSACCIÓN ESPECÍFICA ---
const { transaccion } = Astro.props;

if (!transaccion) {
  return Astro.redirect('/404');
}

// --- 3. FUNCIÓN PARA BADGE DE ESTADO ---
const getEstadoBadge = (estado: string) => {
  const config = {
    pending: { bg: 'bg-yellow-100', text: 'text-yellow-700', icon: '⏳', label: 'Pendiente revisión' },
    verificando: { bg: 'bg-blue-100', text: 'text-blue-700', icon: '🔍', label: 'Verificando' },
    completado: { bg: 'bg-green-100', text: 'text-green-700', icon: '✅', label: 'Completado' },
    rechazado: { bg: 'bg-red-100', text: 'text-red-700', icon: '❌', label: 'Rechazado' }
  };
  const style = config[estado] || config.pending;
  return `<span class="px-3 py-1 rounded-full text-xs font-medium ${style.bg} ${style.text} flex items-center gap-1 w-fit">${style.icon} ${style.label}</span>`;
};
---

<AdminLayout>
  <div class="max-w-5xl mx-auto space-y-6 p-4">
    <!-- Botón para volver -->
    <a href="/admin/transacciones" class="inline-flex items-center text-blue-600 hover:text-blue-800 mb-4 transition-colors">
      ← Volver a transacciones
    </a>

    <!-- Header con estado -->
    <div class="flex justify-between items-start">
      <div>
        <h1 class="text-3xl font-bold">Detalle de Transacción</h1>
        <p class="text-gray-500">ID: {transaccion.id} · {transaccion.fecha}</p>
      </div>
      <div set:html={getEstadoBadge(transaccion.estado || 'pending')} />
    </div>

    <!-- Información de Remitente y Destinatario -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
        <h2 class="text-lg font-semibold mb-3 flex items-center gap-2">
          <span class="text-2xl">📤</span> Remitente
        </h2>
        <p class="font-medium">{transaccion.remitente.nombre}</p>
        {transaccion.remitente.telefono ? (
          <p class="text-sm text-gray-500">Tel: {transaccion.remitente.telefono}</p>
        ) : (
          <p class="text-sm text-gray-400 italic">Sin teléfono</p>
        )}
      </div>

      <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
        <h2 class="text-lg font-semibold mb-3 flex items-center gap-2">
          <span class="text-2xl">📥</span> Destinatario
        </h2>
        <p class="font-medium">{transaccion.destinatario.nombre}</p>
        <p class="text-sm text-gray-500">Tel: {transaccion.destinatario.telefono}</p>
        {transaccion.destinatario.banco && (
          <p class="text-sm text-gray-500">Banco: {transaccion.destinatario.banco}</p>
        )}
      </div>
    </div>

    <!-- Tarjetas de Montos -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      <div class="bg-blue-50 rounded-xl p-5 shadow-sm border border-blue-100">
        <p class="text-sm text-blue-600 font-medium mb-1">💰 Ingreso USD</p>
        <p class="text-2xl font-bold">${transaccion.montos.ingreso_usd.toFixed(2)}</p>
      </div>

      <div class="bg-yellow-50 rounded-xl p-5 shadow-sm border border-yellow-100">
        <p class="text-sm text-yellow-600 font-medium mb-1">🪙 Salida USDT</p>
        <p class="text-2xl font-bold">${transaccion.montos.salida_usdt.toFixed(2)}</p>
      </div>

      <div class="bg-green-50 rounded-xl p-5 shadow-sm border border-green-100">
        <p class="text-sm text-green-600 font-medium mb-1">💵 Monto VES</p>
        <p class="text-2xl font-bold">Bs. {transaccion.montos.monto_ves_entregado.toLocaleString()}</p>
      </div>

      <div class="bg-purple-50 rounded-xl p-5 shadow-sm border border-purple-100">
        <p class="text-sm text-purple-600 font-medium mb-1">📊 Tasa</p>
        <p class="text-2xl font-bold">Bs. {transaccion.tasa}/USD</p>
        <p class="text-xs text-gray-500 mt-1">Método: {transaccion.metodo}</p>
      </div>
    </div>

    <!-- Profit y Comisión -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div class="bg-white rounded-xl p-5 shadow-sm border border-gray-200">
        <p class="text-sm text-gray-500 mb-1 flex items-center gap-1">
          <span>📈</span> Profit
        </p>
        <p class="text-2xl font-bold text-green-600">${transaccion.profit.usd.toFixed(2)}</p>
        {transaccion.profit.ves > 0 && (
          <p class="text-sm text-gray-500">+ Bs. {transaccion.profit.ves}</p>
        )}
      </div>

      <div class="bg-white rounded-xl p-5 shadow-sm border border-gray-200">
        <p class="text-sm text-gray-500 mb-1 flex items-center gap-1">
          <span>🧾</span> Comisión Admin
        </p>
        <p class="text-2xl font-bold text-blue-600">${transaccion.admin_comision.toFixed(2)}</p>
      </div>
    </div>

    <!-- ===== NUEVA SECCIÓN: VERIFICACIÓN ADMINISTRATIVA ===== -->
    <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-200">
      <h2 class="text-xl font-bold mb-4 flex items-center gap-2">
        <span>✅</span> Verificación Administrativa
      </h2>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Comprobantes -->
        <div class="space-y-4">
          <h3 class="font-semibold text-gray-700">📎 Comprobantes</h3>
          
          <!-- Comprobante de pago del cliente -->
          <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
            <div class="flex items-center gap-2">
              <span class="text-xl">📄</span>
              <div>
                <p class="font-medium">Comprobante de pago</p>
                <p class="text-xs text-gray-500">{transaccion.comprobante_pago || 'No disponible'}</p>
              </div>
            </div>
            {transaccion.comprobante_pago ? (
              <button 
                onClick={() => alert('Ver comprobante de pago')}
                class="text-blue-600 hover:text-blue-800 text-sm"
              >
                Ver
              </button>
            ) : (
              <span class="text-gray-400 text-sm">—</span>
            )}
          </div>
          
          <!-- Comprobante administrativo -->
          <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
            <div class="flex items-center gap-2">
              <span class="text-xl">📋</span>
              <div>
                <p class="font-medium">Comprobante administrativo</p>
                <p class="text-xs text-gray-500">{transaccion.comprobante_admin || 'No disponible'}</p>
              </div>
            </div>
            {transaccion.comprobante_admin ? (
              <button 
                onClick={() => alert('Ver comprobante administrativo')}
                class="text-blue-600 hover:text-blue-800 text-sm"
              >
                Ver
              </button>
            ) : (
              <span class="text-gray-400 text-sm">—</span>
            )}
          </div>
        </div>

        <!-- Panel de verificación -->
        <div class="space-y-4">
          <h3 class="font-semibold text-gray-700">⚙️ Acciones de verificación</h3>
          
          <!-- Selector de estado -->
          <div>
            <label class="block text-sm text-gray-500 mb-1">Cambiar estado</label>
            <select 
              id="estadoSelect"
              class="w-full border border-gray-300 rounded-lg px-4 py-2"
            >
              <option value="pending" selected={transaccion.estado === 'pending'}>⏳ Pendiente revisión</option>
              <option value="verificando" selected={transaccion.estado === 'verificando'}>🔍 En verificación</option>
              <option value="completado" selected={transaccion.estado === 'completado'}>✅ Completado</option>
              <option value="rechazado" selected={transaccion.estado === 'rechazado'}>❌ Rechazado</option>
            </select>
          </div>
          
          <!-- Notas administrativas -->
          <div>
            <label class="block text-sm text-gray-500 mb-1">Notas de verificación</label>
            <textarea 
              id="notasAdmin"
              rows="3"
              class="w-full border border-gray-300 rounded-lg px-4 py-2"
              placeholder="Agregar notas sobre la verificación..."
            >{transaccion.notas_admin || ''}</textarea>
          </div>
          
          <!-- Información de verificación -->
          {transaccion.fecha_verificacion && (
            <div class="p-3 bg-blue-50 rounded-lg text-sm">
              <p class="text-blue-800">Verificado por: <span class="font-medium">{transaccion.verificador}</span></p>
              <p class="text-blue-600 text-xs">{transaccion.fecha_verificacion}</p>
            </div>
          )}
          
          <!-- Botones de acción -->
          <div class="flex gap-3 pt-2">
            <button 
              onClick={() => {
                const nuevoEstado = (document.getElementById('estadoSelect') as HTMLSelectElement).value;
                const notas = (document.getElementById('notasAdmin') as HTMLTextAreaElement).value;
                alert(`✅ Transacción marcada como ${nuevoEstado}\nNotas: ${notas || '(vacío)'}`);
              }}
              class="flex-1 bg-green-600 text-white px-4 py-2 rounded-lg hover:bg-green-700 transition-colors"
            >
              Guardar verificación
            </button>
            <button 
              onClick={() => alert('Función: Subir comprobante')}
              class="flex-1 border border-gray-300 px-4 py-2 rounded-lg hover:bg-gray-50 transition-colors"
            >
              📎 Subir comprobante
            </button>
          </div>
        </div>
      </div>
    </div>
    <!-- ===== FIN DE NUEVA SECCIÓN ===== -->

    <!-- Botones de acción (originales) -->
    <div class="flex gap-3 pt-4">
      <button 
        onClick={() => alert('Función: Editar transacción (próximamente)')}
        class="bg-gray-900 text-white px-4 py-2 rounded-lg hover:bg-gray-800 transition-colors text-sm flex items-center gap-2"
      >
        ✏️ Editar
      </button>
      <button 
        onClick={() => alert('Función: Descargar comprobante (próximamente)')}
        class="border border-gray-300 px-4 py-2 rounded-lg hover:bg-gray-50 transition-colors text-sm flex items-center gap-2"
      >
        📎 Comprobante
      </button>
    </div>

    <!-- Mensaje informativo -->
    <div class="bg-blue-50 border-l-4 border-blue-400 p-4 mt-6">
      <p class="text-sm text-blue-700">
        ℹ️ Esta es una vista previa con datos de ejemplo. Cuando el desarrollador conecte la base de datos, 
        aquí se mostrarán las transacciones reales.
      </p>
    </div>
  </div>
</AdminLayout>