      var sel = tdMetodo.querySelector('select');
      if (!sel) return;
      var currentVal = sel.value;
    sel.innerHTML = metodos.map(function(m) { return '<option value="' + m.nombre + '"' + (m.nombre === currentVal ? ' selected' : '') + '>' + m.nombre + '</option>'; }).join('');
    });
  }

  function abrirModalMetodo() { 
    const m = document.getElementById('modalMetodo');
    const c = document.getElementById('modalContentMetodo');
    renderListaMetodos();
    m.classList.remove('hidden');
    m.classList.add('anim-overlay');
    setTimeout(() => { c.style.transform = 'scale(1)'; c.classList.add('anim-modal'); }, 10);
  }
  function cerrarModalMetodo() { 
    const m = document.getElementById('modalMetodo');
    const c = document.getElementById('modalContentMetodo');
    c.style.transform = 'scale(0.95)'; 
    c.classList.remove('anim-modal');
    setTimeout(() => { m.classList.add('hidden'); m.classList.remove('anim-overlay'); }, 200);
  }

  function guardarBanco(e) {
    e.preventDefault();
    var nuevoBanco = document.getElementById('bancoNombre').value.trim();
    if (!nuevoBanco) return;
    var emojiBanco = document.getElementById('bancoEmoji') ? document.getElementById('bancoEmoji').value.trim() || '🏦' : '🏦';
    bancos.push({ color: 'bg-blue-100 text-blue-600', icon: '<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 21h18M3 10h18M5 6l7-3 7 3M4 10v11M20 10v11M9 10v11M15 10v11"/></svg>', nombre: nuevoBanco });
    e.target.reset();
    renderListaBancos();
    actualizarSelectoresBanco();
    showToast('success', 'Banco agregado', nuevoBanco + ' fue agregado a la lista.');
  }

  async function guardarMetodo(e) {
    e.preventDefault();
    var nuevoMetodo = document.getElementById('metodoNombre').value.trim();
    if (!nuevoMetodo) return;
    var primeraLetra = nuevoMetodo.charAt(0).toUpperCase();
    try {
      await crearMetodoAPI(nuevoMetodo, primeraLetra, 'bg-slate-100 text-slate-600', nuevoMetodo, 'bg-slate-100 text-slate-600', '<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>');
      e.target.reset();
      renderListaMetodos();
      actualizarSelectoresMetodo();
      showToast('success', 'Método agregado', nuevoMetodo + ' fue agregado a la lista.');
    } catch (e) {}
  }

  async function guardarTodo() {
    var tablaBody = document.getElementById('tablaBody');
    if (!tablaBody) return;
    
    var filasDom = tablaBody.querySelectorAll('tr');
    if (filasDom.length === 0) {
      showToast('warning', 'Sin transacciones', 'Agrega al menos una transacción antes de guardar.');
      return;
    }
    
    var transacciones = [];
    var errores = [];
    
    filasDom.forEach(function(tr, idx) {
      var tds = tr.querySelectorAll('td');
      if (tds.length < 13) return;
      
      var clientId = tds[1].querySelector('select')?.value || '';
      var metodoRaw = tds[3].querySelector('select')?.value || 'USDT';
      var metodoMap = {
        'USDT': 'USDT',
        'Efectivo': 'EFECTIVO',
        'Zelle': 'ZELLE',
        'Venmo': 'VENMO',
        'CashApp': 'CASHAPP',
        'PayPal': 'PAYPAL',
        'Wire': 'WIRE',
        'Deposito': 'DEPOSITO',
        'Pago Movil': 'PAGO_MOVIL',
        'Transferencia': 'TRANSFERENCIA'
      };
      var metodo = metodoMap[metodoRaw] || 'TRANSFERENCIA';
      var recipientId = tds[4].querySelector('select')?.value || null;
      if (recipientId === '') recipientId = null;
      var ingreso = parseFloat(tds[7].querySelector('input')?.value || '0');
      var salida = parseFloat(tds[8].querySelector('input')?.value || '0');
      var tasa = parseFloat(tds[9].querySelector('input')?.value || '0');
      var montoBsText = tds[10].querySelector('.monto-bs')?.textContent?.replace(/,/g, '') || '0';
      var montoVES = parseFloat(montoBsText);
      var profitText = tds[11].querySelector('.profit')?.textContent?.replace(/[$,]/g, '') || '0';
      var profitUSD = parseFloat(profitText);
      
      if (!clientId) {
        errores.push('Fila ' + (idx + 1) + ': selecciona un cliente');
        return;
      }
      if (ingreso <= 0) {
        errores.push('Fila ' + (idx + 1) + ': el ingreso debe ser mayor a 0');
        return;
      }
      if (salida <= 0) {
        errores.push('Fila ' + (idx + 1) + ': la salida debe ser mayor a 0');
        return;
      }
      if (tasa <= 0) {
        errores.push('Fila ' + (idx + 1) + ': la tasa debe ser mayor a 0');
        return;
      }
      
      transacciones.push({
        clientId: clientId,
        recipientId: recipientId,
        ingresoUSD: ingreso,
        salidaUSDT: salida,
        tasa: tasa,
        montoVES: montoVES || (salida * tasa),
        metodo: metodo,
        profitUSD: profitUSD || (ingreso - salida),
        estado: 'PENDING'
      });
    });
    
    if (errores.length > 0) {
      showToast('error', 'Corrige los errores', errores[0]);
      return;
    }
    
    if (transacciones.length === 0) {
      showToast('warning', 'Sin transacciones válidas', 'Completa al menos una fila correctamente.');
      return;
    }
    
    var token = localStorage.getItem('adglobal_token');
    var API_URL = window.__ADGLOBAL_API_URL__ || 'https://backend-global-production.up.railway.app';
    var guardadas = 0;
    var fallidas = 0;
    
    for (var i = 0; i < transacciones.length; i++) {
      try {
        var res = await fetch(API_URL + '/api/transactions', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': 'Bearer ' + token
          },
          body: JSON.stringify(transacciones[i])
        });
        
        if (!res.ok) {
          var errData = await res.json().catch(function() { return {}; });
          console.error('Error fila ' + (i + 1) + ':', errData);
          fallidas++;
        } else {
          guardadas++;
        }
      } catch (e) {
        console.error('Error de red fila ' + (i + 1) + ':', e);
        fallidas++;
      }
    }
    
    if (fallidas > 0) {
      showToast('error', 'Error al guardar', 'Guardadas: ' + guardadas + ', Fallidas: ' + fallidas);
      return;
    }
    
    showToast('success', 'Transacciones guardadas', guardadas + ' transacción(es) registrada(s) exitosamente.');
    setTimeout(function() {
      window.location.href = '/admin/transacciones';
    }, 1200);
  }
</script>
