---
import AdminLayout from '../../../layouts/AdminLayout.astro';
---

<AdminLayout>
  <div class="max-w-7xl mx-auto space-y-4 p-4">
    <!-- Header -->
    <div class="flex justify-between items-center">
      <h1 class="text-3xl font-bold">➕ Nueva Transacción</h1>
      <a href="/admin/transacciones" class="text-blue-600 hover:underline">
        ← Cancelar
      </a>
    </div>

    <!-- Opciones globales (botones para agregar) -->
    <div class="grid grid-cols-4 gap-3 mb-3">
      <a href="/admin/clientes" class="bg-blue-50 hover:bg-blue-100 text-blue-700 px-3 py-1.5 rounded-lg text-xs flex items-center justify-center gap-1 border border-blue-200 transition-colors">
        <span>➕</span> Clientes
      </a>
      <a href="/admin/clientes?tab=destinatarios" class="bg-green-50 hover:bg-green-100 text-green-700 px-3 py-1.5 rounded-lg text-xs flex items-center justify-center gap-1 border border-green-200 transition-colors">
        <span>➕</span> Destinatarios
      </a>
      <button onclick="abrirModalBanco()" class="bg-purple-50 hover:bg-purple-100 text-purple-700 px-3 py-1.5 rounded-lg text-xs flex items-center justify-center gap-1 border border-purple-200 transition-colors">
        <span>➕</span> Bancos
      </button>
      <button onclick="abrirModalMetodo()" class="bg-orange-50 hover:bg-orange-100 text-orange-700 px-3 py-1.5 rounded-lg text-xs flex items-center justify-center gap-1 border border-orange-200 transition-colors">
        <span>➕</span> Métodos
      </button>
    </div>

    <!-- Tabla de transacciones - SIN SCROLL HORIZONTAL -->
    <div class="bg-white rounded-xl p-4 shadow-sm border border-gray-100">
      <!-- Versión para pantallas grandes (visible en desktop) -->
      <div class="hidden lg:block">
        <table class="w-full">
          <thead>
            <tr class="text-left text-gray-500 text-xs border-b">
              <th class="pb-2 pr-2">Fecha</th>
              <th class="pb-2 pr-2">Cliente</th>
              <th class="pb-2 pr-2">Método</th>
              <th class="pb-2 pr-2">Destinatario</th>
              <th class="pb-2 pr-2">Banco</th>
              <th class="pb-2 pr-2">Ingreso</th>
              <th class="pb-2 pr-2">Salida</th>
              <th class="pb-2 pr-2">Tasa</th>
              <th class="pb-2 pr-2">Bs</th>
              <th class="pb-2 pr-2">Profit</th>
              <th class="pb-2 pr-2"></th>
            </tr>
          </thead>
          <tbody id="tablaBody">
            <!-- Las filas se insertan aquí -->
          </tbody>
        </table>
      </div>

      <!-- Versión para móvil/tablet (cards) -->
      <div class="lg:hidden space-y-3" id="cardsContainer">
        <p class="text-center text-gray-500 text-sm py-4">
          Usa una pantalla más grande para ver la tabla completa
        </p>
      </div>

      <!-- Botón para agregar fila -->
      <div class="mt-3 flex justify-center">
        <button 
          id="btnAgregar"
          class="bg-gray-100 hover:bg-gray-200 text-gray-700 px-5 py-2 rounded-lg border flex items-center gap-1 text-sm"
        >
          <span class="text-lg">➕</span> Agregar otra transacción
        </button>
      </div>
    </div>
  </div>

  <!-- Modales (sin cambios) -->
  <div id="modalBanco" class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center hidden z-50">
    <div class="bg-white rounded-xl p-6 max-w-md w-full">
      <h2 class="text-2xl font-bold mb-4">➕ Nuevo Banco</h2>
      <form id="formBanco" class="space-y-4" onsubmit="guardarBanco(event)">
        <div>
          <label class="block text-sm font-medium mb-1">Nombre del banco *</label>
          <input type="text" id="bancoNombre" required class="w-full border rounded-lg px-3 py-2" placeholder="Ej: BNC">
        </div>
        <div class="flex justify-end gap-2 pt-4">
          <button type="button" onclick="cerrarModalBanco()" class="px-4 py-2 border rounded-lg hover:bg-gray-50">Cancelar</button>
          <button type="submit" class="px-4 py-2 bg-purple-600 text-white rounded-lg hover:bg-purple-700">Guardar Banco</button>
        </div>
      </form>
    </div>
  </div>

  <div id="modalMetodo" class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center hidden z-50">
    <div class="bg-white rounded-xl p-6 max-w-md w-full">
      <h2 class="text-2xl font-bold mb-4">➕ Nuevo Método de Pago</h2>
      <form id="formMetodo" class="space-y-4" onsubmit="guardarMetodo(event)">
        <div>
          <label class="block text-sm font-medium mb-1">Nombre del método *</label>
          <input type="text" id="metodoNombre" required class="w-full border rounded-lg px-3 py-2" placeholder="Ej: Zelle, BOFA, Chase, PNC">
        </div>
        <div class="flex justify-end gap-2 pt-4">
          <button type="button" onclick="cerrarModalMetodo()" class="px-4 py-2 border rounded-lg hover:bg-gray-50">Cancelar</button>
          <button type="submit" class="px-4 py-2 bg-orange-600 text-white rounded-lg hover:bg-orange-700">Guardar Método</button>
        </div>
      </form>
    </div>
  </div>
</AdminLayout>

<script is:inline>
  // Datos iniciales
  var clientes = [
    { id: '1', nombre: 'Luisa Ideas Creativas', telefono: '4242459151', email: '', metodo: 'Zelle' },
    { id: '2', nombre: 'Cartaya Auto Sales', telefono: '3055551234', email: 'cartaya@autos.com', metodo: 'BOFA' }
  ];

  var destinatarios = [
    { id: '201', nombre: 'Carlos Mendoza', telefono: '+58 412 1234567', banco: 'Banco Venezuela', cuenta: '0102-1234-56-78901234', relacion: 'Hermano' },
    { id: '202', nombre: 'Ana Torres', telefono: '+58 414 7654321', banco: 'Mercantil', cuenta: '0105-4321-87-65432109', relacion: 'Prima' }
  ];

  var bancos = ['Banesco', 'Mercantil', 'Banco Venezuela', 'Banco Provincial', 'BNC', 'BOD'];
  var metodos = ['Zelle', 'BOFA', 'Chase', 'PNC', 'Debit Card', 'Efectivo', 'USDT'];

  document.addEventListener('DOMContentLoaded', function() {
    console.log('✅ Página cargada');
    
    var btnAgregar = document.getElementById('btnAgregar');
    var tablaBody = document.getElementById('tablaBody');
    
    if (btnAgregar && tablaBody) {
      agregarFila();
      
      btnAgregar.onclick = function() {
        agregarFila();
      };
    }
  });

  function agregarFila() {
    var tablaBody = document.getElementById('tablaBody');
    if (!tablaBody) return;
    
    var tr = document.createElement('tr');
    tr.className = 'border-b hover:bg-gray-50';
    
    // Fecha
    var tdFecha = document.createElement('td');
    tdFecha.className = 'py-2 pr-2';
    var spanFecha = document.createElement('span');
    spanFecha.className = 'text-xs whitespace-nowrap';
    var ahora = new Date();
    spanFecha.textContent = ('0' + ahora.getDate()).slice(-2) + '/' + 
                            ('0' + (ahora.getMonth() + 1)).slice(-2) + '/' + 
                            ahora.getFullYear().toString().slice(-2) + ' ' +
                            ('0' + ahora.getHours()).slice(-2) + ':' +
                            ('0' + ahora.getMinutes()).slice(-2);
    tdFecha.appendChild(spanFecha);
    
    // Cliente
    var tdCliente = document.createElement('td');
    tdCliente.className = 'py-2 pr-2';
    var selectCliente = document.createElement('select');
    selectCliente.className = 'cliente-select w-32 border rounded px-2 py-1 text-xs';
    
    var optionsCliente = '<option value="">Selec</option>';
    for (var i = 0; i < clientes.length; i++) {
      optionsCliente += '<option value="' + clientes[i].id + '">' + clientes[i].nombre.split(' ')[0] + '</option>';
    }
    selectCliente.innerHTML = optionsCliente;
    tdCliente.appendChild(selectCliente);
    
    // Método
    var tdMetodo = document.createElement('td');
    tdMetodo.className = 'py-2 pr-2';
    var selectMetodo = document.createElement('select');
    selectMetodo.className = 'metodo-select w-16 border rounded px-2 py-1 text-xs';
    
    var optionsMetodo = '';
    for (var m = 0; m < metodos.length; m++) {
      optionsMetodo += '<option value="' + metodos[m] + '">' + metodos[m] + '</option>';
    }
    selectMetodo.innerHTML = optionsMetodo;
    tdMetodo.appendChild(selectMetodo);
    
    // Destinatario
    var tdDestino = document.createElement('td');
    tdDestino.className = 'py-2 pr-2';
    var selectDestino = document.createElement('select');
    selectDestino.className = 'destino-select w-32 border rounded px-2 py-1 text-xs';
    
    var optionsDestino = '<option value="">Selec</option>';
    for (var j = 0; j < destinatarios.length; j++) {
      optionsDestino += '<option value="' + destinatarios[j].id + '">' + destinatarios[j].nombre.split(' ')[0] + '</option>';
    }
    selectDestino.innerHTML = optionsDestino;
    tdDestino.appendChild(selectDestino);
    
    // Banco
    var tdBanco = document.createElement('td');
    tdBanco.className = 'py-2 pr-2';
    var selectBanco = document.createElement('select');
    selectBanco.className = 'banco-select w-24 border rounded px-2 py-1 text-xs';
    
    var optionsBanco = '<option value="">Selec</option>';
    for (var k = 0; k < bancos.length; k++) {
      optionsBanco += '<option value="' + bancos[k] + '">' + bancos[k].substring(0, 8) + '</option>';
    }
    selectBanco.innerHTML = optionsBanco;
    tdBanco.appendChild(selectBanco);
    
    // Ingreso
    var tdIngreso = document.createElement('td');
    tdIngreso.className = 'py-2 pr-2';
    var inputIngreso = document.createElement('input');
    inputIngreso.type = 'number';
    inputIngreso.step = '0.01';
    inputIngreso.placeholder = '0';
    inputIngreso.className = 'ingreso w-14 border rounded px-2 py-1 text-xs';
    inputIngreso.oninput = function() { calcularFila(tr); };
    tdIngreso.appendChild(inputIngreso);
    
    // Salida
    var tdSalida = document.createElement('td');
    tdSalida.className = 'py-2 pr-2';
    var inputSalida = document.createElement('input');
    inputSalida.type = 'number';
    inputSalida.step = '0.01';
    inputSalida.placeholder = '0';
    inputSalida.className = 'salida w-14 border rounded px-2 py-1 text-xs';
    inputSalida.oninput = function() { calcularFila(tr); };
    tdSalida.appendChild(inputSalida);
    
    // Tasa
    var tdTasa = document.createElement('td');
    tdTasa.className = 'py-2 pr-2';
    var inputTasa = document.createElement('input');
    inputTasa.type = 'number';
    inputTasa.step = '0.01';
    inputTasa.placeholder = '0';
    inputTasa.className = 'tasa w-14 border rounded px-2 py-1 text-xs';
    inputTasa.oninput = function() { calcularFila(tr); };
    tdTasa.appendChild(inputTasa);
    
    // Monto Bs
    var tdMontoBs = document.createElement('td');
    tdMontoBs.className = 'py-2 pr-2 font-medium text-blue-600 monto-bs text-xs whitespace-nowrap';
    tdMontoBs.textContent = 'Bs. 0';
    
    // Profit
    var tdProfit = document.createElement('td');
    tdProfit.className = 'py-2 pr-2 font-medium text-green-600 profit text-xs whitespace-nowrap';
    tdProfit.textContent = '$0';
    
    // Botón eliminar
    var tdEliminar = document.createElement('td');
    tdEliminar.className = 'py-2';
    var btnEliminar = document.createElement('button');
    btnEliminar.innerHTML = '🗑️';
    btnEliminar.className = 'text-red-600 hover:text-red-800 text-sm';
    btnEliminar.onclick = function() { tr.remove(); };
    tdEliminar.appendChild(btnEliminar);
    
    tr.appendChild(tdFecha);
    tr.appendChild(tdCliente);
    tr.appendChild(tdMetodo);
    tr.appendChild(tdDestino);
    tr.appendChild(tdBanco);
    tr.appendChild(tdIngreso);
    tr.appendChild(tdSalida);
    tr.appendChild(tdTasa);
    tr.appendChild(tdMontoBs);
    tr.appendChild(tdProfit);
    tr.appendChild(tdEliminar);
    
    tablaBody.appendChild(tr);
  }

  function calcularFila(tr) {
    var ingreso = parseFloat(tr.querySelector('.ingreso').value) || 0;
    var salida = parseFloat(tr.querySelector('.salida').value) || 0;
    var tasa = parseFloat(tr.querySelector('.tasa').value) || 0;
    
    var montoBs = salida * tasa;
    var profit = ingreso - salida;
    
    tr.querySelector('.monto-bs').textContent = 'Bs. ' + montoBs.toFixed(0);
    tr.querySelector('.profit').textContent = '$' + profit.toFixed(0);
  }

  // Funciones para modales
  function abrirModalBanco() { document.getElementById('modalBanco').classList.remove('hidden'); }
  function cerrarModalBanco() { document.getElementById('modalBanco').classList.add('hidden'); }
  
  function abrirModalMetodo() { document.getElementById('modalMetodo').classList.remove('hidden'); }
  function cerrarModalMetodo() { document.getElementById('modalMetodo').classList.add('hidden'); }

  function guardarBanco(e) {
    e.preventDefault();
    var nuevoBanco = document.getElementById('bancoNombre').value;
    bancos.push(nuevoBanco);
    actualizarSelectsBanco();
    alert('✅ Banco agregado: ' + nuevoBanco);
    cerrarModalBanco();
    e.target.reset();
  }

  function guardarMetodo(e) {
    e.preventDefault();
    var nuevoMetodo = document.getElementById('metodoNombre').value;
    metodos.push(nuevoMetodo);
    actualizarSelectsMetodo();
    alert('✅ Método agregado: ' + nuevoMetodo);
    cerrarModalMetodo();
    e.target.reset();
  }

  function actualizarSelectsBanco() {
    var selects = document.querySelectorAll('.banco-select');
    selects.forEach(function(select) {
      var valorActual = select.value;
      var options = '<option value="">Selec</option>';
      for (var b = 0; b < bancos.length; b++) {
        options += '<option value="' + bancos[b] + '" ' + (valorActual === bancos[b] ? 'selected' : '') + '>' + bancos[b].substring(0, 8) + '</option>';
      }
      select.innerHTML = options;
    });
  }

  function actualizarSelectsMetodo() {
    var selects = document.querySelectorAll('.metodo-select');
    selects.forEach(function(select) {
      var valorActual = select.value;
      var options = '';
      for (var m = 0; m < metodos.length; m++) {
        options += '<option value="' + metodos[m] + '" ' + (valorActual === metodos[m] ? 'selected' : '') + '>' + metodos[m] + '</option>';
      }
      select.innerHTML = options;
    });
  }
</script>