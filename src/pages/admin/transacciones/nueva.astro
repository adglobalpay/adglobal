<script is:inline>
  var clientes = [];
  var destinatariosPorCliente = {};
  var destinatariosVista = [];
  var metodos = [];
  var bancosLista = [];
  var accountTypesLista = [];
  var busquedaDestinatario = '';
  var debounceBusquedaDestinatario = null;
  var busquedaExistente = '';
  var debounceBusquedaExistente = null;
  var existentesRequestId = 0;
  var existentesVista = [];
  var destinatariosRequestId = 0;
  var paginacionDestinatarios = {
    limit: 24,
    offset: 0,
    total: 0,
    hasMore: false,
    cargando: false
  };

  var API_URL = window.__ADGLOBAL_API_URL__ || 'https://backend-global-production.up.railway.app';

  var estado = {
    paso: 1,
    cliente: null,
    destinatario: null,
    destinatarios: [],
    detallesPorDestinatario: {},
    metodo: '',
    banco: '',
    ingreso: 0,
    salida: 0,
    tasa: 0,
    comprobantes: { egresos: {} }
  };
  var previewUrls = {
    pago: null,
    admin: null
  };

  function formatFileSize(bytes) {
    if (!bytes) return '0 KB';
    if (bytes < 1024) return bytes + ' B';
    if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
    return (bytes / (1024 * 1024)).toFixed(2) + ' MB';
  }

  function revokePreviewUrl(tipo) {
    if (previewUrls[tipo]) {
      URL.revokeObjectURL(previewUrls[tipo]);
      previewUrls[tipo] = null;
    }
  }

  function resetPreview(tipo) {
    var sufijo = tipo === 'pago' ? 'Pago' : 'Admin';
    var preview = document.getElementById('preview' + sufijo);
    var img = document.getElementById('preview' + sufijo + 'Img');
    var pdf = document.getElementById('preview' + sufijo + 'Pdf');
    var open = document.getElementById('preview' + sufijo + 'Open');
    var name = document.getElementById('preview' + sufijo + 'Name');
    var meta = document.getElementById('preview' + sufijo + 'Meta');

    revokePreviewUrl(tipo);

    if (preview) preview.classList.add('hidden');
    if (img) {
      img.classList.add('hidden');
      img.removeAttribute('src');
    }
    if (pdf) {
      pdf.classList.add('hidden');
      pdf.removeAttribute('src');
    }
    if (open) open.setAttribute('href', '#');
    if (name) name.textContent = 'Archivo';
    if (meta) meta.textContent = '0 KB';
  }

  function renderPreviewComprobante(tipo, file) {
    var sufijo = tipo === 'pago' ? 'Pago' : 'Admin';
    var preview = document.getElementById('preview' + sufijo);
    var img = document.getElementById('preview' + sufijo + 'Img');
    var pdf = document.getElementById('preview' + sufijo + 'Pdf');
    var open = document.getElementById('preview' + sufijo + 'Open');
    var name = document.getElementById('preview' + sufijo + 'Name');
    var meta = document.getElementById('preview' + sufijo + 'Meta');
    var objectUrl = URL.createObjectURL(file);

    revokePreviewUrl(tipo);
    previewUrls[tipo] = objectUrl;

    if (preview) preview.classList.remove('hidden');
    if (name) name.textContent = file.name;
    if (meta) meta.textContent = formatFileSize(file.size) + ' · ' + (file.type === 'application/pdf' ? 'PDF' : 'Imagen');
    if (open) open.setAttribute('href', objectUrl);

    if (file.type === 'application/pdf') {
      if (img) {
        img.classList.add('hidden');
        img.removeAttribute('src');
      }
      if (pdf) {
        pdf.src = objectUrl + '#toolbar=0&navpanes=0&scrollbar=0&view=FitH';
        pdf.classList.remove('hidden');
      }
      return;
    }

    if (pdf) {
      pdf.classList.add('hidden');
      pdf.removeAttribute('src');
    }
    if (img) {
      img.src = objectUrl;
      img.classList.remove('hidden');
    }
  }

  function ocultarAlertaKyc() {
    var box = document.getElementById('kycRequiredAlert');
    var reasons = document.getElementById('kycRequiredReasons');
    var message = document.getElementById('kycRequiredMessage');
    if (box) box.classList.add('hidden');
    if (reasons) reasons.innerHTML = '';
    if (message) message.textContent = '';
  }

  function mostrarAlertaKyc(errorData) {
    var box = document.getElementById('kycRequiredAlert');
    var title = document.getElementById('kycRequiredTitle');
    var message = document.getElementById('kycRequiredMessage');
    var reasons = document.getElementById('kycRequiredReasons');
    var profileLink = document.getElementById('kycRequiredProfileLink');

    if (!box || !title || !message || !reasons || !profileLink || !estado.cliente) return;

    var entityType = errorData.entityType === 'RECIPIENT' ? 'RECIPIENT' : 'CLIENT';
    var entityLabel = entityType === 'RECIPIENT' ? 'destinatario' : 'cliente';

    title.textContent = errorData.kycRequestCreated
      ? 'Se generó una solicitud KYC para este ' + entityLabel
      : 'El ' + entityLabel + ' ya tiene KYC pendiente o en proceso';
    message.textContent = errorData.error || ('El ' + entityLabel + ' debe completar KYC antes de registrar este giro.');
    reasons.innerHTML = (errorData.reasons || []).map(function(reason) {
      return '<li class="flex items-start gap-2"><span class="mt-1 h-2 w-2 rounded-full bg-amber-400 shrink-0"></span><span>' + reason + '</span></li>';
    }).join('');
    profileLink.href = entityType === 'RECIPIENT'
      ? '/admin/destinatarios/perfil?id=' + encodeURIComponent(errorData.entityId || '')
      : '/admin/clientes/perfil?id=' + encodeURIComponent(errorData.entityId || estado.cliente.id);
    box.classList.remove('hidden');
  }

  function ocultarAlertaOfac() {
    var box = document.getElementById('ofacRequiredAlert');
    var reasons = document.getElementById('ofacRequiredReasons');
    var message = document.getElementById('ofacRequiredMessage');
    if (box) box.classList.add('hidden');
    if (reasons) reasons.innerHTML = '';
    if (message) message.textContent = '';
  }

  function mostrarAlertaOfac(errorData) {
    var box = document.getElementById('ofacRequiredAlert');
    var title = document.getElementById('ofacRequiredTitle');
    var message = document.getElementById('ofacRequiredMessage');
    var reasons = document.getElementById('ofacRequiredReasons');
    var profileLink = document.getElementById('ofacRequiredProfileLink');

    if (!box || !title || !message || !reasons || !profileLink || !estado.cliente) return;

    var entityType = errorData.entityType === 'RECIPIENT' ? 'RECIPIENT' : 'CLIENT';
    var entityLabel = entityType === 'RECIPIENT' ? 'destinatario' : 'cliente';

    title.textContent = errorData.ofacCheckCreated
      ? 'Se generó una verificación OFAC para este ' + entityLabel
      : 'El ' + entityLabel + ' ya tiene una verificación OFAC pendiente o en revisión';
    message.textContent = errorData.error || ('El ' + entityLabel + ' debe completar la verificación OFAC antes de registrar este giro.');
    reasons.innerHTML = (errorData.reasons || []).map(function(reason) {
      return '<li class="flex items-start gap-2"><span class="mt-1 h-2 w-2 rounded-full bg-rose-400 shrink-0"></span><span>' + reason + '</span></li>';
    }).join('');
    profileLink.href = entityType === 'RECIPIENT'
      ? '/admin/destinatarios/perfil?id=' + encodeURIComponent(errorData.entityId || '')
      : '/admin/clientes/perfil?id=' + encodeURIComponent(errorData.entityId || estado.cliente.id);
    profileLink.textContent = entityType === 'RECIPIENT'
      ? 'Ver perfil del destinatario'
      : 'Ver perfil del cliente';
    box.classList.remove('hidden');
  }

  function showToast(type, message, description) {
    window.dispatchEvent(new CustomEvent('show-toast', {
      detail: { type: type, message: message, description: description }
    }));
  }

  function escapeHtml(value) {
    return String(value || '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function normalizeSearchValue(value) {
    return String(value || '')
      .toLowerCase()
      .normalize('NFD')
      .replace(/[\u0300-\u036f]/g, '')
      .trim();
  }

  function extractDigits(value) {
    return String(value || '').replace(/\D/g, '');
  }

  function actualizarBusquedaDestinatarios(value) {
    busquedaDestinatario = String(value || '');
    var clearBtn = document.getElementById('clearBusquedaDestinatario');
    if (clearBtn) clearBtn.classList.toggle('hidden', !busquedaDestinatario.trim());
    if (!estado.cliente) return;

    if (debounceBusquedaDestinatario) clearTimeout(debounceBusquedaDestinatario);
    debounceBusquedaDestinatario = setTimeout(function() {
      cargarDestinatariosWizard(estado.cliente.id, { reset: true });
    }, 250);
  }

  function limpiarBusquedaDestinatarios(shouldReload) {
    if (typeof shouldReload === 'undefined') shouldReload = true;
    busquedaDestinatario = '';
    var input = document.getElementById('buscarDestinatario');
    var clearBtn = document.getElementById('clearBusquedaDestinatario');
    if (input) input.value = '';
    if (clearBtn) clearBtn.classList.add('hidden');
    if (debounceBusquedaDestinatario) clearTimeout(debounceBusquedaDestinatario);
    if (!shouldReload || !estado.cliente) return;
    cargarDestinatariosWizard(estado.cliente.id, { reset: true });
  }

  function actualizarEstadoVacioDestinatarios(hasQuery) {
    var titulo = document.getElementById('sinDestinatariosTitulo');
    var descripcion = document.getElementById('sinDestinatariosDescripcion');
    if (!titulo || !descripcion) return;
    if (hasQuery) {
      titulo.textContent = 'Sin coincidencias';
      descripcion.textContent = 'No se encontró entre los destinatarios de este cliente.';
      return;
    }
    titulo.textContent = 'Sin destinatarios';
    descripcion.textContent = 'Este cliente no tiene destinatarios registrados';
  }

  function obtenerCatalogoDestinatarios(clientId) {
    if (!destinatariosPorCliente[clientId]) destinatariosPorCliente[clientId] = {};
    return destinatariosPorCliente[clientId];
  }

  function mapDestinatarioWizard(r) {
    return {
      id: r.id,
      nombre: r.name,
      telefono: r.phone || '',
      banco: r.bank || '',
      cuenta: r.accountNumber || '',
      relacion: r.relationship || '',
      identificacion: r.identification || '',
      clienteId: r.clientId || (r.client && r.client.id) || '',
      clienteOrigen: r.client ? (r.client.firstName + (r.client.lastName ? ' ' + r.client.lastName : '')).trim() : ''
    };
  }

  function filtrarDestinatariosLegacy(lista) {
    var query = normalizeSearchValue(busquedaDestinatario);
    if (!query) return lista;

    var queryDigits = extractDigits(busquedaDestinatario);

    return lista.filter(function(item) {
      var nombre = normalizeSearchValue(item.nombre);
      var telefono = normalizeSearchValue(item.telefono);
      var identificacion = normalizeSearchValue(item.identificacion);
      var telefonoDigits = extractDigits(item.telefono);
      var identificacionDigits = extractDigits(item.identificacion);

      return nombre.includes(query)
        || telefono.includes(query)
        || identificacion.includes(query)
        || (queryDigits && telefonoDigits.includes(queryDigits))
        || (queryDigits && identificacionDigits.includes(queryDigits));
    });
  }

  function guardarDestinatariosEnCatalogo(clientId, lista) {
    var catalogo = obtenerCatalogoDestinatarios(clientId);
    lista.forEach(function(item) {
      catalogo[item.id] = item;
    });
  }

  function actualizarAccionesDestinatarios() {
    var wrap = document.getElementById('destinatariosLoadMoreWrap');
    var btn = document.getElementById('destinatariosLoadMoreBtn');
    if (!wrap || !btn) return;

    var mostrar = destinatariosVista.length > 0 && (paginacionDestinatarios.hasMore || paginacionDestinatarios.cargando);
    wrap.classList.toggle('hidden', !mostrar);
    wrap.classList.toggle('flex', mostrar);
    btn.disabled = paginacionDestinatarios.cargando || !paginacionDestinatarios.hasMore;
    btn.textContent = paginacionDestinatarios.cargando ? 'Buscando...' : 'Cargar más';
  }

  function cargarMasDestinatarios() {
    if (!estado.cliente || paginacionDestinatarios.cargando || !paginacionDestinatarios.hasMore) return;
    cargarDestinatariosWizard(estado.cliente.id, { reset: false });
  }

  function optionList(options, selected) {
    return options.map(function(option) {
      var safe = escapeHtml(option);
      return '<option value="' + safe + '"' + (option === selected ? ' selected' : '') + '>' + safe + '</option>';
    }).join('');
  }

  function bancoEsBinance(value) {
    return String(value || '').trim().toLowerCase() === 'binance';
  }

  // ===================== CARGA INICIAL =====================
  document.addEventListener('DOMContentLoaded', async function() {
    await cargarClientes();
    await cargarMetodosAPI();
    await cargarBancosAPI();
    await cargarTiposCuentaAPI();
    poblarSelectMetodos();
    toggleTasaPorBanco();

    // Autocomplete de clientes
    var inputBuscar = document.getElementById('buscarCliente');
    inputBuscar.addEventListener('input', function() {
      var query = this.value.trim().toLowerCase();
      document.getElementById('clearBusqueda').classList.toggle('hidden', !query);
      if (query.length < 2) {
        document.getElementById('resultadosClientes').classList.add('hidden');
        return;
      }
      var resultados = clientes.filter(function(c) {
        return c.nombre.toLowerCase().includes(query)
          || c.telefono.includes(query)
          || c.email.toLowerCase().includes(query);
      });
      renderResultadosClientes(resultados);
    });

    inputBuscar.addEventListener('focus', function() {
      if (this.value.trim().length >= 2) {
        document.getElementById('resultadosClientes').classList.remove('hidden');
      }
    });

    document.addEventListener('click', function(e) {
      if (!document.querySelector('.relative').contains(e.target)) {
        document.getElementById('resultadosClientes').classList.add('hidden');
      }
    });

    // Setup drag & drop para comprobantes
    setupDropZone('dropPago', 'filePago', 'pago');
  });

  function setupDropZone(dropId, inputId, tipo) {
    var dropZone = document.getElementById(dropId);
    var input = document.getElementById(inputId);
    if (!dropZone || !input) return;

    ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(function(eventName) {
      dropZone.addEventListener(eventName, function(e) {
        e.preventDefault();
        e.stopPropagation();
      }, false);
    });

    ['dragenter', 'dragover'].forEach(function(eventName) {
      dropZone.addEventListener(eventName, function() {
        dropZone.classList.add('border-indigo-400', 'bg-indigo-50');
        dropZone.classList.remove('border-slate-300', 'bg-slate-50');
      }, false);
    });

    ['dragleave', 'drop'].forEach(function(eventName) {
      dropZone.addEventListener(eventName, function() {
        if (!estado.comprobantes[tipo]) {
          dropZone.classList.remove('border-indigo-400', 'bg-indigo-50');
          dropZone.classList.add('border-slate-300', 'bg-slate-50');
        }
      }, false);
    });

    dropZone.addEventListener('drop', function(e) {
      var files = e.dataTransfer.files;
      if (files.length > 0) {
        input.files = files;
        procesarComprobante(input, tipo);
      }
    }, false);
  }

  async function cargarClientes() {
    try {
      var token = localStorage.getItem('adglobal_token');
      var res = await fetch(API_URL + '/api/clients', { headers: { 'Authorization': 'Bearer ' + token } });
      if (!res.ok) throw new Error('Error');
      var data = await res.json();
      clientes = data.map(function(c) {
        return {
          id: c.id,
          nombre: c.firstName + (c.lastName ? ' ' + c.lastName : ''),
          telefono: c.phone || '',
          email: c.email || '',
          reportTagId: c.reportTagId || null
        };
      });
    } catch (e) {
      console.error('Error cargando clientes:', e);
    }
  }

