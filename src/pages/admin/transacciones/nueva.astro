  // ===================== UPLOAD S3 =====================
  async function subirComprobanteAS3(file, tipo) {
    var token = localStorage.getItem('adglobal_token');
    var formData = new FormData();
    formData.append('file', file);
    formData.append('folder', 'transactions/' + (estado.cliente ? estado.cliente.id : 'unknown'));

    var res = await fetch(API_URL + '/api/upload', {
      method: 'POST',
      headers: { 'Authorization': 'Bearer ' + token },
      body: formData
    });

    if (!res.ok) {
      var err = await res.json().catch(function() { return {}; });
      throw new Error(err.error || 'Error subiendo comprobante ' + tipo);
    }

    var data = await res.json();
    return data.url;
  }

  // ===================== GUARDAR =====================
  async function guardarTransaccion() {
    var btn = document.getElementById('btnGuardarFinal');
    btn.disabled = true;
    btn.innerHTML = '<svg class="animate-spin w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> Guardando...';

    var metodoMap = {
      'USDT': 'USDT', 'Efectivo': 'EFECTIVO', 'Zelle': 'ZELLE',
      'PayPal': 'PAYPAL', 'Wire': 'WIRE', 'Deposito': 'DEPOSITO',
      'Pago Movil': 'PAGO_MOVIL', 'Transferencia': 'TRANSFERENCIA'
    };

    try {
      // Subir comprobantes a S3 primero
      var comprobantePagoUrl = null;

      if (estado.comprobantes.pago && estado.comprobantes.pago.archivo) {
        comprobantePagoUrl = await subirComprobanteAS3(estado.comprobantes.pago.archivo, 'pago');
      }

      var token = localStorage.getItem('adglobal_token');
      var destinatarios = estado.destinatarios || [];
      var multipleGroupId = destinatarios.length > 1
        ? ((window.crypto && typeof window.crypto.randomUUID === 'function')
            ? window.crypto.randomUUID()
            : 'mul-' + Date.now() + '-' + Math.random().toString(16).slice(2, 10))
        : null;
      for (var i = 0; i < destinatarios.length; i++) {
        var destinatario = destinatarios[i];
        var detalle = obtenerDetalleDestinatario(destinatario.id);
        var comprobanteEgreso = estado.comprobantes.egresos ? estado.comprobantes.egresos[destinatario.id] : null;
        var comprobanteEgresoUrl = comprobanteEgreso && comprobanteEgreso.archivo
          ? await subirComprobanteAS3(comprobanteEgreso.archivo, 'egreso-' + destinatario.id)
          : null;
        var ingresoAsignado = obtenerIngresoAsignado(destinatario, destinatarios, estado.ingreso);
        var tasa = bancoEsBinance(detalle.banco) ? 0 : (parseFloat(detalle.tasa) || 0);
        var salida = parseFloat(detalle.salida) || 0;
        var montoVES = obtenerVESDetalle(destinatario, destinatarios, estado.ingreso);
        var metodo = metodoMap[detalle.metodo] || 'TRANSFERENCIA';
        var payload = {
          clientId: estado.cliente.id,
          recipientId: destinatario.id,
          ingresoUSD: ingresoAsignado,
          salidaUSDT: salida,
          tasa: tasa,
          montoVES: montoVES,
          montoVESManual: tieneVESManual(detalle),
          metodo: metodo,
          profitUSD: ingresoAsignado - salida,
          reportTagId: estado.cliente.reportTagId || null,
          estado: 'PENDING'
        };

        if (multipleGroupId) {
          payload.multipleGroupId = multipleGroupId;
          payload.multipleGroupIndex = i + 1;
        }

        if (comprobantePagoUrl) payload.comprobantePago = comprobantePagoUrl;
        if (comprobanteEgresoUrl) payload.comprobanteAdmin = comprobanteEgresoUrl;

        var res = await fetch(API_URL + '/api/transactions', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
          body: JSON.stringify(payload)
        });
        if (!res.ok) {
          var err = await res.json().catch(function() { return {}; });
          if (err.code === 'KYC_REQUIRED') {
            mostrarAlertaKyc(err);
            showToast('warning', 'KYC obligatorio', err.error || 'El cliente debe completar KYC antes de registrar este giro.');
            throw new Error('KYC obligatorio');
          }
          if (err.code === 'OFAC_REQUIRED') {
            mostrarAlertaOfac(err);
            showToast('warning', 'Verificación OFAC obligatoria', err.error || 'Debe completar la verificación OFAC antes de registrar este giro.');
            throw new Error('Verificación OFAC obligatoria');
          }
          if (err.code === 'MIN_TRANSACTION_REQUIRED') {
            throw new Error(err.error || 'La transacción no cumple el monto mínimo.');
          }
          throw new Error(err.error || 'Error al guardar');
        }
      }

      document.getElementById('modalExitoTitulo').textContent = destinatarios.length === 1
        ? '¡Transacción guardada!'
        : '¡Transacciones guardadas!';
      document.getElementById('modalExitoDescripcion').textContent = destinatarios.length === 1
        ? 'La operación fue registrada exitosamente.'
        : 'Se registraron ' + destinatarios.length + ' transacciones exitosamente.';

      var modal = document.getElementById('modalExito');
      var content = document.getElementById('modalContentExito');
      modal.classList.remove('hidden');
      modal.classList.add('anim-overlay');
      setTimeout(function() { content.style.transform = 'scale(1)'; content.classList.add('anim-modal'); }, 10);

    } catch (e) {
      showToast('error', 'Error al guardar', e.message);
      btn.disabled = false;
      btn.innerHTML = '<Save class="w-4 h-4"/> Guardar transacción';
    }
  }

  function nuevaTransaccion() {
    document.getElementById('modalExito').classList.add('hidden');
    document.getElementById('modalContentExito').style.transform = 'scale(0.95)';
    document.getElementById('modalContentExito').classList.remove('anim-modal');

    estado.paso = 1;
    estado.cliente = null;
    estado.destinatario = null;
    estado.destinatarios = [];
    estado.detallesPorDestinatario = {};
    estado.metodo = '';
    estado.banco = '';
    estado.ingreso = 0;
    estado.salida = 0;
    estado.tasa = 0;
    Object.keys(previewUrls).forEach(function(key) {
      revokePreviewUrl(key);
    });
    estado.comprobantes = { egresos: {} };
    resetPreview('pago');
    ocultarAlertaKyc();
    ocultarAlertaOfac();

    limpiarBusqueda();
    actualizarInfoDestinatariosSeleccionados();
    document.getElementById('txIngreso').value = '';
    renderDetallesDestinatarios();
    renderComprobantesEgreso();
    toggleTasaPorBanco();
    calcularTransaccion();

    var labelP = document.getElementById('labelPago');
    var dropP = document.getElementById('dropPago');
    labelP.textContent = 'Arrastra o haz click';
    labelP.classList.remove('text-emerald-600');
    dropP.classList.remove('border-emerald-400', 'bg-emerald-50');
    dropP.classList.add('border-slate-300', 'bg-slate-50');
    document.getElementById('filePago').value = '';

    document.getElementById('btnGuardarFinal').disabled = false;
    document.getElementById('btnGuardarFinal').innerHTML = '<Save class="w-4 h-4"/> Guardar transacción';

    mostrarPaso(1);
  }

  // ===================== MODAL EXISTENTE =====================
  function abrirModalExistente() {
    if (!estado.cliente) {
      showToast('warning', 'Selecciona un cliente', 'Elige primero el cliente que hará el envío.');
      return;
    }

    var m = document.getElementById('modalExistente');
    var c = document.getElementById('modalContentExistente');
    m.classList.remove('hidden');
    m.classList.add('anim-overlay');
    setTimeout(function() {
      c.style.transform = 'scale(1)';
      c.classList.add('anim-modal');
      var input = document.getElementById('buscarExistente');
      if (input) input.focus();
    }, 10);
    cargarDestinatariosExistentes();
  }

  function cerrarModalExistente() {
    var m = document.getElementById('modalExistente');
    var c = document.getElementById('modalContentExistente');
    c.style.transform = 'scale(0.95)';
    c.classList.remove('anim-modal');
    setTimeout(function() { m.classList.add('hidden'); m.classList.remove('anim-overlay'); }, 200);
  }

  function actualizarBusquedaExistente(value) {
    busquedaExistente = value || '';
    var clearBtn = document.getElementById('clearBusquedaExistente');
    if (clearBtn) clearBtn.classList.toggle('hidden', !busquedaExistente.trim());
    if (debounceBusquedaExistente) clearTimeout(debounceBusquedaExistente);
    debounceBusquedaExistente = setTimeout(function() {
      cargarDestinatariosExistentes();
    }, 250);
  }

  function limpiarBusquedaExistente() {
    busquedaExistente = '';
    var input = document.getElementById('buscarExistente');
    var clearBtn = document.getElementById('clearBusquedaExistente');
    if (input) input.value = '';
    if (clearBtn) clearBtn.classList.add('hidden');
    if (debounceBusquedaExistente) clearTimeout(debounceBusquedaExistente);
    cargarDestinatariosExistentes();
  }

  async function cargarDestinatariosExistentes() {
    if (!estado.cliente) return;
    var cont = document.getElementById('listaExistentes');
    var sin = document.getElementById('sinExistentes');
    var requestId = ++existentesRequestId;

    cont.innerHTML = '<div class="rounded-2xl border border-dashed border-slate-200 bg-slate-50 px-5 py-8 text-center text-sm font-semibold text-slate-400">Buscando destinatarios...</div>';
    sin.classList.add('hidden');

    try {
      var token = localStorage.getItem('adglobal_token');
      var params = new URLSearchParams({ limit: '36', offset: '0' });
      if (busquedaExistente.trim()) params.set('search', busquedaExistente.trim());

      var res = await fetch(API_URL + '/api/recipients?' + params.toString(), {
        headers: { 'Authorization': 'Bearer ' + token }
      });
      if (!res.ok) throw new Error('Error');
      var data = await res.json();
      if (requestId !== existentesRequestId) return;

      existentesVista = (data.items || []).map(function(r) {
        return mapDestinatarioWizard(r);
      });
      guardarDestinatariosEnCatalogo(estado.cliente.id, existentesVista);
      renderDestinatariosExistentes();
    } catch (err) {
      if (requestId !== existentesRequestId) return;
      existentesVista = [];
      cont.innerHTML = '';
      document.getElementById('sinExistentesTitulo').textContent = 'Error al buscar';
      document.getElementById('sinExistentesDescripcion').textContent = 'Intenta nuevamente en unos segundos.';
      sin.classList.remove('hidden');
    }
  }

  function renderDestinatariosExistentes() {
    var cont = document.getElementById('listaExistentes');
    var sin = document.getElementById('sinExistentes');
    if (existentesVista.length === 0) {
      cont.innerHTML = '';
      document.getElementById('sinExistentesTitulo').textContent = busquedaExistente.trim() ? 'Sin coincidencias' : 'Sin destinatarios';
      document.getElementById('sinExistentesDescripcion').textContent = busquedaExistente.trim()
        ? 'Prueba con otro nombre, cédula, teléfono, banco o cuenta.'
        : 'Todavía no hay destinatarios registrados en el sistema.';
      sin.classList.remove('hidden');
      return;
    }

    sin.classList.add('hidden');
    cont.innerHTML = existentesVista.map(function(d) {
      var seleccionado = estado.destinatarios.some(function(item) { return item.id === d.id; });
      var nombre = escapeHtml(d.nombre);
      var banco = escapeHtml(d.banco);
      var cuenta = escapeHtml(d.cuenta);
      var telefono = escapeHtml(d.telefono);
      var identificacion = escapeHtml(d.identificacion);
      var clienteOrigen = d.clienteOrigen ? escapeHtml('De: ' + d.clienteOrigen) : '';
      var meta = [];
      if (telefono) meta.push('Tel: ' + telefono);
      if (identificacion) meta.push('CI: ' + identificacion);

      return '<article class="rounded-2xl border border-slate-200 bg-white p-4 shadow-[0_14px_30px_-26px_rgba(15,23,42,0.35)] flex items-start gap-3">' +
        '<div class="w-10 h-10 rounded-xl ' + (seleccionado ? 'bg-emerald-500 text-white' : 'bg-indigo-50 text-indigo-600') + ' flex items-center justify-center text-sm font-bold shrink-0">' + (seleccionado ? '✓' : nombre.charAt(0)) + '</div>' +
        '<div class="min-w-0 flex-1">' +
          '<p class="font-bold text-sm text-slate-800 truncate">' + nombre + '</p>' +
          '<p class="text-xs text-slate-500 font-medium truncate">' + banco + ' · ' + cuenta + '</p>' +
          (meta.length > 0 ? '<p class="mt-1 text-[0.65rem] font-semibold text-slate-400 truncate">' + meta.join(' · ') + '</p>' : '') +
          (clienteOrigen ? '<span class="mt-2 inline-block px-1.5 py-0.5 bg-indigo-50 text-indigo-500 rounded text-[0.6rem] font-black uppercase tracking-wider">' + clienteOrigen + '</span>' : '') +
        '</div>' +
        '<button type="button" onclick="seleccionarDestinatarioExistente(\'' + d.id + '\')" class="shrink-0 rounded-xl px-3 py-2 text-xs font-bold transition-all ' + (seleccionado ? 'bg-emerald-50 text-emerald-700 border border-emerald-200 hover:bg-emerald-100' : 'bg-slate-900 text-white hover:bg-slate-800') + '">' +
          (seleccionado ? 'Quitar' : 'Agregar') +
        '</button>' +
      '</article>';
    }).join('');
  }

  function seleccionarDestinatarioExistente(id) {
    var catalogo = obtenerCatalogoDestinatarios(estado.cliente.id);
    var destinatario = catalogo[id];
    if (!destinatario) return;

    if (!destinatariosVista.some(function(item) { return item.id === id; })) {
      destinatariosVista.unshift(destinatario);
    }

    seleccionarDestinatario(id);
    renderDestinatariosExistentes();
  }

  // ===================== MODAL DESTINATARIO =====================
  function abrirModalDestinatario() {
    if (!estado.cliente) return;
    document.getElementById('destClienteId').value = estado.cliente.id;
    var m = document.getElementById('modalDestinatario');
    var c = document.getElementById('modalContentDestinatario');
    m.classList.remove('hidden');
    m.classList.add('anim-overlay');
    setTimeout(function() { c.style.transform = 'scale(1)'; c.classList.add('anim-modal'); }, 10);
  }

  function cerrarModalDestinatario() {
    var m = document.getElementById('modalDestinatario');
    var c = document.getElementById('modalContentDestinatario');
    c.style.transform = 'scale(0.95)';
    c.classList.remove('anim-modal');
    setTimeout(function() { m.classList.add('hidden'); m.classList.remove('anim-overlay'); }, 200);
  }

  async function guardarDestinatario(e) {
    e.preventDefault();
    var btn = document.getElementById('btnGuardarDestinatario');
    btn.disabled = true;
    btn.innerHTML = '<svg class="animate-spin w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> Guardando...';

    var payload = {
      name: document.getElementById('destName').value,
      relationship: document.getElementById('destRel').value,
      phone: document.getElementById('destPhone').value,
      bank: document.getElementById('destBank').value,
      accountNumber: document.getElementById('destAccount').value,
      accountType: document.getElementById('destAccountType').value,
      identification: document.getElementById('destId').value
    };

    try {
      var token = localStorage.getItem('adglobal_token');
      var res = await fetch(API_URL + '/api/clients/' + estado.cliente.id + '/recipients', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
        body: JSON.stringify(payload)
      });
      if (!res.ok) throw new Error('Error creando destinatario');
      var data = await res.json();
      showToast('success', 'Destinatario creado', payload.name + ' fue registrado.');
      e.target.reset();
      cerrarModalDestinatario();
      limpiarBusquedaDestinatarios(false);
      paginacionDestinatarios.offset = 0;
      paginacionDestinatarios.total = 0;
      paginacionDestinatarios.hasMore = false;
      destinatariosVista = [];
      if (estado.cliente) {
        var nuevoDestinatario = mapDestinatarioWizard(data);
        guardarDestinatariosEnCatalogo(estado.cliente.id, [nuevoDestinatario]);
        cargarDestinatariosWizard(estado.cliente.id, { reset: true });
      }
    } catch (err) {
      showToast('error', 'Error', err.message);
    } finally {
      btn.disabled = false;
      btn.innerHTML = 'Guardar';
    }
  }
</script>
