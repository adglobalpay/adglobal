  function crearDropArea(filaId, tipo) {
    var container = document.createElement('div');
    container.className = 'flex flex-col items-center justify-center w-full h-full p-0.5';
    
    var dropArea = document.createElement('div');
    dropArea.className = 'w-7 h-7 md:w-8 md:h-8 border-2 border-dashed border-slate-300 rounded-lg bg-slate-50 flex items-center justify-center cursor-pointer hover:border-indigo-400 hover:bg-indigo-50 hover:text-indigo-600 text-slate-400 transition-all duration-300';
    dropArea.innerHTML = svgUpload;
    
    var fileInput = document.createElement('input');
    fileInput.type = 'file';
    fileInput.accept = 'image/*,application/pdf';
    fileInput.className = 'hidden';
    
    var fileNameSpan = document.createElement('span');
    fileNameSpan.className = 'text-[0.5rem] font-bold text-slate-400 mt-0.5 truncate max-w-[28px] md:max-w-[32px] text-center absolute -bottom-3';
    fileNameSpan.textContent = '';
    
    dropArea.ondragover = function(e) {
      e.preventDefault();
      this.classList.add('border-indigo-500', 'bg-indigo-100', 'text-indigo-600', 'scale-110');
    };
    
    dropArea.ondragleave = function(e) {
      e.preventDefault();
      this.classList.remove('border-indigo-500', 'bg-indigo-100', 'text-indigo-600', 'scale-110');
    };
    
    dropArea.ondrop = function(e) {
      e.preventDefault();
      this.classList.remove('border-indigo-500', 'bg-indigo-100', 'text-indigo-600', 'scale-110');
      var file = e.dataTransfer.files[0];
      if (file) {
        procesarArchivo(file, filaId, tipo, fileNameSpan, dropArea);
      }
    };
    
    dropArea.onclick = function() {
      fileInput.click();
    };
    
    fileInput.onchange = function(e) {
      var file = e.target.files[0];
      if (file) {
        procesarArchivo(file, filaId, tipo, fileNameSpan, dropArea);
      }
    };
    
    container.appendChild(dropArea);
    container.appendChild(fileInput);
    container.appendChild(fileNameSpan);
    
    var wrapper = document.createElement('div');
    wrapper.className = 'relative flex justify-center items-center h-full w-full';
    wrapper.appendChild(container);
    return wrapper;
  }

  // Helper para mostrar toast
  function showToast(type, message, description) {
    window.dispatchEvent(new CustomEvent('show-toast', {
      detail: { type: type, message: message, description: description }
    }));
  }

  function procesarArchivo(file, filaId, tipo, fileNameSpan, dropArea) {
    var tiposPermitidos = ['image/jpeg', 'image/png', 'image/webp', 'application/pdf'];
    var esValido = tiposPermitidos.includes(file.type);
    
    if (!esValido) {
      showToast('error', 'Tipo de archivo no permitido', 'Solo se permiten imágenes (JPG, PNG, WEBP) o PDF');
      return false;
    }

    if (file.size > 5 * 1024 * 1024) {
      showToast('error', 'Archivo demasiado grande', 'El archivo no debe superar los 5MB');
      return false;
    }
    
    var comprobantes = window.comprobantes || {};
    if (!comprobantes[filaId]) comprobantes[filaId] = {};
    comprobantes[filaId][tipo] = {
      nombre: file.name,
      tipo: file.type,
      tamaño: file.size,
      archivo: file
    };
    window.comprobantes = comprobantes;
    
    var nombreCorto = file.name.length > 6 ? file.name.substring(0, 4) + '...' : file.name;
    fileNameSpan.textContent = nombreCorto;
    fileNameSpan.classList.remove('text-slate-400');
    fileNameSpan.classList.add('text-emerald-600');
    
    dropArea.classList.remove('border-slate-300', 'bg-slate-50', 'text-slate-400');
    dropArea.classList.add('border-emerald-500', 'bg-emerald-50', 'text-emerald-600');
    dropArea.innerHTML = svgCheck;
    
    return true;
  }

