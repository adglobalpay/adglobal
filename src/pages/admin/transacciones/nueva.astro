  function calcularFila(filaId) {
    var fila = document.getElementById(filaId);
    if (!fila) return;
    
    var ingresoInputs = fila.querySelectorAll('input[type="number"]');
    if(ingresoInputs.length < 3) return;

    var ingreso = parseFloat(ingresoInputs[0].value) || 0;
    var salida = parseFloat(ingresoInputs[1].value) || 0;
    var tasa = parseFloat(ingresoInputs[2].value) || 0;
    
    var montoBs = salida * tasa;
    var profit = ingreso - salida;
    
    fila.querySelector('.monto-bs').textContent = new Intl.NumberFormat('es-US').format(montoBs);
    fila.querySelector('.profit').textContent = '$' + new Intl.NumberFormat('es-US').format(profit);
  }

  function eliminarFila(filaId) {
    var fila = document.getElementById(filaId);
    if (fila) {
      fila.style.opacity = '0';
      fila.style.transform = 'translateX(-20px)';
      setTimeout(() => {
        fila.remove();
        var index = filas.indexOf(filaId);
        if (index > -1) filas.splice(index, 1);
        if (window.comprobantes && window.comprobantes[filaId]) {
          delete window.comprobantes[filaId];
        }
      }, 300);
    }
  }

