  <!-- Modal Nuevo Destinatario -->
  <div id="modalDestinatario" class="fixed inset-0 z-[90] flex items-end md:items-center justify-center hidden">
    <div class="fixed inset-0 bg-slate-950/60 backdrop-blur-lg" onclick="cerrarModalDestinatario()"></div>
    <div class="relative w-full max-w-lg overflow-hidden rounded-t-3xl md:rounded-3xl bg-white shadow-[0_24px_80px_-20px_rgba(2,6,23,0.35)] transition-all duration-200" id="modalContentDestinatario">
      <!-- Header oscuro con acento esmeralda -->
      <div class="relative bg-slate-900 px-5 py-6 sm:px-8 sm:py-7">
        <div class="absolute inset-0 opacity-40">
          <div class="absolute -top-10 -right-10 h-40 w-40 rounded-full bg-emerald-500/20 blur-3xl"></div>
          <div class="absolute -bottom-8 -left-8 h-32 w-32 rounded-full bg-teal-500/10 blur-3xl"></div>
        </div>
        <div class="relative flex items-start justify-between gap-4">
          <div class="flex items-start gap-3 sm:gap-4">
            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-slate-800 text-xl font-black text-emerald-400 shadow-inner ring-1 ring-white/10">
              <Users class="w-5 h-5"/>
            </div>
            <div class="min-w-0">
              <p class="text-[0.6rem] font-black uppercase tracking-[0.2em] text-emerald-400/80">Nuevo registro</p>
              <h2 class="mt-0.5 text-lg sm:text-2xl font-bold tracking-tight text-white">Nuevo Destinatario</h2>
              <p class="mt-1 max-w-md text-xs sm:text-sm font-medium text-slate-400 leading-relaxed">
                Completa los datos bancarios y de contacto de la persona que recibirá los fondos.
              </p>
            </div>
          </div>
          <button onclick="cerrarModalDestinatario()" class="inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-slate-800 text-slate-400 transition-all hover:bg-slate-700 hover:text-white ring-1 ring-white/10">
            <X class="w-4 h-4" />
          </button>
        </div>
      </div>

      <form id="formDestinatario" class="relative" onsubmit="guardarDestinatario(event)">
        <div class="p-5 sm:p-8">
          <input type="hidden" id="destClienteId" />
          <div class="grid gap-4 sm:grid-cols-2">
            <div class="sm:col-span-2">
              <label class="mb-1.5 block text-[0.65rem] font-black uppercase tracking-[0.18em] text-slate-500">Nombre completo *</label>
              <input type="text" id="destName" required class="w-full rounded-xl border border-slate-200 bg-slate-50/50 px-3.5 py-2.5 text-sm font-semibold text-slate-800 outline-none transition-all placeholder:text-slate-400 hover:bg-white hover:border-slate-300 focus:border-emerald-400 focus:bg-white focus:ring-[3px] focus:ring-emerald-500/10" placeholder="Ej. Amparo Gomez">
            </div>
            <div>
              <label class="mb-1.5 block text-[0.65rem] font-black uppercase tracking-[0.18em] text-slate-500">Relación</label>
              <select id="destRel" class="w-full rounded-xl border border-slate-200 bg-slate-50/50 px-3.5 py-2.5 text-sm font-semibold text-slate-800 outline-none transition-all hover:bg-white hover:border-slate-300 focus:border-emerald-400 focus:bg-white focus:ring-[3px] focus:ring-emerald-500/10">
                <option value="Familiar">Familiar</option>
