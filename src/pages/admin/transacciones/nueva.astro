  function cambiarCliente() {
    limpiarBusqueda();
    document.getElementById('buscarCliente').focus();
  }

  // ===================== PASOS / WIZARD =====================
  function mostrarPaso(n) {
    if (n !== 4) {
      ocultarAlertaKyc();
      ocultarAlertaOfac();
    }
    for (var i = 1; i <= 4; i++) {
      document.getElementById('step' + i).classList.add('hidden');
    }
    document.getElementById('step' + n).classList.remove('hidden');
    estado.paso = n;
    actualizarStepper();
    actualizarBotonesNav();

    if (n === 2 && estado.cliente) {
      cargarDestinatariosWizard(estado.cliente.id);
    }
    if (n === 3) {
      renderDetallesDestinatarios();
      renderComprobantesEgreso();
      calcularTransaccion();
    }
    if (n === 4) {
      renderResumen();
    }
  }

  function actualizarStepper() {
    var ancho = ((estado.paso - 1) / 3) * 100;
    document.getElementById('stepLine').style.width = ancho + '%';

    for (var i = 1; i <= 4; i++) {
      var dot = document.getElementById('dot' + i);
      var label = document.getElementById('label' + i);
      if (i < estado.paso) {
        dot.className = 'w-9 h-9 md:w-10 md:h-10 rounded-full bg-emerald-500 text-white flex items-center justify-center text-sm font-bold shadow-md transition-all duration-300 ring-4 ring-emerald-50';
        dot.innerHTML = '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>';
        label.className = 'text-[0.65rem] md:text-xs font-bold text-emerald-600 uppercase tracking-wider';
      } else if (i === estado.paso) {
        dot.className = 'w-9 h-9 md:w-10 md:h-10 rounded-full bg-indigo-600 text-white flex items-center justify-center text-sm font-bold shadow-md transition-all duration-300 ring-4 ring-indigo-50';
        dot.textContent = i;
        label.className = 'text-[0.65rem] md:text-xs font-bold text-indigo-600 uppercase tracking-wider';
      } else {
        dot.className = 'w-9 h-9 md:w-10 md:h-10 rounded-full bg-slate-200 text-slate-500 flex items-center justify-center text-sm font-bold transition-all duration-300';
        dot.textContent = i;
        label.className = 'text-[0.65rem] md:text-xs font-bold text-slate-400 uppercase tracking-wider';
      }
    }
  }

  function actualizarBotonesNav() {
    var btnAtras = document.getElementById('btnAtras');
    var btnSig = document.getElementById('btnSiguiente');
    var nav = document.getElementById('navPasos');

    if (estado.paso === 4) {
      nav.classList.add('hidden');
      return;
    }
    nav.classList.remove('hidden');
    btnAtras.classList.toggle('hidden', estado.paso === 1);
    btnSig.innerHTML = estado.paso === 3 ? 'Revisar <ChevronRight class="w-4 h-4"/>' : 'Siguiente <ChevronRight class="w-4 h-4"/>';
  }

  function pasoSiguiente() {
    if (estado.paso === 1) {
      if (!estado.cliente) {
        showToast('warning', 'Selecciona un cliente', 'Busca y selecciona un cliente para continuar.');
        return;
      }
    }
    if (estado.paso === 2) {
      if (!estado.destinatarios || estado.destinatarios.length === 0) {
        showToast('warning', 'Selecciona un destinatario', 'Elige quién recibe el envío.');
        return;
      }
    }
    if (estado.paso === 3) {
      var ing = parseFloat(document.getElementById('txIngreso').value) || 0;
      if (ing <= 0) { showToast('warning', 'Monto inválido', 'El ingreso debe ser mayor a 0.'); return; }

      var destinatarios = estado.destinatarios || [];
      for (var idx = 0; idx < destinatarios.length; idx++) {
        var destinatario = destinatarios[idx];
        var detalle = obtenerDetalleDestinatario(destinatario.id);
        var salida = parseFloat(detalle.salida) || 0;
        var requiereTasa = !bancoEsBinance(detalle.banco);
        var tasa = requiereTasa ? (parseFloat(detalle.tasa) || 0) : 0;
        var vesManual = detalle.ves === undefined || detalle.ves === null ? '' : String(detalle.ves).trim();
        var vesManualNumero = vesManual === '' ? null : parseFloat(vesManual);
        var nombreDestino = destinatario.nombre || ('Destinatario ' + (idx + 1));

        if (!detalle.metodo) { showToast('warning', 'Falta método', 'Selecciona un método para ' + nombreDestino + '.'); return; }
        if (!detalle.banco) { showToast('warning', 'Falta banco', 'Selecciona un banco para ' + nombreDestino + '.'); return; }
        if (salida <= 0) { showToast('warning', 'Monto inválido', 'La salida de ' + nombreDestino + ' debe ser mayor a 0.'); return; }
        if (requiereTasa && tasa <= 0) { showToast('warning', 'Tasa inválida', 'La tasa de ' + nombreDestino + ' debe ser mayor a 0.'); return; }
        if (vesManual !== '' && (isNaN(vesManualNumero) || vesManualNumero < 0)) { showToast('warning', 'VES inválido', 'El monto VES de ' + nombreDestino + ' debe ser 0 o mayor.'); return; }

        detalle.salida = salida;
        detalle.tasa = tasa;
        if (vesManual !== '') detalle.ves = vesManualNumero;
      }
      estado.ingreso = ing;
    }
    mostrarPaso(estado.paso + 1);
  }

  function pasoAnterior() {
    mostrarPaso(estado.paso - 1);
  }

  function volverPaso(n) {
    mostrarPaso(n);
  }

  // ===================== DESTINATARIOS =====================
  async function cargarDestinatariosWizard(clientId, options) {
    options = options || {};
    var reset = options.reset !== false;
    var cont = document.getElementById('listaDestinatarios');
    var sin = document.getElementById('sinDestinatarios');
    var offset = reset ? 0 : paginacionDestinatarios.offset;
    var requestId = ++destinatariosRequestId;

    try {
      paginacionDestinatarios.cargando = true;
      actualizarAccionesDestinatarios();
      if (reset) {
        cont.innerHTML = '<div class="md:col-span-2 rounded-2xl border border-dashed border-slate-200 bg-slate-50 px-5 py-8 text-center text-sm font-semibold text-slate-400">Buscando destinatarios...</div>';
        sin.classList.add('hidden');
      }

      var token = localStorage.getItem('adglobal_token');
      var params = new URLSearchParams({
        limit: String(paginacionDestinatarios.limit),
        offset: String(offset)
      });
      if (busquedaDestinatario.trim()) params.set('search', busquedaDestinatario.trim());

      var res = await fetch(API_URL + '/api/clients/' + clientId + '/recipients?' + params.toString(), {
        headers: { 'Authorization': 'Bearer ' + token }
      });
      if (!res.ok) throw new Error('Error');
      var data = await res.json();

      if (requestId !== destinatariosRequestId) {
        return;
      }

      var respuestaEsArray = Array.isArray(data);
      var rawItems = respuestaEsArray ? data : (data.items || []);
      var lista = rawItems.map(function(r) {
        return mapDestinatarioWizard(r);
      });
      if (respuestaEsArray) {
        lista = filtrarDestinatariosLegacy(lista);
      }
      guardarDestinatariosEnCatalogo(clientId, lista);
      destinatariosVista = reset ? lista : destinatariosVista.concat(lista.filter(function(item) {
        return !destinatariosVista.some(function(existing) { return existing.id === item.id; });
      }));

      paginacionDestinatarios.offset = offset + lista.length;
      paginacionDestinatarios.total = respuestaEsArray ? lista.length : Number(data.total || 0);
      paginacionDestinatarios.hasMore = respuestaEsArray ? false : Boolean(data.hasMore);

      var catalogo = obtenerCatalogoDestinatarios(clientId);
      estado.destinatarios = estado.destinatarios.filter(function(selected) {
        return !!catalogo[selected.id];
      });
      estado.destinatario = estado.destinatarios[0] || null;

      renderDestinatariosWizard(destinatariosVista);
    } catch (e) {
      if (requestId !== destinatariosRequestId) {
        return;
      }
      destinatariosVista = [];
      paginacionDestinatarios.offset = 0;
      paginacionDestinatarios.total = 0;
      paginacionDestinatarios.hasMore = false;
      cont.innerHTML = '';
      actualizarEstadoVacioDestinatarios(!!normalizeSearchValue(busquedaDestinatario));
      sin.classList.remove('hidden');
    } finally {
      if (requestId === destinatariosRequestId) {
        paginacionDestinatarios.cargando = false;
        actualizarAccionesDestinatarios();
      }
    }
  }

  function renderDestinatariosWizard(lista) {
    var cont = document.getElementById('listaDestinatarios');
    var sin = document.getElementById('sinDestinatarios');
    var hasQuery = !!normalizeSearchValue(busquedaDestinatario);

    if (lista.length === 0) {
      cont.innerHTML = '';
      actualizarEstadoVacioDestinatarios(hasQuery);
      sin.classList.remove('hidden');
      actualizarInfoDestinatariosSeleccionados();
      actualizarAccionesDestinatarios();
      return;
    }
    sin.classList.add('hidden');
    cont.innerHTML = lista.map(function(d) {
      var seleccionado = estado.destinatarios.some(function(item) { return item.id === d.id; });
      var sel = seleccionado ? 'ring-2 ring-emerald-500 border-emerald-300 bg-emerald-50/50' : 'border-slate-200 hover:border-emerald-300 hover:bg-emerald-50/30';
      var nombre = escapeHtml(d.nombre);
      var banco = escapeHtml(d.banco);
      var cuenta = escapeHtml(d.cuenta);
      var relacion = escapeHtml(d.relacion);
      var telefono = escapeHtml(d.telefono);
      var identificacion = escapeHtml(d.identificacion);
      var clienteOrigen = d.clienteOrigen && d.clienteId !== estado.cliente.id ? escapeHtml('De: ' + d.clienteOrigen) : '';
      var meta = [];
      if (telefono) meta.push('Tel: ' + telefono);
      if (identificacion) meta.push('CI: ' + identificacion);
      return '<button type="button" onclick="seleccionarDestinatario(\'' + d.id + '\')" class="text-left p-4 rounded-xl border-2 ' + sel + ' transition-all duration-200 flex items-start gap-3">' +
        '<div class="w-10 h-10 rounded-lg ' + (seleccionado ? 'bg-emerald-500 text-white' : 'bg-emerald-100 text-emerald-600') + ' flex items-center justify-center text-sm font-bold shrink-0">' + (seleccionado ? '✓' : nombre.charAt(0)) + '</div>' +
        '<div class="flex-1 min-w-0">' +
          '<p class="font-bold text-sm text-slate-800 truncate">' + nombre + '</p>' +
          '<p class="text-xs text-slate-500 font-medium truncate">' + banco + ' · ' + cuenta + '</p>' +
          (meta.length > 0 ? '<p class="mt-1 text-[0.65rem] font-semibold text-slate-400 truncate">' + meta.join(' · ') + '</p>' : '') +
          '<div class="mt-2 flex flex-wrap items-center gap-1.5">' +
            '<span class="inline-block px-1.5 py-0.5 bg-slate-100 text-slate-500 rounded text-[0.6rem] font-black uppercase tracking-wider">' + relacion + '</span>' +
            (clienteOrigen ? '<span class="inline-block px-1.5 py-0.5 bg-indigo-50 text-indigo-500 rounded text-[0.6rem] font-black uppercase tracking-wider">' + clienteOrigen + '</span>' : '') +
          '</div>' +
        '</div>' +
      '</button>';
    }).join('');
    actualizarInfoDestinatariosSeleccionados();
    actualizarAccionesDestinatarios();
  }

  function seleccionarDestinatario(id) {
    var catalogo = obtenerCatalogoDestinatarios(estado.cliente.id);
    var d = catalogo[id];
    if (!d) return;
    var existe = estado.destinatarios.some(function(item) { return item.id === id; });
    if (existe) {
      estado.destinatarios = estado.destinatarios.filter(function(item) { return item.id !== id; });
      delete estado.detallesPorDestinatario[id];
      if (estado.comprobantes.egresos) delete estado.comprobantes.egresos[id];
      revokePreviewUrl('egreso-' + id);
    } else {
      estado.destinatarios.push(d);
      obtenerDetalleDestinatario(d.id);
    }
    estado.destinatario = estado.destinatarios[0] || null;
    renderDestinatariosWizard(destinatariosVista);
    renderComprobantesEgreso();
  }

  function actualizarInfoDestinatariosSeleccionados() {
    var info = document.getElementById('destinatariosSeleccionadosInfo');
    if (!info) return;
    var total = estado.destinatarios ? estado.destinatarios.length : 0;
    info.classList.toggle('hidden', total === 0);
    info.textContent = total + ' destinatario' + (total === 1 ? '' : 's') + ' seleccionado' + (total === 1 ? '' : 's');
  }

  function obtenerDetalleDestinatario(id) {
    if (!estado.detallesPorDestinatario) estado.detallesPorDestinatario = {};
    if (!estado.detallesPorDestinatario[id]) {
      var catalogo = estado.cliente ? obtenerCatalogoDestinatarios(estado.cliente.id) : {};
      var destinatario = catalogo[id] || {};
      estado.detallesPorDestinatario[id] = {
        metodo: '',
        banco: destinatario.banco || '',
        salida: '',
        tasa: '',
        ves: ''
      };
    }
    return estado.detallesPorDestinatario[id];
  }

  function actualizarDetalleDestinatario(id, campo, valor) {
    var detalle = obtenerDetalleDestinatario(id);
    detalle[campo] = valor;
    if (campo === 'banco') {
      if (bancoEsBinance(valor)) detalle.tasa = '';
      renderDetallesDestinatarios();
    }
    calcularTransaccion();
  }

  function obtenerSalidaDetalle(destinatario) {
    var detalle = obtenerDetalleDestinatario(destinatario.id);
    return parseFloat(detalle.salida) || 0;
  }

  function obtenerTotalSalida(destinatarios) {
    return destinatarios.reduce(function(total, destinatario) {
      return total + obtenerSalidaDetalle(destinatario);
    }, 0);
  }

  function obtenerIngresoAsignado(destinatario, destinatarios, ingresoTotal) {
    var totalSalida = obtenerTotalSalida(destinatarios);
    var salida = obtenerSalidaDetalle(destinatario);
    if (totalSalida > 0) {
      return ingresoTotal * (salida / totalSalida);
    }
    return destinatarios.length > 0 ? ingresoTotal / destinatarios.length : ingresoTotal;
  }

  function tieneVESManual(detalle) {
    return detalle && detalle.ves !== undefined && detalle.ves !== null && String(detalle.ves).trim() !== '';
  }

  function obtenerVESDetalle(destinatario, destinatarios, ingresoTotal) {
    var detalle = obtenerDetalleDestinatario(destinatario.id);
    if (tieneVESManual(detalle)) {
      var manual = parseFloat(detalle.ves);
      if (!isNaN(manual)) return manual;
    }
    var ingresoAsignado = obtenerIngresoAsignado(destinatario, destinatarios, ingresoTotal);
    var tasa = bancoEsBinance(detalle.banco) ? 0 : (parseFloat(detalle.tasa) || 0);
    return ingresoAsignado * tasa;
  }

