<style>
  .custom-scrollbar::-webkit-scrollbar { width: 6px; }
  .custom-scrollbar::-webkit-scrollbar-track { background: #f8fafc; border-radius: 3px; }
  .custom-scrollbar::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 3px; }
  .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
</style>

<script is:inline>
  var clientes = [];
  var destinatariosPorCliente = {};
  var metodos = [];
  var bancosLista = [];

  var API_URL = window.__ADGLOBAL_API_URL__ || 'https://backend-global-production.up.railway.app';

  var estado = {
    paso: 1,
    cliente: null,
    destinatario: null,
    metodo: '',
    banco: '',
    ingreso: 0,
    salida: 0,
    tasa: 0,
    comprobantes: {}
  };
  var previewUrls = {
    pago: null,
    admin: null
  };

  function formatFileSize(bytes) {
    if (!bytes) return '0 KB';
    if (bytes < 1024) return bytes + ' B';
    if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
    return (bytes / (1024 * 1024)).toFixed(2) + ' MB';
  }

  function revokePreviewUrl(tipo) {
    if (previewUrls[tipo]) {
      URL.revokeObjectURL(previewUrls[tipo]);
      previewUrls[tipo] = null;
    }
  }

  function resetPreview(tipo) {
    var sufijo = tipo === 'pago' ? 'Pago' : 'Admin';
    var preview = document.getElementById('preview' + sufijo);
    var img = document.getElementById('preview' + sufijo + 'Img');
    var pdf = document.getElementById('preview' + sufijo + 'Pdf');
    var open = document.getElementById('preview' + sufijo + 'Open');
    var name = document.getElementById('preview' + sufijo + 'Name');
    var meta = document.getElementById('preview' + sufijo + 'Meta');

    revokePreviewUrl(tipo);

    if (preview) preview.classList.add('hidden');
    if (img) {
      img.classList.add('hidden');
      img.removeAttribute('src');
    }
    if (pdf) {
      pdf.classList.add('hidden');
      pdf.removeAttribute('src');
    }
    if (open) open.setAttribute('href', '#');
    if (name) name.textContent = 'Archivo';
    if (meta) meta.textContent = '0 KB';
  }

  function renderPreviewComprobante(tipo, file) {
    var sufijo = tipo === 'pago' ? 'Pago' : 'Admin';
    var preview = document.getElementById('preview' + sufijo);
    var img = document.getElementById('preview' + sufijo + 'Img');
    var pdf = document.getElementById('preview' + sufijo + 'Pdf');
    var open = document.getElementById('preview' + sufijo + 'Open');
    var name = document.getElementById('preview' + sufijo + 'Name');
    var meta = document.getElementById('preview' + sufijo + 'Meta');
    var objectUrl = URL.createObjectURL(file);

    revokePreviewUrl(tipo);
    previewUrls[tipo] = objectUrl;

    if (preview) preview.classList.remove('hidden');
    if (name) name.textContent = file.name;
    if (meta) meta.textContent = formatFileSize(file.size) + ' · ' + (file.type === 'application/pdf' ? 'PDF' : 'Imagen');
    if (open) open.setAttribute('href', objectUrl);

    if (file.type === 'application/pdf') {
      if (img) {
        img.classList.add('hidden');
        img.removeAttribute('src');
      }
      if (pdf) {
        pdf.src = objectUrl + '#toolbar=0&navpanes=0&scrollbar=0&view=FitH';
        pdf.classList.remove('hidden');
      }
      return;
    }

    if (pdf) {
      pdf.classList.add('hidden');
      pdf.removeAttribute('src');
    }
    if (img) {
      img.src = objectUrl;
      img.classList.remove('hidden');
    }
  }

  function ocultarAlertaKyc() {
    var box = document.getElementById('kycRequiredAlert');
    var reasons = document.getElementById('kycRequiredReasons');
    var message = document.getElementById('kycRequiredMessage');
    if (box) box.classList.add('hidden');
    if (reasons) reasons.innerHTML = '';
    if (message) message.textContent = '';
  }

  function mostrarAlertaKyc(errorData) {
    var box = document.getElementById('kycRequiredAlert');
    var title = document.getElementById('kycRequiredTitle');
    var message = document.getElementById('kycRequiredMessage');
    var reasons = document.getElementById('kycRequiredReasons');
    var profileLink = document.getElementById('kycRequiredProfileLink');

    if (!box || !title || !message || !reasons || !profileLink || !estado.cliente) return;

    title.textContent = errorData.kycRequestCreated
      ? 'Se generó una solicitud KYC para este cliente'
      : 'El cliente ya tiene KYC pendiente o en proceso';
    message.textContent = errorData.error || 'El cliente debe completar KYC antes de registrar este giro.';
    reasons.innerHTML = (errorData.reasons || []).map(function(reason) {
      return '<li class="flex items-start gap-2"><span class="mt-1 h-2 w-2 rounded-full bg-amber-400 shrink-0"></span><span>' + reason + '</span></li>';
    }).join('');
    profileLink.href = '/admin/clientes/perfil?id=' + encodeURIComponent(estado.cliente.id);
    box.classList.remove('hidden');
  }

  function showToast(type, message, description) {
    window.dispatchEvent(new CustomEvent('show-toast', {
      detail: { type: type, message: message, description: description }
    }));
  }

  // ===================== CARGA INICIAL =====================
  document.addEventListener('DOMContentLoaded', async function() {
    await cargarClientes();
    await cargarMetodosAPI();
    await cargarBancosAPI();
    poblarSelectMetodos();

    // Autocomplete de clientes
    var inputBuscar = document.getElementById('buscarCliente');
    inputBuscar.addEventListener('input', function() {
      var query = this.value.trim().toLowerCase();
      document.getElementById('clearBusqueda').classList.toggle('hidden', !query);
      if (query.length < 2) {
        document.getElementById('resultadosClientes').classList.add('hidden');
        return;
      }
      var resultados = clientes.filter(function(c) {
        return c.nombre.toLowerCase().includes(query)
          || c.telefono.includes(query)
          || c.email.toLowerCase().includes(query);
      });
      renderResultadosClientes(resultados);
    });

    inputBuscar.addEventListener('focus', function() {
      if (this.value.trim().length >= 2) {
        document.getElementById('resultadosClientes').classList.remove('hidden');
      }
    });

    document.addEventListener('click', function(e) {
      if (!document.querySelector('.relative').contains(e.target)) {
        document.getElementById('resultadosClientes').classList.add('hidden');
      }
    });

    // Setup drag & drop para comprobantes
    setupDropZone('dropPago', 'filePago', 'pago');
    setupDropZone('dropAdmin', 'fileAdmin', 'admin');
  });

  function setupDropZone(dropId, inputId, tipo) {
    var dropZone = document.getElementById(dropId);
    var input = document.getElementById(inputId);
    if (!dropZone || !input) return;

    ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(function(eventName) {
      dropZone.addEventListener(eventName, function(e) {
        e.preventDefault();
        e.stopPropagation();
      }, false);
    });

    ['dragenter', 'dragover'].forEach(function(eventName) {
      dropZone.addEventListener(eventName, function() {
        dropZone.classList.add('border-indigo-400', 'bg-indigo-50');
        dropZone.classList.remove('border-slate-300', 'bg-slate-50');
      }, false);
    });

    ['dragleave', 'drop'].forEach(function(eventName) {
      dropZone.addEventListener(eventName, function() {
        if (!estado.comprobantes[tipo]) {
          dropZone.classList.remove('border-indigo-400', 'bg-indigo-50');
          dropZone.classList.add('border-slate-300', 'bg-slate-50');
        }
      }, false);
    });

    dropZone.addEventListener('drop', function(e) {
      var files = e.dataTransfer.files;
      if (files.length > 0) {
        input.files = files;
        procesarComprobante(input, tipo);
      }
    }, false);
  }

  async function cargarClientes() {
    try {
      var token = localStorage.getItem('adglobal_token');
      var res = await fetch(API_URL + '/api/clients', { headers: { 'Authorization': 'Bearer ' + token } });
      if (!res.ok) throw new Error('Error');
      var data = await res.json();
      clientes = data.map(function(c) {
        return {
          id: c.id,
          nombre: c.firstName + (c.lastName ? ' ' + c.lastName : ''),
          telefono: c.phone || '',
          email: c.email || ''
        };
      });
    } catch (e) {
      console.error('Error cargando clientes:', e);
    }
  }

  async function cargarMetodosAPI() {
    try {
      var token = localStorage.getItem('adglobal_token');
      var res = await fetch(API_URL + '/api/payment-methods', { headers: { 'Authorization': 'Bearer ' + token } });
      if (!res.ok) throw new Error('Error');
      var data = await res.json();
      metodos = data.filter(function(m) { return m.isActive !== false; }).map(function(pm) {
        return { _id: pm.id, nombre: pm.name };
      });
    } catch (e) {
      console.error('Error cargando metodos:', e);
    }
  }

  async function cargarBancosAPI() {
    try {
      var token = localStorage.getItem('adglobal_token');
      var res = await fetch(API_URL + '/api/banks', { headers: { 'Authorization': 'Bearer ' + token } });
      if (!res.ok) throw new Error('Error');
      var data = await res.json();
      bancosLista = data.filter(function(b) { return b.isActive !== false; }).map(function(b) {
        return b.label;
      });
      poblarSelectBancos();
      poblarSelectBancosModal();
    } catch (e) {
      console.error('Error cargando bancos:', e);
    }
  }

  // ===================== AUTOCOMPLETE CLIENTES =====================
  function renderResultadosClientes(resultados) {
    var cont = document.getElementById('resultadosClientes');
    if (resultados.length === 0) {
      cont.innerHTML = '<div class="px-4 py-4 text-sm text-slate-400 text-center font-medium">No se encontraron clientes</div>';
      cont.classList.remove('hidden');
      return;
    }
    cont.innerHTML = resultados.map(function(c) {
      var tel = c.telefono ? '<span class="text-slate-400 font-medium ml-2">' + c.telefono + '</span>' : '';
      var em = c.email ? '<span class="text-slate-400 font-medium ml-2">' + c.email + '</span>' : '';
      return '<button type="button" onclick="seleccionarCliente(\'' + c.id + '\')" class="w-full text-left px-4 py-3 hover:bg-indigo-50 transition-all flex items-center gap-3 border-b border-slate-100 last:border-0">' +
        '<div class="w-9 h-9 rounded-lg bg-indigo-100 text-indigo-600 flex items-center justify-center text-sm font-bold shrink-0">' + c.nombre.charAt(0) + '</div>' +
        '<div class="flex-1 min-w-0">' +
          '<p class="font-bold text-sm text-slate-800 truncate">' + c.nombre + '</p>' +
          '<p class="text-xs text-slate-400 font-medium truncate">' + (c.telefono || c.email || '') + '</p>' +
        '</div>' +
      '</button>';
    }).join('');
    cont.classList.remove('hidden');
  }

  function seleccionarCliente(id) {
    var c = clientes.find(function(x) { return x.id === id; });
    if (!c) return;
    ocultarAlertaKyc();
    estado.cliente = c;
    document.getElementById('buscarCliente').value = c.nombre;
    document.getElementById('clearBusqueda').classList.remove('hidden');
    document.getElementById('resultadosClientes').classList.add('hidden');

    document.getElementById('clienteInicial').textContent = c.nombre.charAt(0);
    document.getElementById('clienteNombre').textContent = c.nombre;
    document.getElementById('clienteTelefono').textContent = c.telefono || 'Sin teléfono';
    document.getElementById('clienteEmail').textContent = c.email || '';
    document.getElementById('clienteSeleccionado').classList.remove('hidden');
  }

  function limpiarBusqueda() {
    ocultarAlertaKyc();
    document.getElementById('buscarCliente').value = '';
    document.getElementById('clearBusqueda').classList.add('hidden');
    document.getElementById('clienteSeleccionado').classList.add('hidden');
    document.getElementById('resultadosClientes').classList.add('hidden');
    estado.cliente = null;
  }

  function cambiarCliente() {
    limpiarBusqueda();
    document.getElementById('buscarCliente').focus();
  }

  // ===================== PASOS / WIZARD =====================
  function mostrarPaso(n) {
    if (n !== 4) ocultarAlertaKyc();
    for (var i = 1; i <= 4; i++) {
      document.getElementById('step' + i).classList.add('hidden');
    }
    document.getElementById('step' + n).classList.remove('hidden');
    estado.paso = n;
    actualizarStepper();
    actualizarBotonesNav();

    if (n === 2 && estado.cliente) {
      cargarDestinatariosWizard(estado.cliente.id);
    }
    if (n === 4) {
      renderResumen();
    }
  }

  function actualizarStepper() {
    var ancho = ((estado.paso - 1) / 3) * 100;
    document.getElementById('stepLine').style.width = ancho + '%';

    for (var i = 1; i <= 4; i++) {
      var dot = document.getElementById('dot' + i);
      var label = document.getElementById('label' + i);
      if (i < estado.paso) {
        dot.className = 'w-9 h-9 md:w-10 md:h-10 rounded-full bg-emerald-500 text-white flex items-center justify-center text-sm font-bold shadow-md transition-all duration-300 ring-4 ring-emerald-50';
        dot.innerHTML = '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>';
        label.className = 'text-[0.65rem] md:text-xs font-bold text-emerald-600 uppercase tracking-wider';
      } else if (i === estado.paso) {
        dot.className = 'w-9 h-9 md:w-10 md:h-10 rounded-full bg-indigo-600 text-white flex items-center justify-center text-sm font-bold shadow-md transition-all duration-300 ring-4 ring-indigo-50';
        dot.textContent = i;
        label.className = 'text-[0.65rem] md:text-xs font-bold text-indigo-600 uppercase tracking-wider';
      } else {
        dot.className = 'w-9 h-9 md:w-10 md:h-10 rounded-full bg-slate-200 text-slate-500 flex items-center justify-center text-sm font-bold transition-all duration-300';
        dot.textContent = i;
        label.className = 'text-[0.65rem] md:text-xs font-bold text-slate-400 uppercase tracking-wider';
      }
    }
  }

  function actualizarBotonesNav() {
    var btnAtras = document.getElementById('btnAtras');
    var btnSig = document.getElementById('btnSiguiente');
    var nav = document.getElementById('navPasos');

    if (estado.paso === 4) {
      nav.classList.add('hidden');
      return;
    }
    nav.classList.remove('hidden');
    btnAtras.classList.toggle('hidden', estado.paso === 1);
    btnSig.innerHTML = estado.paso === 3 ? 'Revisar <ChevronRight class="w-4 h-4"/>' : 'Siguiente <ChevronRight class="w-4 h-4"/>';
  }

  function pasoSiguiente() {
    if (estado.paso === 1) {
      if (!estado.cliente) {
        showToast('warning', 'Selecciona un cliente', 'Busca y selecciona un cliente para continuar.');
        return;
      }
    }
    if (estado.paso === 2) {
      if (!estado.destinatario) {
        showToast('warning', 'Selecciona un destinatario', 'Elige quién recibe el envío.');
        return;
      }
    }
    if (estado.paso === 3) {
      var ing = parseFloat(document.getElementById('txIngreso').value) || 0;
      var sal = parseFloat(document.getElementById('txSalida').value) || 0;
      var tasa = parseFloat(document.getElementById('txTasa').value) || 0;
      var met = document.getElementById('txMetodo').value;
      var ban = document.getElementById('txBanco').value;
      if (!met) { showToast('warning', 'Falta método', 'Selecciona un método de pago.'); return; }
      if (!ban) { showToast('warning', 'Falta banco', 'Selecciona un banco destino.'); return; }
      if (ing <= 0) { showToast('warning', 'Monto inválido', 'El ingreso debe ser mayor a 0.'); return; }
      if (sal <= 0) { showToast('warning', 'Monto inválido', 'La salida debe ser mayor a 0.'); return; }
      if (tasa <= 0) { showToast('warning', 'Tasa inválida', 'La tasa debe ser mayor a 0.'); return; }
      estado.metodo = met;
      estado.banco = ban;
      estado.ingreso = ing;
      estado.salida = sal;
      estado.tasa = tasa;
    }
    mostrarPaso(estado.paso + 1);
  }

  function pasoAnterior() {
    mostrarPaso(estado.paso - 1);
  }

  function volverPaso(n) {
    mostrarPaso(n);
  }

  // ===================== DESTINATARIOS =====================
  async function cargarDestinatariosWizard(clientId) {
    var cont = document.getElementById('listaDestinatarios');
    var sin = document.getElementById('sinDestinatarios');

    if (destinatariosPorCliente[clientId]) {
      renderDestinatariosWizard(destinatariosPorCliente[clientId]);
      return;
    }

    try {
      var token = localStorage.getItem('adglobal_token');
      var res = await fetch(API_URL + '/api/clients/' + clientId + '/recipients', {
        headers: { 'Authorization': 'Bearer ' + token }
      });
      if (!res.ok) throw new Error('Error');
      var data = await res.json();
      var lista = data.map(function(r) {
        return { id: r.id, nombre: r.name, telefono: r.phone || '', banco: r.bank || '', cuenta: r.accountNumber || '', relacion: r.relationship || '' };
      });
      destinatariosPorCliente[clientId] = lista;
      renderDestinatariosWizard(lista);
    } catch (e) {
      cont.innerHTML = '';
      sin.classList.remove('hidden');
    }
  }

  function renderDestinatariosWizard(lista) {
    var cont = document.getElementById('listaDestinatarios');
    var sin = document.getElementById('sinDestinatarios');
    if (lista.length === 0) {
      cont.innerHTML = '';
      sin.classList.remove('hidden');
      return;
    }
    sin.classList.add('hidden');
    cont.innerHTML = lista.map(function(d) {
      var sel = estado.destinatario && estado.destinatario.id === d.id ? 'ring-2 ring-emerald-500 border-emerald-300 bg-emerald-50/50' : 'border-slate-200 hover:border-emerald-300 hover:bg-emerald-50/30';
      return '<button type="button" onclick="seleccionarDestinatario(\'' + d.id + '\')" class="text-left p-4 rounded-xl border-2 ' + sel + ' transition-all duration-200 flex items-start gap-3">' +
        '<div class="w-10 h-10 rounded-lg bg-emerald-100 text-emerald-600 flex items-center justify-center text-sm font-bold shrink-0">' + d.nombre.charAt(0) + '</div>' +
        '<div class="flex-1 min-w-0">' +
          '<p class="font-bold text-sm text-slate-800 truncate">' + d.nombre + '</p>' +
          '<p class="text-xs text-slate-500 font-medium">' + d.banco + ' · ' + d.cuenta + '</p>' +
          '<span class="inline-block mt-1 px-1.5 py-0.5 bg-slate-100 text-slate-500 rounded text-[0.6rem] font-black uppercase tracking-wider">' + d.relacion + '</span>' +
        '</div>' +
      '</button>';
    }).join('');
  }

  function seleccionarDestinatario(id) {
    var lista = destinatariosPorCliente[estado.cliente.id] || [];
    var d = lista.find(function(x) { return x.id === id; });
    if (!d) return;
    estado.destinatario = d;
    renderDestinatariosWizard(lista);
  }

  function poblarSelectBancos() {
    var sel = document.getElementById('txBanco');
    if (!sel) return;
    sel.innerHTML = '<option value="">Seleccionar...</option>' +
      bancosLista.map(function(b) { return '<option value="' + b + '">' + b + '</option>'; }).join('');
  }

  function poblarSelectBancosModal() {
    var sel = document.getElementById('destBank');
    if (!sel) return;
    sel.innerHTML = '<option value="">Seleccionar...</option>' +
      bancosLista.map(function(b) { return '<option value="' + b + '">' + b + '</option>'; }).join('');
  }

  function poblarSelectMetodos() {
    var sel = document.getElementById('txMetodo');
    sel.innerHTML = '<option value="">Seleccionar...</option>' +
      metodos.map(function(m) { return '<option value="' + m.nombre + '">' + m.nombre + '</option>'; }).join('');
  }

  // ===================== CÁLCULOS =====================
  function calcularTransaccion() {
    var ing = parseFloat(document.getElementById('txIngreso').value) || 0;
    var sal = parseFloat(document.getElementById('txSalida').value) || 0;
    var tasa = parseFloat(document.getElementById('txTasa').value) || 0;
    var ves = ing * tasa;
    var profit = ing - sal;
    var margen = ing > 0 ? ((profit / ing) * 100) : 0;
    document.getElementById('resVES').textContent = new Intl.NumberFormat('es-VE').format(ves);
    document.getElementById('resProfit').textContent = '$' + new Intl.NumberFormat('es-US').format(profit);
    document.getElementById('resMargen').textContent = margen.toFixed(1) + '%';
  }

  function renderResumen() {
    document.getElementById('resCliente').textContent = estado.cliente ? estado.cliente.nombre : '—';
    document.getElementById('resClienteInfo').textContent = estado.cliente ? (estado.cliente.telefono || estado.cliente.email) : '—';
    document.getElementById('resDestinatario').textContent = estado.destinatario ? estado.destinatario.nombre : '—';
    document.getElementById('resDestinatarioInfo').textContent = estado.destinatario ? (estado.destinatario.banco + ' · ' + estado.destinatario.cuenta) : '—';
    document.getElementById('resMetodo').textContent = estado.metodo || '—';
    document.getElementById('resEntrada').textContent = '$' + new Intl.NumberFormat('es-US').format(estado.ingreso);
    document.getElementById('resSalida').textContent = '$' + new Intl.NumberFormat('es-US').format(estado.salida);
    document.getElementById('resTasa').textContent = new Intl.NumberFormat('es-VE').format(estado.tasa);
    document.getElementById('resTotalVES').textContent = new Intl.NumberFormat('es-VE').format(estado.ingreso * estado.tasa);
    document.getElementById('resTotalProfit').textContent = '$' + new Intl.NumberFormat('es-US').format(estado.ingreso - estado.salida);
  }

  // ===================== COMPROBANTES =====================
  function procesarComprobante(input, tipo) {
    var file = input.files[0];
    if (!file) return;
    var tiposPermitidos = ['image/jpeg', 'image/png', 'image/webp', 'application/pdf'];
    if (!tiposPermitidos.includes(file.type)) {
      showToast('error', 'Tipo no permitido', 'Solo imágenes o PDF');
      input.value = '';
      return;
    }
    if (file.size > 5 * 1024 * 1024) {
      showToast('error', 'Muy grande', 'Máximo 5MB');
      input.value = '';
      return;
    }
    estado.comprobantes[tipo] = { nombre: file.name, tipo: file.type, archivo: file };
    var label = document.getElementById('label' + (tipo === 'pago' ? 'Pago' : 'Admin'));
    var drop = document.getElementById('drop' + (tipo === 'pago' ? 'Pago' : 'Admin'));
    label.textContent = file.name.length > 20 ? file.name.substring(0, 18) + '...' : file.name;
    label.classList.add('text-emerald-600');
    drop.classList.remove('border-slate-300', 'bg-slate-50');
    drop.classList.add('border-emerald-400', 'bg-emerald-50');
    renderPreviewComprobante(tipo, file);
  }

  // ===================== UPLOAD S3 =====================
  async function subirComprobanteAS3(file, tipo) {
    var token = localStorage.getItem('adglobal_token');
    var formData = new FormData();
    formData.append('file', file);
    formData.append('folder', 'transactions/' + (estado.cliente ? estado.cliente.id : 'unknown'));

    var res = await fetch(API_URL + '/api/upload', {
      method: 'POST',
      headers: { 'Authorization': 'Bearer ' + token },
      body: formData
    });

    if (!res.ok) {
      var err = await res.json().catch(function() { return {}; });
      throw new Error(err.error || 'Error subiendo comprobante ' + tipo);
    }

    var data = await res.json();
    return data.url;
  }

  // ===================== GUARDAR =====================
  async function guardarTransaccion() {
    var btn = document.getElementById('btnGuardarFinal');
    btn.disabled = true;
    btn.innerHTML = '<svg class="animate-spin w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> Guardando...';

    var metodoMap = {
      'USDT': 'USDT', 'Efectivo': 'EFECTIVO', 'Zelle': 'ZELLE',
      'PayPal': 'PAYPAL', 'Wire': 'WIRE', 'Deposito': 'DEPOSITO',
      'Pago Movil': 'PAGO_MOVIL', 'Transferencia': 'TRANSFERENCIA'
    };
    var metodo = metodoMap[estado.metodo] || 'TRANSFERENCIA';

    try {
      // Subir comprobantes a S3 primero
      var comprobantePagoUrl = null;
      var comprobanteAdminUrl = null;

      if (estado.comprobantes.pago && estado.comprobantes.pago.archivo) {
        comprobantePagoUrl = await subirComprobanteAS3(estado.comprobantes.pago.archivo, 'pago');
      }
      if (estado.comprobantes.admin && estado.comprobantes.admin.archivo) {
        comprobanteAdminUrl = await subirComprobanteAS3(estado.comprobantes.admin.archivo, 'admin');
      }

      var payload = {
        clientId: estado.cliente.id,
        recipientId: estado.destinatario.id,
        ingresoUSD: estado.ingreso,
        salidaUSDT: estado.salida,
        tasa: estado.tasa,
        montoVES: estado.ingreso * estado.tasa,
        metodo: metodo,
        profitUSD: estado.ingreso - estado.salida,
        estado: 'PENDING'
      };

      if (comprobantePagoUrl) payload.comprobantePago = comprobantePagoUrl;
      if (comprobanteAdminUrl) payload.comprobanteAdmin = comprobanteAdminUrl;

      var token = localStorage.getItem('adglobal_token');
      var res = await fetch(API_URL + '/api/transactions', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
        body: JSON.stringify(payload)
      });
      if (!res.ok) {
        var err = await res.json().catch(function() { return {}; });
        if (err.code === 'KYC_REQUIRED') {
          mostrarAlertaKyc(err);
          showToast('warning', 'KYC obligatorio', err.error || 'El cliente debe completar KYC antes de registrar este giro.');
          throw new Error('KYC obligatorio');
        }
        if (err.code === 'MIN_TRANSACTION_REQUIRED') {
          throw new Error(err.error || 'La transacción no cumple el monto mínimo.');
        }
        throw new Error(err.error || 'Error al guardar');
      }

      var modal = document.getElementById('modalExito');
      var content = document.getElementById('modalContentExito');
      modal.classList.remove('hidden');
      modal.classList.add('anim-overlay');
      setTimeout(function() { content.style.transform = 'scale(1)'; content.classList.add('anim-modal'); }, 10);

    } catch (e) {
      showToast('error', 'Error al guardar', e.message);
      btn.disabled = false;
      btn.innerHTML = '<Save class="w-4 h-4"/> Guardar transacción';
    }
  }

  function nuevaTransaccion() {
    document.getElementById('modalExito').classList.add('hidden');
    document.getElementById('modalContentExito').style.transform = 'scale(0.95)';
    document.getElementById('modalContentExito').classList.remove('anim-modal');

    estado.paso = 1;
    estado.cliente = null;
    estado.destinatario = null;
    estado.metodo = '';
    estado.banco = '';
    estado.ingreso = 0;
    estado.salida = 0;
    estado.tasa = 0;
    estado.comprobantes = {};
    resetPreview('pago');
    resetPreview('admin');
    ocultarAlertaKyc();

    limpiarBusqueda();
    document.getElementById('txMetodo').value = '';
    document.getElementById('txBanco').value = '';
    document.getElementById('txIngreso').value = '';
    document.getElementById('txSalida').value = '';
    document.getElementById('txTasa').value = '';
    calcularTransaccion();

    var labelP = document.getElementById('labelPago');
    var dropP = document.getElementById('dropPago');
    labelP.textContent = 'Arrastra o haz click';
    labelP.classList.remove('text-emerald-600');
    dropP.classList.remove('border-emerald-400', 'bg-emerald-50');
    dropP.classList.add('border-slate-300', 'bg-slate-50');
    document.getElementById('filePago').value = '';

    var labelA = document.getElementById('labelAdmin');
    var dropA = document.getElementById('dropAdmin');
    labelA.textContent = 'Arrastra o haz click';
    labelA.classList.remove('text-emerald-600');
    dropA.classList.remove('border-emerald-400', 'bg-emerald-50');
    dropA.classList.add('border-slate-300', 'bg-slate-50');
    document.getElementById('fileAdmin').value = '';

    document.getElementById('btnGuardarFinal').disabled = false;
    document.getElementById('btnGuardarFinal').innerHTML = '<Save class="w-4 h-4"/> Guardar transacción';

    mostrarPaso(1);
  }

  // ===================== MODAL DESTINATARIO =====================
  function abrirModalDestinatario() {
    if (!estado.cliente) return;
    document.getElementById('destClienteId').value = estado.cliente.id;
    var m = document.getElementById('modalDestinatario');
    var c = document.getElementById('modalContentDestinatario');
    m.classList.remove('hidden');
    m.classList.add('anim-overlay');
    setTimeout(function() { c.style.transform = 'scale(1)'; c.classList.add('anim-modal'); }, 10);
  }

  function cerrarModalDestinatario() {
    var m = document.getElementById('modalDestinatario');
    var c = document.getElementById('modalContentDestinatario');
    c.style.transform = 'scale(0.95)';
    c.classList.remove('anim-modal');
    setTimeout(function() { m.classList.add('hidden'); m.classList.remove('anim-overlay'); }, 200);
  }

  async function guardarDestinatario(e) {
    e.preventDefault();
    var btn = document.getElementById('btnGuardarDestinatario');
    btn.disabled = true;
    btn.innerHTML = '<svg class="animate-spin w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> Guardando...';

    var payload = {
      name: document.getElementById('destName').value,
      relationship: document.getElementById('destRel').value,
      phone: document.getElementById('destPhone').value,
      bank: document.getElementById('destBank').value,
      accountNumber: document.getElementById('destAccount').value,
      accountType: document.getElementById('destAccountType').value,
      identification: document.getElementById('destId').value
    };

    try {
      var token = localStorage.getItem('adglobal_token');
      var res = await fetch(API_URL + '/api/clients/' + estado.cliente.id + '/recipients', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
        body: JSON.stringify(payload)
      });
      if (!res.ok) throw new Error('Error creando destinatario');
      var data = await res.json();
      showToast('success', 'Destinatario creado', payload.name + ' fue registrado.');
      e.target.reset();
      cerrarModalDestinatario();
      destinatariosPorCliente[estado.cliente.id] = null;
      cargarDestinatariosWizard(estado.cliente.id);
    } catch (err) {
      showToast('error', 'Error', err.message);
    } finally {
      btn.disabled = false;
      btn.innerHTML = 'Guardar';
    }
  }
</script>
