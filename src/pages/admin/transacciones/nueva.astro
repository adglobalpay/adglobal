            </div>
            <div>
              <label class="mb-1.5 block text-[0.65rem] font-black uppercase tracking-[0.18em] text-slate-500">Teléfono</label>
              <input type="text" id="destPhone" class="w-full rounded-xl border border-slate-200 bg-slate-50/50 px-3.5 py-2.5 text-sm font-semibold text-slate-800 outline-none transition-all placeholder:text-slate-400 hover:bg-white hover:border-slate-300 focus:border-emerald-400 focus:bg-white focus:ring-[3px] focus:ring-emerald-500/10" placeholder="+58 412...">
            </div>
            <div>
              <label class="mb-1.5 block text-[0.65rem] font-black uppercase tracking-[0.18em] text-slate-500">Banco *</label>
              <select id="destBank" required class="w-full rounded-xl border border-slate-200 bg-slate-50/50 px-3.5 py-2.5 text-sm font-semibold text-slate-800 outline-none transition-all hover:bg-white hover:border-slate-300 focus:border-emerald-400 focus:bg-white focus:ring-[3px] focus:ring-emerald-500/10">
                <option value="">Seleccionar...</option>
              </select>
            </div>
            <div>
              <label class="mb-1.5 block text-[0.65rem] font-black uppercase tracking-[0.18em] text-slate-500">Tipo de Cuenta</label>
              <select id="destAccountType" class="w-full rounded-xl border border-slate-200 bg-slate-50/50 px-3.5 py-2.5 text-sm font-semibold text-slate-800 outline-none transition-all hover:bg-white hover:border-slate-300 focus:border-emerald-400 focus:bg-white focus:ring-[3px] focus:ring-emerald-500/10">
                <option value="Pago Móvil">Pago Móvil</option>
                <option value="Corriente">Corriente</option>
                <option value="Ahorro">Ahorro</option>
                <option value="Zelle">Zelle</option>
              </select>
            </div>
            <div class="sm:col-span-2">
              <label class="mb-1.5 block text-[0.65rem] font-black uppercase tracking-[0.18em] text-slate-500">Cuenta / Pago Móvil *</label>
              <input type="text" id="destAccount" required class="w-full rounded-xl border border-slate-200 bg-slate-50/50 px-3.5 py-2.5 text-sm font-semibold text-slate-800 outline-none transition-all placeholder:text-slate-400 hover:bg-white hover:border-slate-300 focus:border-emerald-400 focus:bg-white focus:ring-[3px] focus:ring-emerald-500/10" placeholder="0134...">
            </div>
            <div class="sm:col-span-2">
              <label class="mb-1.5 block text-[0.65rem] font-black uppercase tracking-[0.18em] text-slate-500">Documento de Identidad</label>
              <input type="text" id="destId" class="w-full rounded-xl border border-slate-200 bg-slate-50/50 px-3.5 py-2.5 text-sm font-semibold text-slate-800 outline-none transition-all placeholder:text-slate-400 hover:bg-white hover:border-slate-300 focus:border-emerald-400 focus:bg-white focus:ring-[3px] focus:ring-emerald-500/10" placeholder="V-...">
            </div>
          </div>
        </div>

        <div class="border-t border-slate-100 bg-slate-50/40 px-5 py-4 sm:px-8 sm:py-5 flex flex-col-reverse gap-2.5 sm:flex-row sm:justify-end">
          <button type="button" onclick="cerrarModalDestinatario()" class="inline-flex items-center justify-center rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm font-bold text-slate-600 transition-all hover:border-slate-300 hover:bg-slate-50 hover:text-slate-900">
            Cancelar
          </button>
          <button type="submit" id="btnGuardarDestinatario" class="inline-flex items-center justify-center gap-2 rounded-xl bg-emerald-600 px-5 py-2.5 text-sm font-bold text-white shadow-lg shadow-emerald-600/20 transition-all hover:bg-emerald-700 hover:shadow-xl hover:shadow-emerald-600/25 active:scale-[0.98]">
            Guardar destinatario
