---
import AdminLayout from '../../../layouts/AdminLayout.astro';
---

<AdminLayout>
  <div class="max-w-full mx-auto space-y-4 p-4">
    <!-- Header -->
    <div class="flex justify-between items-center">
      <h1 class="text-3xl font-bold">➕ Nueva Transacción</h1>
      <a href="/admin/transacciones" class="text-blue-600 hover:underline">
        ← Cancelar
      </a>
    </div>

    <!-- Panel de administración rápida -->
    <div class="grid grid-cols-4 gap-3 mb-3">
      <a href="/admin/clientes" class="bg-blue-50 hover:bg-blue-100 text-blue-700 px-3 py-1.5 rounded-lg text-xs flex items-center justify-center gap-1 border border-blue-200 transition-colors">
        <span>➕</span> Clientes
      </a>
      <a href="/admin/clientes?tab=destinatarios" class="bg-green-50 hover:bg-green-100 text-green-700 px-3 py-1.5 rounded-lg text-xs flex items-center justify-center gap-1 border border-green-200 transition-colors">
        <span>➕</span> Destinatarios
      </a>
      <button onclick="abrirModalBanco()" class="bg-purple-50 hover:bg-purple-100 text-purple-700 px-3 py-1.5 rounded-lg text-xs flex items-center justify-center gap-1 border border-purple-200 transition-colors">
        <span>➕</span> Bancos
      </button>
      <button onclick="abrirModalMetodo()" class="bg-orange-50 hover:bg-orange-100 text-orange-700 px-3 py-1.5 rounded-lg text-xs flex items-center justify-center gap-1 border border-orange-200 transition-colors">
        <span>➕</span> Métodos
      </button>
    </div>

    <!-- Tabla de transacciones -->
    <div class="bg-white rounded-xl p-4 shadow-sm border border-gray-100 overflow-x-auto">
      <div style="min-width: 1100px;">
        <table class="w-full">
          <thead>
            <tr class="text-left text-gray-500 text-xs border-b">
              <th class="pb-2 pr-1">Fecha</th>
              <th class="pb-2 pr-1" colspan="2">Cliente / Comprobante</th>
              <th class="pb-2 pr-1">Método</th>
              <th class="pb-2 pr-1" colspan="2">Destinatario / Comprobante</th>
              <th class="pb-2 pr-1">Banco</th>
              <th class="pb-2 pr-1">Ingreso</th>
              <th class="pb-2 pr-1">Salida</th>
              <th class="pb-2 pr-1">Tasa</th>
              <th class="pb-2 pr-1">Bs</th>
              <th class="pb-2 pr-1">Profit</th>
              <th class="pb-2 pr-1"></th>
            </tr>
            <tr class="text-left text-gray-400 text-[10px] border-b">
              <th></th>
              <th>Nombre</th>
              <th>Comprobante</th>
              <th></th>
              <th>Nombre</th>
              <th>Comprobante</th>
              <th></th>
              <th></th>
              <th></th>
              <th></th>
              <th></th>
              <th></th>
              <th></th>
            </tr>
          </thead>
          <tbody id="tablaBody">
            <!-- Las filas se insertan aquí -->
          </tbody>
        </table>
      </div>

      <!-- Botón para agregar fila -->
      <div class="mt-3 flex justify-center">
        <button 
          id="btnAgregar"
          class="bg-gray-100 hover:bg-gray-200 text-gray-700 px-5 py-2 rounded-lg border flex items-center gap-1 text-sm"
        >
          <span class="text-lg">➕</span> Agregar otra transacción
        </button>
      </div>
    </div>
  </div>

  <!-- Modales (iguales) -->
  <div id="modalBanco" class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center hidden z-50">
    <div class="bg-white rounded-xl p-6 max-w-md w-full">
      <h2 class="text-2xl font-bold mb-4">➕ Nuevo Banco</h2>
      <form id="formBanco" class="space-y-4" onsubmit="guardarBanco(event)">
        <div>
          <label class="block text-sm font-medium mb-1">Nombre del banco *</label>
          <input type="text" id="bancoNombre" required class="w-full border rounded-lg px-3 py-2" placeholder="Ej: BNC">
        </div>
        <div class="flex justify-end gap-2 pt-4">
          <button type="button" onclick="cerrarModalBanco()" class="px-4 py-2 border rounded-lg hover:bg-gray-50">Cancelar</button>
          <button type="submit" class="px-4 py-2 bg-purple-600 text-white rounded-lg hover:bg-purple-700">Guardar Banco</button>
        </div>
      </form>
    </div>
  </div>

  <div id="modalMetodo" class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center hidden z-50">
    <div class="bg-white rounded-xl p-6 max-w-md w-full">
      <h2 class="text-2xl font-bold mb-4">➕ Nuevo Método de Pago</h2>
      <form id="formMetodo" class="space-y-4" onsubmit="guardarMetodo(event)">
        <div>
          <label class="block text-sm font-medium mb-1">Nombre del método *</label>
          <input type="text" id="metodoNombre" required class="w-full border rounded-lg px-3 py-2" placeholder="Ej: Zelle, BOFA, Chase">
        </div>
        <div class="flex justify-end gap-2 pt-4">
          <button type="button" onclick="cerrarModalMetodo()" class="px-4 py-2 border rounded-lg hover:bg-gray-50">Cancelar</button>
          <button type="submit" class="px-4 py-2 bg-orange-600 text-white rounded-lg hover:bg-orange-700">Guardar Método</button>
        </div>
      </form>
    </div>
  </div>
</AdminLayout>

<script is:inline>
  // ============ DATOS INICIALES ============
  var clientes = [
    { id: '1', nombre: 'Luisa Ideas Creativas', telefono: '4242459151', email: '' },
    { id: '2', nombre: 'Cartaya Auto Sales', telefono: '3055551234', email: 'cartaya@autos.com' }
  ];

  var destinatarios = [
    { id: '201', nombre: 'Carlos Mendoza', telefono: '+58 412 1234567', banco: 'Banco Venezuela', cuenta: '0102-1234-56-78901234' },
    { id: '202', nombre: 'Ana Torres', telefono: '+58 414 7654321', banco: 'Mercantil', cuenta: '0105-4321-87-65432109' }
  ];

  var bancos = ['Banesco', 'Mercantil', 'Banco Venezuela', 'Banco Provincial', 'BNC', 'BOD'];
  var metodos = ['Zelle', 'BOFA', 'Chase', 'PNC', 'Debit Card', 'Efectivo', 'USDT'];

  window.comprobantes = window.comprobantes || {};

  // ============ FUNCIÓN DRAG & DROP ============
  function crearDropArea(filaId, tipo) {
    var container = document.createElement('div');
    container.className = 'flex flex-col items-center';
    
    var dropArea = document.createElement('div');
    dropArea.className = 'drop-area w-12 h-12 border-2 border-dashed border-gray-300 rounded-lg flex flex-col items-center justify-center cursor-pointer hover:border-blue-500 hover:bg-blue-50 transition-all';
    dropArea.innerHTML = '<span class="text-lg text-gray-400">📎</span>';
    
    var fileInput = document.createElement('input');
    fileInput.type = 'file';
    fileInput.accept = 'image/*,application/pdf';
    fileInput.className = 'hidden';
    
    var fileNameSpan = document.createElement('span');
    fileNameSpan.className = 'text-[10px] text-gray-500 mt-1 truncate max-w-[50px] text-center';
    fileNameSpan.textContent = '';
    
    dropArea.ondragover = function(e) {
      e.preventDefault();
      this.classList.add('border-blue-500', 'bg-blue-50');
      this.innerHTML = '<span class="text-lg text-blue-500">📤</span>';
    };
    
    dropArea.ondragleave = function(e) {
      e.preventDefault();
      this.classList.remove('border-blue-500', 'bg-blue-50');
      this.innerHTML = '<span class="text-lg text-gray-400">📎</span>';
    };
    
    dropArea.ondrop = function(e) {
      e.preventDefault();
      this.classList.remove('border-blue-500', 'bg-blue-50');
      var file = e.dataTransfer.files[0];
      if (file) {
        procesarArchivo(file, filaId, tipo, fileNameSpan, dropArea);
      }
      this.innerHTML = '<span class="text-lg text-gray-400">📎</span>';
    };
    
    dropArea.onclick = function() {
      fileInput.click();
    };
    
    fileInput.onchange = function(e) {
      var file = e.target.files[0];
      if (file) {
        procesarArchivo(file, filaId, tipo, fileNameSpan, dropArea);
      }
    };
    
    container.appendChild(dropArea);
    container.appendChild(fileInput);
    container.appendChild(fileNameSpan);
    
    return container;
  }

  function procesarArchivo(file, filaId, tipo, fileNameSpan, dropArea) {
    var tiposPermitidos = ['image/jpeg', 'image/png', 'image/webp', 'application/pdf'];
    var esValido = false;
    for (var i = 0; i < tiposPermitidos.length; i++) {
      if (file.type === tiposPermitidos[i]) {
        esValido = true;
        break;
      }
    }
    
    if (!esValido) {
      alert('❌ Solo se permiten imágenes (JPG, PNG, WEBP) o PDF');
      return false;
    }
    
    if (file.size > 5 * 1024 * 1024) {
      alert('❌ El archivo no debe superar los 5MB');
      return false;
    }
    
    var comprobantes = window.comprobantes || {};
    if (!comprobantes[filaId]) comprobantes[filaId] = {};
    comprobantes[filaId][tipo] = {
      nombre: file.name,
      tipo: file.type,
      tamaño: file.size,
      archivo: file
    };
    window.comprobantes = comprobantes;
    
    var nombreCorto = file.name.length > 12 ? file.name.substring(0, 10) + '...' : file.name;
    fileNameSpan.textContent = nombreCorto;
    fileNameSpan.classList.add('text-green-600');
    
    dropArea.classList.add('border-green-500', 'bg-green-50');
    dropArea.innerHTML = '<span class="text-lg text-green-500">✅</span>';
    
    return true;
  }

  // ============ INICIALIZACIÓN ============
  var filas = [];

  document.addEventListener('DOMContentLoaded', function() {
    agregarFila();
    
    var btnAgregar = document.getElementById('btnAgregar');
    if (btnAgregar) {
      btnAgregar.onclick = function() {
        agregarFila();
      };
    }
  });

  function agregarFila() {
    var tablaBody = document.getElementById('tablaBody');
    if (!tablaBody) return;
    
    var filaId = 'fila_' + Date.now() + '_' + Math.random();
    filas.push(filaId);
    
    var tr = document.createElement('tr');
    tr.id = filaId;
    tr.className = 'border-b hover:bg-gray-50';
    
    // FECHA
    var tdFecha = document.createElement('td');
    tdFecha.className = 'py-2 pr-1';
    var spanFecha = document.createElement('span');
    spanFecha.className = 'text-xs whitespace-nowrap';
    var ahora = new Date();
    spanFecha.textContent = ('0' + ahora.getDate()).slice(-2) + '/' + 
                            ('0' + (ahora.getMonth() + 1)).slice(-2) + '/' + 
                            ahora.getFullYear().toString().slice(-2) + ' ' +
                            ('0' + ahora.getHours()).slice(-2) + ':' +
                            ('0' + ahora.getMinutes()).slice(-2);
    tdFecha.appendChild(spanFecha);
    
    // CLIENTE - NOMBRE
    var tdCliente = document.createElement('td');
    tdCliente.className = 'py-2 pr-1';
    var selectCliente = document.createElement('select');
    selectCliente.className = 'cliente-select w-28 border rounded px-2 py-1 text-xs';
    var optionsCliente = '<option value="">Seleccionar</option>';
    for (var i = 0; i < clientes.length; i++) {
      optionsCliente += '<option value="' + clientes[i].id + '">' + clientes[i].nombre + '</option>';
    }
    selectCliente.innerHTML = optionsCliente;
    tdCliente.appendChild(selectCliente);
    
    // CLIENTE - COMPROBANTE
    var tdCompCliente = document.createElement('td');
    tdCompCliente.className = 'py-2 pr-1';
    var dropCliente = crearDropArea(filaId, 'cliente');
    tdCompCliente.appendChild(dropCliente);
    
    // MÉTODO
    var tdMetodo = document.createElement('td');
    tdMetodo.className = 'py-2 pr-1';
    var selectMetodo = document.createElement('select');
    selectMetodo.className = 'metodo-select w-20 border rounded px-2 py-1 text-xs';
    var optionsMetodo = '';
    for (var m = 0; m < metodos.length; m++) {
      optionsMetodo += '<option value="' + metodos[m] + '">' + metodos[m] + '</option>';
    }
    selectMetodo.innerHTML = optionsMetodo;
    tdMetodo.appendChild(selectMetodo);
    
    // DESTINATARIO - NOMBRE
    var tdDestino = document.createElement('td');
    tdDestino.className = 'py-2 pr-1';
    var selectDestino = document.createElement('select');
    selectDestino.className = 'destino-select w-28 border rounded px-2 py-1 text-xs';
    var optionsDestino = '<option value="">Seleccionar</option>';
    for (var j = 0; j < destinatarios.length; j++) {
      optionsDestino += '<option value="' + destinatarios[j].id + '">' + destinatarios[j].nombre + '</option>';
    }
    selectDestino.innerHTML = optionsDestino;
    tdDestino.appendChild(selectDestino);
    
    // DESTINATARIO - COMPROBANTE
    var tdCompDestino = document.createElement('td');
    tdCompDestino.className = 'py-2 pr-1';
    var dropDestino = crearDropArea(filaId, 'destino');
    tdCompDestino.appendChild(dropDestino);
    
    // BANCO
    var tdBanco = document.createElement('td');
    tdBanco.className = 'py-2 pr-1';
    var selectBanco = document.createElement('select');
    selectBanco.className = 'banco-select w-24 border rounded px-2 py-1 text-xs';
    var optionsBanco = '<option value="">Seleccionar</option>';
    for (var k = 0; k < bancos.length; k++) {
      optionsBanco += '<option value="' + bancos[k] + '">' + bancos[k] + '</option>';
    }
    selectBanco.innerHTML = optionsBanco;
    tdBanco.appendChild(selectBanco);
    
    // INGRESO
    var tdIngreso = document.createElement('td');
    tdIngreso.className = 'py-2 pr-1';
    var inputIngreso = document.createElement('input');
    inputIngreso.type = 'number';
    inputIngreso.step = '0.01';
    inputIngreso.placeholder = '0';
    inputIngreso.className = 'ingreso w-16 border rounded px-2 py-1 text-xs text-right';
    inputIngreso.oninput = function() { calcularFila(filaId); };
    tdIngreso.appendChild(inputIngreso);
    
    // SALIDA
    var tdSalida = document.createElement('td');
    tdSalida.className = 'py-2 pr-1';
    var inputSalida = document.createElement('input');
    inputSalida.type = 'number';
    inputSalida.step = '0.01';
    inputSalida.placeholder = '0';
    inputSalida.className = 'salida w-16 border rounded px-2 py-1 text-xs text-right';
    inputSalida.oninput = function() { calcularFila(filaId); };
    tdSalida.appendChild(inputSalida);
    
    // TASA
    var tdTasa = document.createElement('td');
    tdTasa.className = 'py-2 pr-1';
    var inputTasa = document.createElement('input');
    inputTasa.type = 'number';
    inputTasa.step = '0.01';
    inputTasa.placeholder = '0';
    inputTasa.className = 'tasa w-16 border rounded px-2 py-1 text-xs text-right';
    inputTasa.oninput = function() { calcularFila(filaId); };
    tdTasa.appendChild(inputTasa);
    
    // MONTO BS
    var tdMontoBs = document.createElement('td');
    tdMontoBs.className = 'py-2 pr-1 font-medium text-blue-600 monto-bs text-xs text-right';
    tdMontoBs.textContent = '0';
    
    // PROFIT
    var tdProfit = document.createElement('td');
    tdProfit.className = 'py-2 pr-1 font-medium text-green-600 profit text-xs text-right';
    tdProfit.textContent = '0';
    
    // ELIMINAR
    var tdEliminar = document.createElement('td');
    tdEliminar.className = 'py-2';
    var btnEliminar = document.createElement('button');
    btnEliminar.innerHTML = '🗑️';
    btnEliminar.className = 'text-red-600 hover:text-red-800 text-sm';
    btnEliminar.onclick = function() { eliminarFila(filaId); };
    tdEliminar.appendChild(btnEliminar);
    
    // Armar fila
    tr.appendChild(tdFecha);
    tr.appendChild(tdCliente);
    tr.appendChild(tdCompCliente);
    tr.appendChild(tdMetodo);
    tr.appendChild(tdDestino);
    tr.appendChild(tdCompDestino);
    tr.appendChild(tdBanco);
    tr.appendChild(tdIngreso);
    tr.appendChild(tdSalida);
    tr.appendChild(tdTasa);
    tr.appendChild(tdMontoBs);
    tr.appendChild(tdProfit);
    tr.appendChild(tdEliminar);
    
    tablaBody.appendChild(tr);
  }

  function calcularFila(filaId) {
    var fila = document.getElementById(filaId);
    if (!fila) return;
    
    var ingreso = parseFloat(fila.querySelector('.ingreso').value) || 0;
    var salida = parseFloat(fila.querySelector('.salida').value) || 0;
    var tasa = parseFloat(fila.querySelector('.tasa').value) || 0;
    
    var montoBs = salida * tasa;
    var profit = ingreso - salida;
    
    fila.querySelector('.monto-bs').textContent = Math.round(montoBs);
    fila.querySelector('.profit').textContent = Math.round(profit);
  }

  function eliminarFila(filaId) {
    var fila = document.getElementById(filaId);
    if (fila) {
      fila.remove();
      for (var i = 0; i < filas.length; i++) {
        if (filas[i] === filaId) {
          filas.splice(i, 1);
          break;
        }
      }
      if (window.comprobantes && window.comprobantes[filaId]) {
        delete window.comprobantes[filaId];
      }
    }
  }

  // ============ MODALES ============
  function abrirModalBanco() { document.getElementById('modalBanco').classList.remove('hidden'); }
  function cerrarModalBanco() { document.getElementById('modalBanco').classList.add('hidden'); }
  function abrirModalMetodo() { document.getElementById('modalMetodo').classList.remove('hidden'); }
  function cerrarModalMetodo() { document.getElementById('modalMetodo').classList.add('hidden'); }

  function guardarBanco(e) {
    e.preventDefault();
    var nuevoBanco = document.getElementById('bancoNombre').value;
    bancos.push(nuevoBanco);
    actualizarSelectsBanco();
    alert('✅ Banco agregado: ' + nuevoBanco);
    cerrarModalBanco();
    e.target.reset();
  }

  function guardarMetodo(e) {
    e.preventDefault();
    var nuevoMetodo = document.getElementById('metodoNombre').value;
    metodos.push(nuevoMetodo);
    actualizarSelectsMetodo();
    alert('✅ Método agregado: ' + nuevoMetodo);
    cerrarModalMetodo();
    e.target.reset();
  }

  function actualizarSelectsBanco() {
    var selects = document.querySelectorAll('.banco-select');
    selects.forEach(function(select) {
      var valorActual = select.value;
      var options = '<option value="">Seleccionar</option>';
      for (var b = 0; b < bancos.length; b++) {
        options += '<option value="' + bancos[b] + '" ' + (valorActual === bancos[b] ? 'selected' : '') + '>' + bancos[b] + '</option>';
      }
      select.innerHTML = options;
    });
  }

  function actualizarSelectsMetodo() {
    var selects = document.querySelectorAll('.metodo-select');
    selects.forEach(function(select) {
      var valorActual = select.value;
      var options = '';
      for (var m = 0; m < metodos.length; m++) {
        options += '<option value="' + metodos[m] + '" ' + (valorActual === metodos[m] ? 'selected' : '') + '>' + metodos[m] + '</option>';
      }
      select.innerHTML = options;
    });
  }

  // ============ GUARDAR TODO ============
  function guardarTodo() {
    var transacciones = [];
    var comprobantes = window.comprobantes || {};
    
    for (var i = 0; i < filas.length; i++) {
      var fila = document.getElementById(filas[i]);
      if (!fila) continue;
      
      var clienteId = fila.querySelector('.cliente-select').value;
      var destinoId = fila.querySelector('.destino-select').value;
      var metodo = fila.querySelector('.metodo-select').value;
      var banco = fila.querySelector('.banco-select').value;
      var ingreso = parseFloat(fila.querySelector('.ingreso').value) || 0;
      var salida = parseFloat(fila.querySelector('.salida').value) || 0;
      var tasa = parseFloat(fila.querySelector('.tasa').value) || 0;
      
      if (clienteId && destinoId && ingreso > 0 && salida > 0 && tasa > 0) {
        transacciones.push({
          fecha: fila.querySelector('.fecha').textContent,
          cliente: clientes.find(c => c.id === clienteId)?.nombre || '',
          metodo: metodo,
          destinatario: destinatarios.find(d => d.id === destinoId)?.nombre || '',
          banco: banco,
          ingreso_usd: ingreso,
          salida_usdt: salida,
          tasa: tasa,
          monto_bs: salida * tasa,
          profit_usd: ingreso - salida,
          comprobante_cliente: comprobantes[filas[i]]?.cliente || null,
          comprobante_destino: comprobantes[filas[i]]?.destino || null
        });
      }
    }
    
    if (transacciones.length === 0) {
      alert('⚠️ No hay transacciones válidas para guardar');
      return;
    }
    
    console.log('Transacciones guardadas:', transacciones);
    alert('✅ ' + transacciones.length + ' transacciones guardadas');
    window.location.href = '/admin/transacciones';
  }

  window.abrirModalBanco = abrirModalBanco;
  window.cerrarModalBanco = cerrarModalBanco;
  window.abrirModalMetodo = abrirModalMetodo;
  window.cerrarModalMetodo = cerrarModalMetodo;
  window.guardarBanco = guardarBanco;
  window.guardarMetodo = guardarMetodo;
  window.guardarTodo = guardarTodo;
  
  document.addEventListener('DOMContentLoaded', function() {
    var btnGuardar = document.getElementById('btnGuardar');
    if (btnGuardar) {
      btnGuardar.onclick = guardarTodo;
    }
  });
</script>