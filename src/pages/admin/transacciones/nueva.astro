  // ===================== CÁLCULOS =====================
  function calcularTransaccion() {
    var ing = parseFloat(document.getElementById('txIngreso').value) || 0;
    var destinatarios = estado.destinatarios || [];
    var totalVES = 0;
    var totalProfit = 0;

    destinatarios.forEach(function(destinatario) {
      var detalle = obtenerDetalleDestinatario(destinatario.id);
      var ingresoAsignado = obtenerIngresoAsignado(destinatario, destinatarios, ing);
      var salida = parseFloat(detalle.salida) || 0;
      var ves = obtenerVESDetalle(destinatario, destinatarios, ing);
      var profit = ingresoAsignado - salida;
      var margenDetalle = ingresoAsignado > 0 ? ((profit / ingresoAsignado) * 100) : 0;
      totalVES += ves;
      totalProfit += profit;

      var detIngreso = document.getElementById('detIngreso-' + destinatario.id);
      var detVES = document.getElementById('detVES-' + destinatario.id);
      var detProfit = document.getElementById('detProfit-' + destinatario.id);
      var detMargen = document.getElementById('detMargen-' + destinatario.id);
      if (detIngreso) detIngreso.textContent = '$' + new Intl.NumberFormat('es-US').format(ingresoAsignado);
      if (detVES) {
        if (detVES.tagName === 'INPUT') {
          if (!tieneVESManual(detalle)) detVES.placeholder = Number.isFinite(ves) ? ves.toFixed(2) : '0.00';
        } else {
          detVES.textContent = new Intl.NumberFormat('es-VE').format(ves);
        }
      }
      if (detProfit) detProfit.textContent = '$' + new Intl.NumberFormat('es-US').format(profit);
      if (detMargen) detMargen.textContent = margenDetalle.toFixed(1) + '%';
    });

    var margen = ing > 0 ? ((totalProfit / ing) * 100) : 0;
    document.getElementById('resVES').textContent = new Intl.NumberFormat('es-VE').format(totalVES);
    document.getElementById('resProfit').textContent = '$' + new Intl.NumberFormat('es-US').format(totalProfit);
    document.getElementById('resMargen').textContent = margen.toFixed(1) + '%';
  }

  function renderResumen() {
    var destinatarios = estado.destinatarios || [];
    document.getElementById('resCliente').textContent = estado.cliente ? estado.cliente.nombre : '—';
    document.getElementById('resClienteInfo').textContent = estado.cliente ? (estado.cliente.telefono || estado.cliente.email) : '—';
    document.getElementById('resDestinatario').textContent = destinatarios.length > 0
      ? destinatarios.map(function(d) { return d.nombre; }).join(', ')
      : '—';
    document.getElementById('resDestinatarioInfo').textContent = destinatarios.length > 0
      ? destinatarios.length + ' destinatario' + (destinatarios.length === 1 ? '' : 's') + ' seleccionado' + (destinatarios.length === 1 ? '' : 's') + ' · entrada fija'
      : '—';
    var metodosUsados = [];
    var tasasUsadas = [];
    var totalSalida = 0;
    var totalVES = 0;
    var totalProfit = 0;

    destinatarios.forEach(function(destinatario) {
      var detalle = obtenerDetalleDestinatario(destinatario.id);
      var ingresoAsignado = obtenerIngresoAsignado(destinatario, destinatarios, estado.ingreso);
      var salida = parseFloat(detalle.salida) || 0;
      var tasa = bancoEsBinance(detalle.banco) ? 0 : (parseFloat(detalle.tasa) || 0);
      var ves = obtenerVESDetalle(destinatario, destinatarios, estado.ingreso);
      if (detalle.metodo && !metodosUsados.includes(detalle.metodo)) metodosUsados.push(detalle.metodo);
      if (!bancoEsBinance(detalle.banco) && tasa > 0) tasasUsadas.push(tasa);
      totalSalida += salida;
      totalVES += ves;
      totalProfit += ingresoAsignado - salida;
    });

    document.getElementById('resMetodo').textContent = metodosUsados.length > 0 ? metodosUsados.join(', ') : '—';
    document.getElementById('resEntrada').textContent = '$' + new Intl.NumberFormat('es-US').format(estado.ingreso) + ' fija';
    document.getElementById('resSalida').textContent = '$' + new Intl.NumberFormat('es-US').format(totalSalida) + (destinatarios.length > 1 ? ' total' : '');
    document.getElementById('resTasa').textContent = tasasUsadas.length === 0
      ? '0'
      : (tasasUsadas.length === 1 ? new Intl.NumberFormat('es-VE').format(tasasUsadas[0]) : 'Varias');
    document.getElementById('resTotalVES').textContent = new Intl.NumberFormat('es-VE').format(totalVES);
    document.getElementById('resTotalProfit').textContent = '$' + new Intl.NumberFormat('es-US').format(totalProfit);
  }

  // ===================== COMPROBANTES =====================
  function validarArchivoComprobante(input) {
    var file = input.files[0];
    if (!file) return null;
    var tiposPermitidos = ['image/jpeg', 'image/png', 'image/webp', 'application/pdf'];
    if (!tiposPermitidos.includes(file.type)) {
      showToast('error', 'Tipo no permitido', 'Solo imágenes o PDF');
      input.value = '';
      return null;
    }
    if (file.size > 5 * 1024 * 1024) {
      showToast('error', 'Muy grande', 'Máximo 5MB');
      input.value = '';
      return null;
    }
    return file;
  }

  function procesarComprobante(input, tipo) {
    var file = validarArchivoComprobante(input);
    if (!file) return;
    estado.comprobantes[tipo] = { nombre: file.name, tipo: file.type, archivo: file };
    var label = document.getElementById('label' + (tipo === 'pago' ? 'Pago' : 'Admin'));
    var drop = document.getElementById('drop' + (tipo === 'pago' ? 'Pago' : 'Admin'));
    label.textContent = file.name.length > 20 ? file.name.substring(0, 18) + '...' : file.name;
    label.classList.add('text-emerald-600');
    drop.classList.remove('border-slate-300', 'bg-slate-50');
    drop.classList.add('border-emerald-400', 'bg-emerald-50');
    renderPreviewComprobante(tipo, file);
  }

  function procesarComprobanteEgreso(input, destinatarioId) {
    var file = validarArchivoComprobante(input);
    if (!file) return;
    if (!estado.comprobantes.egresos) estado.comprobantes.egresos = {};
    var previewKey = 'egreso-' + destinatarioId;
    revokePreviewUrl(previewKey);
    previewUrls[previewKey] = URL.createObjectURL(file);
    estado.comprobantes.egresos[destinatarioId] = { nombre: file.name, tipo: file.type, archivo: file };
    renderComprobantesEgreso();
  }

