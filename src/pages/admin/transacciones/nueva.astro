  <!-- Modal de éxito / Nueva transacción -->
  <div id="modalExito" class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm flex items-center justify-center hidden z-50 transition-opacity p-4">
    <div class="bg-white rounded-3xl p-8 max-w-sm w-full shadow-[0_20px_60px_rgba(0,0,0,0.15)] border border-slate-200 text-center scale-95 transition-transform" id="modalContentExito">
      <div class="w-16 h-16 rounded-full bg-emerald-100 text-emerald-600 flex items-center justify-center mx-auto mb-4">
        <Check class="w-8 h-8" />
      </div>
      <h2 class="text-xl font-extrabold text-slate-800 mb-2">¡Transacción guardada!</h2>
      <p class="text-sm text-slate-500 font-medium mb-6">La operación fue registrada exitosamente.</p>
      <div class="flex flex-col gap-3">
        <button onclick="nuevaTransaccion()" class="w-full px-5 py-3 bg-indigo-600 text-white rounded-xl font-bold text-sm shadow-[0_4px_12px_rgba(79,70,229,0.2)] hover:bg-indigo-700 transition-all">
          <Plus class="w-4 h-4 inline -mt-0.5 mr-1" /> Registrar otra
        </button>
        <a href="/admin/transacciones" class="w-full px-5 py-3 border-2 border-slate-200 text-slate-600 rounded-xl font-bold text-sm hover:bg-slate-50 transition-all inline-block">
          Ver transacciones
        </a>
