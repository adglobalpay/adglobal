    <!-- Botones de navegación entre pasos (1-3) -->
    <div id="navPasos" class="flex justify-between items-center anim-fade-in stagger-3">
      <button id="btnAtras" onclick="pasoAnterior()" class="px-6 py-3 border-2 border-slate-200 text-slate-600 rounded-xl font-bold text-sm hover:bg-slate-50 transition-all disabled:opacity-40 disabled:cursor-not-allowed hidden">
        <ChevronLeft class="w-4 h-4 inline -mt-0.5 mr-1" /> Atrás
