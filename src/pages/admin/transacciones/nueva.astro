      <div></div>
      <button id="btnSiguiente" onclick="pasoSiguiente()" class="px-8 py-3 bg-indigo-600 text-white rounded-xl font-bold text-sm shadow-[0_4px_12px_rgba(79,70,229,0.2)] hover:bg-indigo-700 hover:shadow-[0_4px_16px_rgba(79,70,229,0.3)] transition-all flex items-center gap-2 disabled:opacity-40 disabled:cursor-not-allowed">
        Siguiente <ChevronRight class="w-4 h-4" />
