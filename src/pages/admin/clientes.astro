<script is:inline>
  // Helper para mostrar toast
  function showToast(type, message, description) {
    window.dispatchEvent(new CustomEvent('show-toast', {
      detail: { type: type, message: message, description: description }
    }));
  }

  document.addEventListener('DOMContentLoaded', function() {
    var btnNuevoCliente = document.getElementById('btnNuevoCliente');
    if (btnNuevoCliente) {
      btnNuevoCliente.onclick = function(e) {
        e.preventDefault();
        abrirModalCliente();
      };
    }
    updateClienteTipoUI();
    var clienteTipo = document.getElementById('clienteTipo');
    if (clienteTipo) {
      clienteTipo.addEventListener('change', updateClienteTipoUI);
    }
  });

  function updateClienteTipoUI() {
    var tipo = document.getElementById('clienteTipo') && document.getElementById('clienteTipo').value === 'JURIDICO' ? 'JURIDICO' : 'NATURAL';
    var label = document.getElementById('clienteNombreLabel');
    var input = document.getElementById('clienteNombre');
    if (label) label.textContent = tipo === 'JURIDICO' ? 'Razón social *' : 'Nombre *';
    if (input) input.placeholder = tipo === 'JURIDICO' ? 'Ej. AD Global Services LLC' : 'Ej. Juan Pérez';
  }

  function abrirModalCliente() {
    const modal = document.getElementById('modalCliente');
    const content = document.getElementById('modalContentCliente');
    modal.classList.remove('hidden');
    modal.classList.add('anim-overlay');
    setTimeout(() => {
      content.style.transform = 'scale(1)';
      content.classList.add('anim-modal');
    }, 10);
  }

  function cerrarModalCliente() {
    const modal = document.getElementById('modalCliente');
    const content = document.getElementById('modalContentCliente');
    content.style.transform = 'scale(0.95)';
    setTimeout(() => {
      modal.classList.add('hidden');
      content.classList.remove('anim-modal');
    }, 200);
  }

  async function guardarCliente(e) {
    e.preventDefault();

    var clientType = document.getElementById('clienteTipo').value;
    var nombreCompleto = document.getElementById('clienteNombre').value.trim();
    var firstName = '';
    var lastName = '';

    if (clientType === 'JURIDICO') {
      firstName = nombreCompleto;
    } else {
      var partes = nombreCompleto.split(' ');
      firstName = partes[0] || '';
      lastName = partes.slice(1).join(' ') || '';
    }

    var payload = {
      clientType: clientType,
      firstName: firstName,
      lastName: lastName,
      phone: document.getElementById('clienteTelefono').value,
      email: document.getElementById('clienteEmail').value,
      documentId: document.getElementById('clienteDocumento').value,
      country: document.getElementById('clientePais').value,
      preferredMethod: document.getElementById('clienteMetodo').value,
      notes: document.getElementById('clienteNotas').value
    };

    var token = localStorage.getItem('adglobal_token');
    if (!token) {
      showToast('error', 'No autenticado', 'Por favor inicia sesión nuevamente.');
      return;
    }

    var API_URL = window.__ADGLOBAL_API_URL__ || 'http://localhost:3001';

    try {
      var res = await fetch(API_URL + '/api/clients', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': 'Bearer ' + token
        },
        body: JSON.stringify(payload)
      });

      var data = await res.json();

      if (!res.ok) {
        throw new Error(data.error || 'Error al crear cliente');
      }

      showToast('success', 'Cliente creado', payload.firstName + ' ' + payload.lastName + ' fue registrado exitosamente.');

      // Cerrar modal y limpiar formulario
      document.getElementById('formCliente').reset();
      updateClienteTipoUI();
      cerrarModalCliente();

      // Notificar a la tabla para que refresque sin recargar la página
      window.dispatchEvent(new CustomEvent('clients:refresh'));

    } catch (err) {
      showToast('error', 'Error al crear cliente', err.message);
    }
  }

  // === DROPDOWN CUSTOM DE MÉTODO ===
  function toggleMetodoDropdown() {
    var menu = document.getElementById('metodoDropdownMenu');
    var arrow = document.getElementById('metodoDropdownArrow');
    if (menu.classList.contains('hidden')) {
      menu.classList.remove('hidden');
      arrow.style.transform = 'rotate(180deg)';
    } else {
      menu.classList.add('hidden');
      arrow.style.transform = 'rotate(0deg)';
    }
  }

  function selectMetodo(valor, letra, clases) {
    document.getElementById('clienteMetodo').value = valor;
    document.getElementById('metodoSelectedLabel').textContent = valor;
    var icon = document.getElementById('metodoSelectedIcon');
    icon.textContent = letra;
    icon.className = 'w-7 h-7 rounded-lg flex items-center justify-center text-xs font-black transition-all ' + clases;
    toggleMetodoDropdown();
  }

  document.addEventListener('click', function(e) {
    var wrapper = document.getElementById('metodoDropdownWrapper');
    var menu = document.getElementById('metodoDropdownMenu');
    var arrow = document.getElementById('metodoDropdownArrow');
    if (wrapper && !wrapper.contains(e.target)) {
      menu.classList.add('hidden');
      arrow.style.transform = 'rotate(0deg)';
    }
  });

  // === CARGA DINÁMICA DE MÉTODOS DESDE API ===
  var API_URL_CLIENTES = window.__ADGLOBAL_API_URL__ || 'https://backend-global-production.up.railway.app';

  async function cargarMetodosAPI() {
    try {
      var token = localStorage.getItem('adglobal_token');
      var res = await fetch(API_URL_CLIENTES + '/api/payment-methods', {
        headers: { 'Authorization': 'Bearer ' + token }
      });
      if (!res.ok) throw new Error('Error cargando metodos');
      var data = await res.json();
      return data.map(function(pm) {
        return {
          nombre: pm.name,
          letra: pm.letter,
          clases: pm.classes,
          subtitulo: pm.subtitle || ''
        };
      });
    } catch (e) {
      console.error('Error cargando metodos:', e);
      return [];
    }
  }

  async function renderDropdownMetodos() {
    var list = document.getElementById('metodoDropdownList');
    if (!list) return;
    var metodos = await cargarMetodosAPI();
    var html = '';
    for (var i = 0; i < metodos.length; i++) {
      var m = metodos[i];
      html += '<button type="button" onclick="selectMetodo(\'' + m.nombre + '\', \'' + m.letra + '\', \'' + m.clases + '\')" class="w-full text-left px-3 py-2.5 rounded-lg hover:bg-slate-50 transition-all duration-200 flex items-center gap-3 group/metodo">' +
        '<span class="w-8 h-8 rounded-lg ' + m.clases + ' flex items-center justify-center text-xs font-black group-hover/metodo:scale-110 transition-transform">' + m.letra + '</span>' +
        '<div>' +
          '<p class="font-bold text-sm text-slate-800">' + m.nombre + '</p>' +
          '<p class="text-[0.65rem] text-slate-400 font-medium">' + (m.subtitulo || '') + '</p>' +
        '</div>' +
      '</button>';
    }
    list.innerHTML = html;
  }

  renderDropdownMetodos();
</script>
