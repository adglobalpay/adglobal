---
// src/pages/admin/login.astro
import ToastProvider from '../../components/admin/ToastProvider';

const API_URL = import.meta.env.VITE_API_URL || 'https://backend-global-production.up.railway.app';
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
  
  <link rel="icon" href="/img/logo.webp" type="image/webp" />
  <title>Iniciar sesión - AD Global Pay</title>

  <style is:global>
    :root {
      --font-body: 'DM Sans', sans-serif;
      --font-heading: 'Outfit', sans-serif;
      --font-mono: 'JetBrains Mono', monospace;
    }
    body {
      font-family: var(--font-body);
      -webkit-tap-highlight-color: transparent;
    }
    h1, h2, h3, h4, h5, h6 {
      font-family: var(--font-heading);
    }

    @keyframes fadeInUp {
      from { opacity: 0; transform: translateY(24px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes fadeInScale {
      from { opacity: 0; transform: scale(0.96); }
      to { opacity: 1; transform: scale(1); }
    }
    @keyframes float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-8px); }
    }

    .anim-fade-in-up {
      animation: fadeInUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      opacity: 0;
    }
    .anim-scale-in {
      animation: fadeInScale 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      opacity: 0;
    }
    .stagger-1 { animation-delay: 0.08s; }
    .stagger-2 { animation-delay: 0.16s; }
    .stagger-3 { animation-delay: 0.24s; }
    .stagger-4 { animation-delay: 0.32s; }
    .stagger-5 { animation-delay: 0.40s; }

    .float-anim {
      animation: float 5s ease-in-out infinite;
    }

    .glass-card {
      background: rgba(255, 255, 255, 0.75);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid rgba(255, 255, 255, 0.6);
      box-shadow: 0 25px 50px -12px rgba(15, 23, 42, 0.15), 0 0 0 1px rgba(226, 232, 240, 0.5);
    }

    .input-glow:focus {
      box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.15), 0 4px 12px -4px rgba(99, 102, 241, 0.2);
    }

    .btn-gradient {
      background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%);
      background-size: 200% 200%;
      transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .btn-gradient:hover {
      background-position: 100% 0;
      transform: translateY(-2px);
      box-shadow: 0 12px 32px -8px rgba(79, 70, 229, 0.45);
    }
    .btn-gradient:active {
      transform: translateY(0) scale(0.98);
    }

    @media (pointer: coarse) {
      button, a, input {
        min-height: 44px;
      }
    }
  </style>
</head>
<body class="min-h-screen flex items-center justify-center relative overflow-hidden bg-slate-50">
  
  <!-- Decorative background blobs -->
  <div class="absolute top-0 left-0 w-full h-full overflow-hidden pointer-events-none">
    <div class="absolute -top-40 -left-40 w-[500px] h-[500px] bg-indigo-200/40 rounded-full blur-[100px] float-anim" style="animation-duration: 8s;"></div>
    <div class="absolute -bottom-40 -right-40 w-[600px] h-[600px] bg-cyan-200/30 rounded-full blur-[120px] float-anim" style="animation-duration: 10s; animation-delay: 2s;"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-emerald-100/20 rounded-full blur-[140px] float-anim" style="animation-duration: 12s; animation-delay: 1s;"></div>
    
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('https://www.transparenttextures.com/patterns/cubes.png');"></div>
  </div>

  <div class="relative z-10 w-full max-w-md px-5 py-8 md:px-0">
    
    <!-- Logo -->
    <div class="flex flex-col items-center mb-8 anim-scale-in stagger-1">
      <img src="/img/logo.webp" alt="AD Global Pay" class="w-16 h-16 rounded-2xl shadow-xl shadow-indigo-500/25 mb-4 float-anim object-cover" />
      <h1 class="text-2xl font-bold text-slate-800 tracking-tight" style="font-family: var(--font-heading);">AD Global Pay</h1>
      <p class="text-sm font-medium text-slate-500 mt-1 tracking-wide">Panel de Administración</p>
    </div>

    <!-- Login Card -->
    <div class="glass-card rounded-3xl p-6 md:p-8 anim-fade-in-up stagger-2">
      
      <div class="mb-6">
        <h2 class="text-lg font-bold text-slate-800" style="font-family: var(--font-heading);">Bienvenido de vuelta</h2>
        <p class="text-sm text-slate-500 mt-1 font-medium">Ingresa tus credenciales para continuar</p>
      </div>

      <form id="loginForm" class="space-y-5" onsubmit="event.preventDefault();">
        
        <div id="errorMessage" class="hidden p-3 bg-red-50 border border-red-200 rounded-xl text-sm text-red-700 font-medium text-center"></div>

        <!-- Email -->
        <div class="anim-fade-in-up stagger-3">
          <label for="email" class="block text-xs font-bold uppercase tracking-wider text-slate-500 mb-2">Correo electrónico</label>
          <div class="relative group">
            <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none transition-colors duration-300 text-slate-400 group-focus-within:text-indigo-500">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            </div>
            <input
              type="email"
              id="email"
              name="email"
              placeholder="admin@adglobalpay.com"
              class="w-full pl-11 pr-4 py-3 bg-white/80 border border-slate-200 text-slate-800 rounded-xl focus:outline-none focus:border-indigo-400 input-glow transition-all duration-300 font-medium placeholder:text-slate-400 placeholder:font-normal text-sm"
              autocomplete="username"
            />
          </div>
        </div>

        <!-- Password -->
        <div class="anim-fade-in-up stagger-4">
          <label for="password" class="block text-xs font-bold uppercase tracking-wider text-slate-500 mb-2">Contraseña</label>
          <div class="relative group">
            <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none transition-colors duration-300 text-slate-400 group-focus-within:text-indigo-500">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            </div>
            <input
              type="password"
              id="password"
              name="password"
              placeholder="••••••••"
              class="w-full pl-11 pr-11 py-3 bg-white/80 border border-slate-200 text-slate-800 rounded-xl focus:outline-none focus:border-indigo-400 input-glow transition-all duration-300 font-medium placeholder:text-slate-400 text-sm"
              autocomplete="current-password"
            />
            <button
              type="button"
              id="togglePassword"
              class="absolute inset-y-0 right-0 pr-3 flex items-center text-slate-400 hover:text-slate-600 transition-colors cursor-pointer"
              aria-label="Mostrar contraseña"
            >
              <svg id="eyeIcon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
              <svg id="eyeOffIcon" class="hidden" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.88 9.88a3 3 0 1 0 4.24 4.24"/><path d="M10.73 5.08A10.43 10.43 0 0 1 12 5c7 0 10 7 10 7a13.16 13.16 0 0 1-1.67 2.68"/><path d="M6.61 6.61A13.526 13.526 0 0 0 2 12s3 7 10 7a9.74 9.74 0 0 0 5.39-1.61"/><line x1="2" x2="22" y1="2" y2="22"/></svg>
            </button>
          </div>
        </div>

        <!-- Remember + Forgot -->
        <div class="flex items-center justify-between anim-fade-in-up stagger-4">
          <label class="flex items-center gap-2 cursor-pointer group">
            <input type="checkbox" id="rememberMe" class="w-4 h-4 rounded-md border-slate-300 text-indigo-600 focus:ring-indigo-500/20 accent-indigo-600 cursor-pointer" />
            <span class="text-sm text-slate-500 font-medium group-hover:text-slate-700 transition-colors">Recordarme</span>
          </label>
          <a href="#" class="text-sm font-bold text-indigo-600 hover:text-indigo-700 transition-colors link-anim">¿Olvidaste tu contraseña?</a>
        </div>

        <!-- Submit -->
        <div class="anim-fade-in-up stagger-5 pt-1">
          <button
            type="submit"
            id="submitBtn"
            class="btn-gradient w-full text-white font-bold py-3.5 rounded-xl shadow-lg shadow-indigo-500/25 text-sm tracking-wide"
          >
            Iniciar sesión
          </button>
        </div>
      </form>

      <!-- Divider -->
      <div class="relative my-6 anim-fade-in-up stagger-5">
        <div class="absolute inset-0 flex items-center">
          <div class="w-full border-t border-slate-200"></div>
        </div>
        <div class="relative flex justify-center text-xs">
          <span class="bg-white/60 px-3 text-slate-400 font-semibold uppercase tracking-wider">O</span>
        </div>
      </div>

      <!-- Back to site -->
      <div class="text-center anim-fade-in-up stagger-5">
        <a href="/" class="inline-flex items-center gap-2 text-sm font-bold text-slate-500 hover:text-slate-800 transition-colors group">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:-translate-x-1 transition-transform"><path d="m15 18-6-6 6-6"/></svg>
          Volver al sitio público
        </a>
      </div>
    </div>

    <!-- Footer -->
    <p class="text-center text-xs text-slate-400 mt-8 font-medium anim-fade-in-up stagger-5">
      © 2026 AD Global Services LLC. Todos los derechos reservados.
    </p>
  </div>

  <ToastProvider client:load />

  <script is:inline define:vars={{ API_URL }}>
    window.__ADGLOBAL_API_URL__ = API_URL;
  </script>
  <script is:inline>
    (function() {
      // Helper para mostrar toast
      function showToast(type, message, description) {
        window.dispatchEvent(new CustomEvent('show-toast', {
          detail: { type: type, message: message, description: description }
        }));
      }

      // Toggle password visibility
      var toggle = document.getElementById('togglePassword');
      var input = document.getElementById('password');
      var eye = document.getElementById('eyeIcon');
      var eyeOff = document.getElementById('eyeOffIcon');
      
      if (toggle && input) {
        toggle.addEventListener('click', function() {
          var isPassword = input.type === 'password';
          input.type = isPassword ? 'text' : 'password';
          if (eye && eyeOff) {
            eye.classList.toggle('hidden', !isPassword);
            eyeOff.classList.toggle('hidden', isPassword);
          }
        });
      }

      // Check if already logged in
      var token = localStorage.getItem('adglobal_token');
      if (token) {
        window.location.href = '/admin';
        return;
      }

      // Login form
      var form = document.getElementById('loginForm');
      var errorMsg = document.getElementById('errorMessage');
      var submitBtn = document.getElementById('submitBtn');
      
      if (form) {
        form.addEventListener('submit', async function(e) {
          e.preventDefault();
          
          var email = document.getElementById('email').value.trim();
          var password = document.getElementById('password').value;
          
          if (!email || !password) {
            showToast('error', 'Campos requeridos', 'Por favor ingresa email y contraseña');
            return;
          }
          
          // Loading state
          var originalText = submitBtn.textContent;
          submitBtn.innerHTML = '<svg class="animate-spin mx-auto" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>';
          submitBtn.disabled = true;
          if (errorMsg) errorMsg.classList.add('hidden');
          
          try {
            var API_URL = window.__ADGLOBAL_API_URL__ || 'http://localhost:3001';
            var res = await fetch(API_URL + '/api/auth/login', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ email: email, password: password })
            });
            
            var data = await res.json();
            
            if (!res.ok) {
              throw new Error(data.error || 'Credenciales invalidas');
            }
            
            // Save auth
            localStorage.setItem('adglobal_token', data.token);
            localStorage.setItem('adglobal_user', JSON.stringify(data.user));
            
            showToast('success', 'Inicio de sesion exitoso', 'Bienvenido de vuelta, ' + (data.user.firstName || 'Admin'));
            
            // Redirect to dashboard
            setTimeout(function() {
              window.location.href = '/admin';
            }, 800);
            
          } catch (err) {
            showToast('error', 'Error al iniciar sesion', err.message || 'Credenciales invalidas');
            if (errorMsg) {
              errorMsg.textContent = err.message || 'Error al iniciar sesion';
              errorMsg.classList.remove('hidden');
            }
            submitBtn.innerHTML = originalText;
            submitBtn.disabled = false;
          }
        });
      }
    })();

    // Interceptar alert() y convertir en toast
    (function() {
      window.alert = function(message) {
        window.dispatchEvent(new CustomEvent('show-toast', {
          detail: { type: 'info', message: message }
        }));
      };
    })();
  </script>
</body>
</html>
