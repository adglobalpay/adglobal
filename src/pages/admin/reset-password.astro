---
import ToastProvider from '../../components/admin/ToastProvider';

const API_URL = import.meta.env.VITE_API_URL || 'https://backend-global-production.up.railway.app';
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet">
  <link rel="icon" href="/img/logo.webp" type="image/webp" />
  <title>Nueva contraseña - AD Global Pay</title>

  <style is:global>
    :root {
      --font-body: 'DM Sans', sans-serif;
      --font-heading: 'Outfit', sans-serif;
    }
    body {
      font-family: var(--font-body);
      -webkit-tap-highlight-color: transparent;
    }
    h1, h2, h3, h4, h5, h6 {
      font-family: var(--font-heading);
    }
    @keyframes fadeInUp {
      from { opacity: 0; transform: translateY(24px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes fadeInScale {
      from { opacity: 0; transform: scale(0.96); }
      to { opacity: 1; transform: scale(1); }
    }
    @keyframes float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-8px); }
    }
    .anim-fade-in-up {
      animation: fadeInUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      opacity: 0;
    }
    .anim-scale-in {
      animation: fadeInScale 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      opacity: 0;
    }
    .float-anim {
      animation: float 5s ease-in-out infinite;
    }
    .glass-card {
      background: rgba(255, 255, 255, 0.78);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid rgba(255, 255, 255, 0.62);
      box-shadow: 0 25px 50px -12px rgba(15, 23, 42, 0.15), 0 0 0 1px rgba(226, 232, 240, 0.5);
    }
    .input-glow:focus {
      box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.14), 0 4px 12px -4px rgba(37, 99, 235, 0.2);
    }
    .btn-gradient {
      background: linear-gradient(135deg, #2563eb 0%, #4f46e5 100%);
      background-size: 200% 200%;
      transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .btn-gradient:hover {
      background-position: 100% 0;
      transform: translateY(-2px);
      box-shadow: 0 12px 32px -8px rgba(37, 99, 235, 0.45);
    }
    .btn-gradient:active {
      transform: translateY(0) scale(0.98);
    }
    @media (pointer: coarse) {
      button, a, input {
        min-height: 44px;
      }
    }
  </style>
</head>
<body class="min-h-screen flex items-center justify-center relative overflow-hidden bg-slate-50">
  <div class="absolute top-0 left-0 w-full h-full overflow-hidden pointer-events-none">
    <div class="absolute -top-40 -left-40 w-[500px] h-[500px] bg-blue-200/40 rounded-full blur-[100px] float-anim" style="animation-duration: 8s;"></div>
    <div class="absolute -bottom-40 -right-40 w-[600px] h-[600px] bg-cyan-200/30 rounded-full blur-[120px] float-anim" style="animation-duration: 10s; animation-delay: 2s;"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-emerald-100/20 rounded-full blur-[140px] float-anim" style="animation-duration: 12s; animation-delay: 1s;"></div>
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('https://www.transparenttextures.com/patterns/cubes.png');"></div>
  </div>

  <div class="relative z-10 w-full max-w-md px-5 py-8 md:px-0">
    <div class="flex flex-col items-center mb-8 anim-scale-in">
      <img src="/img/logo.webp" alt="AD Global Pay" class="w-16 h-16 rounded-2xl shadow-xl shadow-blue-500/20 mb-4 float-anim object-cover" />
      <h1 class="text-2xl font-bold text-slate-800 tracking-tight">AD Global Pay</h1>
      <p class="text-sm font-medium text-slate-500 mt-1 tracking-wide">Panel de Administración</p>
    </div>

    <div class="glass-card rounded-3xl p-6 md:p-8 anim-fade-in-up">
      <div class="mb-6">
        <h2 class="text-lg font-bold text-slate-800">Nueva contraseña</h2>
        <p class="text-sm text-slate-500 mt-1 font-medium">Crea una clave segura para volver a entrar.</p>
      </div>

      <form id="resetForm" class="space-y-5" onsubmit="event.preventDefault();">
        <div id="errorMessage" class="hidden p-3 bg-red-50 border border-red-200 rounded-xl text-sm text-red-700 font-medium text-center"></div>

        <div>
          <label for="password" class="block text-xs font-bold uppercase tracking-wider text-slate-500 mb-2">Contraseña nueva</label>
          <input
            type="password"
            id="password"
            name="password"
            minlength="8"
            class="w-full px-4 py-3 bg-white/80 border border-slate-200 text-slate-800 rounded-xl focus:outline-none focus:border-blue-400 input-glow transition-all duration-300 font-medium text-sm"
            autocomplete="new-password"
          />
        </div>

        <div>
          <label for="confirmPassword" class="block text-xs font-bold uppercase tracking-wider text-slate-500 mb-2">Confirmar contraseña</label>
          <input
            type="password"
            id="confirmPassword"
            name="confirmPassword"
            minlength="8"
            class="w-full px-4 py-3 bg-white/80 border border-slate-200 text-slate-800 rounded-xl focus:outline-none focus:border-blue-400 input-glow transition-all duration-300 font-medium text-sm"
            autocomplete="new-password"
          />
        </div>

        <button
          type="submit"
          id="submitBtn"
          class="btn-gradient w-full text-white font-bold py-3.5 rounded-xl shadow-lg shadow-blue-500/25 text-sm tracking-wide"
        >
          Guardar contraseña
        </button>
      </form>

      <div class="text-center mt-6">
        <a href="/admin/login" class="inline-flex items-center gap-2 text-sm font-bold text-slate-500 hover:text-slate-800 transition-colors group">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:-translate-x-1 transition-transform"><path d="m15 18-6-6 6-6"/></svg>
          Volver al login
        </a>
      </div>
    </div>
  </div>

  <ToastProvider client:load />

  <script is:inline define:vars={{ API_URL }}>
    window.__ADGLOBAL_API_URL__ = API_URL;
  </script>
  <script is:inline>
    (function() {
      function showToast(type, message, description) {
        window.dispatchEvent(new CustomEvent('show-toast', {
          detail: { type: type, message: message, description: description }
        }));
      }

      var params = new URLSearchParams(window.location.search);
      var token = params.get('token') || '';
      var form = document.getElementById('resetForm');
      var submitBtn = document.getElementById('submitBtn');
      var errorMsg = document.getElementById('errorMessage');

      if (!token) {
        if (errorMsg) {
          errorMsg.textContent = 'El enlace no es valido o esta incompleto';
          errorMsg.classList.remove('hidden');
        }
        if (submitBtn) submitBtn.disabled = true;
      }

      if (form) {
        form.addEventListener('submit', async function(e) {
          e.preventDefault();

          var password = document.getElementById('password').value;
          var confirmPassword = document.getElementById('confirmPassword').value;

          if (password.length < 8) {
            showToast('error', 'Contraseña muy corta', 'Usa al menos 8 caracteres');
            return;
          }

          if (password !== confirmPassword) {
            showToast('error', 'No coinciden', 'Confirma la misma contraseña');
            return;
          }

          var originalText = submitBtn.textContent;
          submitBtn.innerHTML = '<svg class="animate-spin mx-auto" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>';
          submitBtn.disabled = true;
          if (errorMsg) errorMsg.classList.add('hidden');

          try {
            var API_URL = window.__ADGLOBAL_API_URL__ || 'http://localhost:3001';
            var res = await fetch(API_URL + '/api/auth/reset-password', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ token: token, password: password })
            });
            var data = await res.json().catch(function() { return {}; });

            if (!res.ok) {
              throw new Error(data.error || 'No se pudo actualizar la contraseña');
            }

            localStorage.removeItem('adglobal_token');
            localStorage.removeItem('adglobal_user');
            showToast('success', 'Contraseña actualizada', 'Ya puedes iniciar sesión');
            setTimeout(function() {
              window.location.href = '/admin/login';
            }, 900);
          } catch (err) {
            showToast('error', 'No se pudo guardar', err.message || 'El enlace puede haber expirado');
            if (errorMsg) {
              errorMsg.textContent = err.message || 'Error al restablecer contraseña';
              errorMsg.classList.remove('hidden');
            }
            submitBtn.innerHTML = originalText;
            submitBtn.disabled = false;
          }
        });
      }
    })();
  </script>
</body>
</html>
