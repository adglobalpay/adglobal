---
// Página estática para verificación KYC
// El token se lee del query string con JavaScript del lado del cliente
// Diseño premium alineado con la identidad visual de AD Global Pay
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes, viewport-fit=cover">
  <title>Verificación de Identidad — AD Global Pay</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="icon" href="/img/logo.webp" type="image/webp" />
  <style>
    :root {
      --font-heading: 'Outfit', sans-serif;
      --font-body: 'DM Sans', sans-serif;
      --font-mono: 'JetBrains Mono', monospace;
      --indigo: #6366f1;
      --indigo-light: #818cf8;
      --indigo-dark: #4f46e5;
      --indigo-50: #eef2ff;
      --indigo-100: #e0e7ff;
      --indigo-200: #c7d2fe;
      --cyan: #06b6d4;
      --emerald: #10b981;
      --emerald-50: #ecfdf5;
      --emerald-100: #d1fae5;
      --amber: #f59e0b;
      --rose: #f43f5e;
      --slate-50: #f8fafc;
      --slate-100: #f1f5f9;
      --slate-200: #e2e8f0;
      --slate-300: #cbd5e1;
      --slate-400: #94a3b8;
      --slate-500: #64748b;
      --slate-600: #475569;
      --slate-700: #334155;
      --slate-800: #1e293b;
      --slate-900: #0f172a;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: var(--font-body);
      background: linear-gradient(160deg, var(--slate-50) 0%, #f0f4ff 40%, #e8f4fd 100%);
      min-height: 100vh;
      color: var(--slate-800);
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      overflow-x: hidden;
    }

    /* ===== ANIMATIONS ===== */
    @keyframes fadeInUp {
      from { opacity: 0; transform: translateY(24px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes fadeInScale {
      from { opacity: 0; transform: scale(0.96); }
      to { opacity: 1; transform: scale(1); }
    }
    @keyframes slideInLeft {
      from { opacity: 0; transform: translateX(-30px); }
      to { opacity: 1; transform: translateX(0); }
    }
    @keyframes slideInRight {
      from { opacity: 0; transform: translateX(30px); }
      to { opacity: 1; transform: translateX(0); }
    }
    @keyframes pulse-ring {
      0% { transform: scale(0.8); opacity: 1; }
      100% { transform: scale(1.6); opacity: 0; }
    }
    @keyframes float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-8px); }
    }
    @keyframes spin {
      from { transform: rotate(0deg); }
      to { transform: rotate(360deg); }
    }
    @keyframes shimmer {
      0% { background-position: -200% 0; }
      100% { background-position: 200% 0; }
    }
    @keyframes drawCheck {
      0% { stroke-dashoffset: 24; }
      100% { stroke-dashoffset: 0; }
    }
    @keyframes progressFill {
      from { width: 0%; }
      to { width: 100%; }
    }
    @keyframes badgePulse {
      0%, 100% { box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.4); }
      50% { box-shadow: 0 0 0 8px rgba(16, 185, 129, 0); }
    }
    @keyframes gradientShift {
      0% { background-position: 0% 50%; }
      50% { background-position: 100% 50%; }
      100% { background-position: 0% 50%; }
    }

    .anim-fade-up {
      animation: fadeInUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      opacity: 0;
    }
    .anim-scale-in {
      animation: fadeInScale 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      opacity: 0;
    }
    .anim-slide-left { animation: slideInLeft 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards; opacity: 0; }
    .anim-slide-right { animation: slideInRight 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards; opacity: 0; }

    .delay-1 { animation-delay: 0.08s; }
    .delay-2 { animation-delay: 0.16s; }
    .delay-3 { animation-delay: 0.24s; }
    .delay-4 { animation-delay: 0.32s; }
    .delay-5 { animation-delay: 0.40s; }
    .delay-6 { animation-delay: 0.48s; }

    /* ===== BACKGROUND DECORATIONS ===== */
    .bg-decoration {
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 0;
      overflow: hidden;
    }
    .bg-decoration::before {
      content: '';
      position: absolute;
      top: -20%;
      right: -10%;
      width: 600px;
      height: 600px;
      background: radial-gradient(circle, rgba(99, 102, 241, 0.08) 0%, transparent 70%);
      border-radius: 50%;
    }
    .bg-decoration::after {
      content: '';
      position: absolute;
      bottom: -10%;
      left: -5%;
      width: 500px;
      height: 500px;
      background: radial-gradient(circle, rgba(6, 182, 212, 0.06) 0%, transparent 70%);
      border-radius: 50%;
    }

    /* ===== HEADER ===== */
    .kyc-header {
      position: relative;
      z-index: 10;
      padding: 1.5rem;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .kyc-header-inner {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 0.625rem 1.25rem;
      background: rgba(255, 255, 255, 0.7);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid rgba(226, 232, 240, 0.6);
      border-radius: 9999px;
      box-shadow: 0 4px 20px -4px rgba(15, 23, 42, 0.06);
    }
    .kyc-header-logo {
      width: 32px;
      height: 32px;
      border-radius: 10px;
      background: linear-gradient(135deg, var(--indigo) 0%, var(--cyan) 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: 14px;
      flex-shrink: 0;
    }
    .kyc-header-title {
      font-family: var(--font-heading);
      font-weight: 700;
      font-size: 0.875rem;
      color: var(--slate-800);
      letter-spacing: -0.01em;
    }
    .kyc-header-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.25rem;
      padding: 0.25rem 0.625rem;
      background: var(--emerald-50);
      border: 1px solid var(--emerald-100);
      border-radius: 9999px;
      font-size: 0.7rem;
      font-weight: 700;
      color: var(--emerald);
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    /* ===== MAIN CONTAINER ===== */
    .kyc-container {
      position: relative;
      z-index: 10;
      max-width: 520px;
      margin: 0 auto;
      padding: 0 1rem 3rem;
    }

    /* ===== CARD ===== */
    .kyc-card {
      background: rgba(255, 255, 255, 0.85);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border: 1px solid rgba(226, 232, 240, 0.7);
      border-radius: 28px;
      box-shadow: 0 20px 60px -16px rgba(15, 23, 42, 0.08), 0 0 0 1px rgba(255, 255, 255, 0.5) inset;
      overflow: hidden;
      transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s ease;
    }
    .kyc-card:hover {
      box-shadow: 0 24px 72px -16px rgba(15, 23, 42, 0.12), 0 0 0 1px rgba(255, 255, 255, 0.5) inset;
    }

    /* ===== HERO SECTION ===== */
    .kyc-hero {
      position: relative;
      padding: 2.5rem 1.75rem 2rem;
      text-align: center;
      background: linear-gradient(135deg, var(--indigo) 0%, var(--indigo-dark) 50%, #4338ca 100%);
      background-size: 200% 200%;
      animation: gradientShift 8s ease infinite;
      overflow: hidden;
    }
    .kyc-hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.04'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    }
    .kyc-hero-step {
      position: relative;
      z-index: 2;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.375rem 1rem;
      background: rgba(255, 255, 255, 0.12);
      border: 1px solid rgba(255, 255, 255, 0.15);
      border-radius: 9999px;
      font-family: var(--font-heading);
      font-size: 0.75rem;
      font-weight: 600;
      color: rgba(255, 255, 255, 0.85);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      margin-bottom: 1.25rem;
    }
    .kyc-hero-step-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--emerald);
      animation: badgePulse 2s ease-in-out infinite;
    }
    .kyc-hero-icon-wrap {
      position: relative;
      z-index: 2;
      width: 72px;
      height: 72px;
      margin: 0 auto 1.25rem;
      border-radius: 22px;
      background: rgba(255, 255, 255, 0.1);
      border: 1px solid rgba(255, 255, 255, 0.15);
      backdrop-filter: blur(8px);
      display: flex;
      align-items: center;
      justify-content: center;
      animation: float 5s ease-in-out infinite;
    }
    .kyc-hero-icon-wrap svg {
      width: 32px;
      height: 32px;
      color: white;
    }
    .kyc-hero h1 {
      position: relative;
      z-index: 2;
      font-family: var(--font-heading);
      font-size: 1.5rem;
      font-weight: 800;
      color: white;
      letter-spacing: -0.02em;
      line-height: 1.2;
      margin-bottom: 0.5rem;
    }
    .kyc-hero p {
      position: relative;
      z-index: 2;
      font-size: 0.875rem;
      color: rgba(255, 255, 255, 0.7);
      font-weight: 500;
    }

    /* ===== PROGRESS STEPS ===== */
    .kyc-steps {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      padding: 1.5rem 1.75rem 0.5rem;
    }
    .kyc-step {
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .kyc-step-circle {
      width: 32px;
      height: 32px;
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--font-heading);
      font-size: 0.75rem;
      font-weight: 700;
      flex-shrink: 0;
      transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .kyc-step-circle.active {
      background: linear-gradient(135deg, var(--indigo) 0%, var(--indigo-dark) 100%);
      color: white;
      box-shadow: 0 4px 12px -2px rgba(99, 102, 241, 0.4);
    }
    .kyc-step-circle.pending {
      background: var(--slate-100);
      color: var(--slate-400);
      border: 2px solid var(--slate-200);
    }
    .kyc-step-circle.done {
      background: var(--emerald);
      color: white;
    }
    .kyc-step-line {
      width: 40px;
      height: 2px;
      background: var(--slate-200);
      border-radius: 1px;
      position: relative;
      overflow: hidden;
    }
    .kyc-step-line-fill {
      position: absolute;
      inset: 0;
      background: linear-gradient(90deg, var(--indigo) 0%, var(--cyan) 100%);
      border-radius: 1px;
      width: 0%;
      transition: width 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .kyc-step-label {
      font-size: 0.65rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--slate-400);
      margin-top: 0.25rem;
      text-align: center;
    }

    /* ===== CONTENT ===== */
    .kyc-content {
      padding: 1.5rem 1.75rem 2rem;
    }

    /* ===== LOADING STATE ===== */
    .kyc-loading {
      text-align: center;
      padding: 3rem 1rem;
    }
    .kyc-loading-ring {
      width: 48px;
      height: 48px;
      margin: 0 auto 1.25rem;
      position: relative;
    }
    .kyc-loading-ring::before {
      content: '';
      position: absolute;
      inset: 0;
      border: 3px solid var(--indigo-100);
      border-top-color: var(--indigo);
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
    }
    .kyc-loading-ring::after {
      content: '';
      position: absolute;
      inset: 6px;
      border: 2px solid transparent;
      border-top-color: var(--cyan);
      border-radius: 50%;
      animation: spin 1.2s linear infinite reverse;
    }
    .kyc-loading p {
      font-size: 0.875rem;
      color: var(--slate-500);
      font-weight: 500;
    }
    .kyc-loading-dots::after {
      content: '';
      animation: dots 1.5s steps(4, end) infinite;
    }
    @keyframes dots {
      0% { content: ''; }
      25% { content: '.'; }
      50% { content: '..'; }
      75% { content: '...'; }
      100% { content: ''; }
    }

    /* ===== CLIENT INFO CARD ===== */
    .kyc-client-card {
      display: flex;
      align-items: center;
      gap: 1rem;
      padding: 1rem 1.25rem;
      background: linear-gradient(135deg, var(--indigo-50) 0%, rgba(6, 182, 212, 0.06) 100%);
      border: 1px solid var(--indigo-100);
      border-radius: 18px;
      margin-bottom: 1.5rem;
      transition: all 0.3s ease;
    }
    .kyc-client-card:hover {
      border-color: var(--indigo-200);
      box-shadow: 0 4px 16px -4px rgba(99, 102, 241, 0.1);
    }
    .kyc-client-avatar {
      width: 44px;
      height: 44px;
      border-radius: 14px;
      background: linear-gradient(135deg, var(--indigo) 0%, var(--cyan) 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      font-family: var(--font-heading);
      font-weight: 700;
      font-size: 1rem;
      flex-shrink: 0;
    }
    .kyc-client-avatar svg {
      width: 22px;
      height: 22px;
    }
    .kyc-client-info p {
      font-family: var(--font-heading);
      font-weight: 700;
      font-size: 0.9rem;
      color: var(--slate-800);
      line-height: 1.3;
    }
    .kyc-client-info span {
      font-size: 0.75rem;
      color: var(--slate-400);
      font-weight: 500;
    }

    /* ===== SECTION TITLE ===== */
    .kyc-section-title {
      display: flex;
      align-items: center;
      gap: 0.625rem;
      font-family: var(--font-heading);
      font-size: 0.95rem;
      font-weight: 700;
      color: var(--slate-800);
      margin-bottom: 1rem;
    }
    .kyc-section-title svg {
      width: 20px;
      height: 20px;
      color: var(--indigo);
    }

    /* ===== DECLARACIÓN JURADA ===== */
    .kyc-declaracion {
      background: var(--slate-50);
      border: 1px solid var(--slate-200);
      border-left: 3px solid var(--indigo);
      border-radius: 18px;
      padding: 1.25rem;
      margin-bottom: 1.5rem;
      transition: all 0.3s ease;
    }
    .kyc-declaracion:hover {
      border-color: var(--indigo-200);
      box-shadow: 0 4px 16px -4px rgba(99, 102, 241, 0.08);
    }
    .kyc-declaracion ul {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    .kyc-declaracion li {
      position: relative;
      padding-left: 1.5rem;
      font-size: 0.8rem;
      line-height: 1.6;
      color: var(--slate-600);
      margin-bottom: 0.625rem;
    }
    .kyc-declaracion li::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0.4rem;
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--indigo) 0%, var(--cyan) 100%);
    }
    .kyc-declaracion li:last-child { margin-bottom: 0; }
    .kyc-declaracion a {
      color: var(--indigo);
      font-weight: 600;
      text-decoration: none;
      border-bottom: 1px solid var(--indigo-200);
      transition: all 0.2s ease;
    }
    .kyc-declaracion a:hover {
      color: var(--indigo-dark);
      border-bottom-color: var(--indigo);
    }

    /* ===== SIGNATURE ===== */
    .kyc-signature-wrap {
      margin-bottom: 1.5rem;
    }
    .kyc-signature-label {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.8rem;
      font-weight: 600;
      color: var(--slate-700);
      margin-bottom: 0.625rem;
    }
    .kyc-signature-label svg {
      width: 16px;
      height: 16px;
      color: var(--indigo);
    }
    .kyc-signature-box {
      position: relative;
      border: 2px dashed var(--slate-300);
      border-radius: 16px;
      background: white;
      overflow: hidden;
      transition: all 0.3s ease;
    }
    .kyc-signature-box:hover {
      border-color: var(--indigo-200);
    }
    .kyc-signature-box.drawing {
      border-color: var(--indigo);
      border-style: solid;
      box-shadow: 0 0 0 4px var(--indigo-50);
    }
    .kyc-signature-canvas {
      width: 100%;
      height: auto;
      max-width: 400px;
      display: block;
      touch-action: none;
      cursor: crosshair;
    }
    .kyc-signature-hint {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      pointer-events: none;
      font-size: 0.75rem;
      color: var(--slate-300);
      font-weight: 500;
      letter-spacing: 0.02em;
    }
    .kyc-signature-actions {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.625rem 0.875rem;
      background: var(--slate-50);
      border-top: 1px solid var(--slate-200);
    }
    .kyc-signature-clear {
      display: inline-flex;
      align-items: center;
      gap: 0.375rem;
      padding: 0.375rem 0.75rem;
      background: transparent;
      border: 1px solid var(--slate-200);
      border-radius: 10px;
      font-family: var(--font-body);
      font-size: 0.75rem;
      font-weight: 600;
      color: var(--slate-500);
      cursor: pointer;
      transition: all 0.2s ease;
    }
    .kyc-signature-clear:hover {
      background: var(--rose);
      color: white;
      border-color: var(--rose);
    }
    .kyc-signature-clear svg {
      width: 14px;
      height: 14px;
    }
    .kyc-signature-hint-text {
      font-size: 0.7rem;
      color: var(--slate-400);
      font-weight: 500;
    }

    /* ===== CHECKBOX CUSTOM ===== */
    .kyc-checkbox-wrap {
      display: flex;
      align-items: flex-start;
      gap: 0.75rem;
      padding: 1rem 1.25rem;
      background: white;
      border: 2px solid var(--slate-200);
      border-radius: 16px;
      cursor: pointer;
      transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
      margin-bottom: 1.25rem;
    }
    .kyc-checkbox-wrap:hover {
      border-color: var(--indigo-200);
      box-shadow: 0 4px 16px -4px rgba(99, 102, 241, 0.08);
    }
    .kyc-checkbox-wrap.checked {
      border-color: var(--indigo);
      background: var(--indigo-50);
      box-shadow: 0 4px 16px -4px rgba(99, 102, 241, 0.12);
    }
    .kyc-checkbox {
      appearance: none;
      -webkit-appearance: none;
      width: 22px;
      height: 22px;
      min-width: 22px;
      border: 2px solid var(--slate-300);
      border-radius: 7px;
      margin-top: 1px;
      cursor: pointer;
      transition: all 0.2s ease;
      position: relative;
      background: white;
    }
    .kyc-checkbox:checked {
      background: linear-gradient(135deg, var(--indigo) 0%, var(--indigo-dark) 100%);
      border-color: var(--indigo);
    }
    .kyc-checkbox:checked::after {
      content: '';
      position: absolute;
      left: 6px;
      top: 2px;
      width: 5px;
      height: 10px;
      border: solid white;
      border-width: 0 2px 2px 0;
      transform: rotate(45deg);
    }
    .kyc-checkbox-label {
      font-size: 0.85rem;
      line-height: 1.5;
      color: var(--slate-700);
      font-weight: 500;
      user-select: none;
    }
    .kyc-checkbox-label strong {
      color: var(--slate-900);
      font-weight: 700;
    }

    /* ===== VERIFICATION AREA ===== */
    .kyc-verify-area {
      text-align: center;
      padding: 2rem 1.5rem;
      background: linear-gradient(135deg, var(--indigo-50) 0%, rgba(6, 182, 212, 0.04) 100%);
      border: 2px dashed var(--indigo-200);
      border-radius: 20px;
      margin-bottom: 1.25rem;
      transition: all 0.3s ease;
    }
    .kyc-verify-area:hover {
      border-color: var(--indigo);
      background: linear-gradient(135deg, var(--indigo-50) 0%, rgba(6, 182, 212, 0.08) 100%);
    }
    .kyc-verify-icon {
      width: 64px;
      height: 64px;
      margin: 0 auto 1rem;
      border-radius: 20px;
      background: linear-gradient(135deg, var(--indigo) 0%, var(--indigo-dark) 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 8px 24px -6px rgba(99, 102, 241, 0.35);
      animation: float 4s ease-in-out infinite;
    }
    .kyc-verify-icon svg {
      width: 28px;
      height: 28px;
      color: white;
    }
    .kyc-verify-area h3 {
      font-family: var(--font-heading);
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--slate-800);
      margin-bottom: 0.375rem;
    }
    .kyc-verify-area p {
      font-size: 0.8rem;
      color: var(--slate-500);
      font-weight: 500;
      margin-bottom: 1.25rem;
      max-width: 280px;
      margin-left: auto;
      margin-right: auto;
    }

    /* ===== BUTTONS ===== */
    .kyc-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      width: 100%;
      padding: 0.875rem 1.5rem;
      font-family: var(--font-heading);
      font-size: 0.9rem;
      font-weight: 700;
      border: none;
      border-radius: 14px;
      cursor: pointer;
      transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
      position: relative;
      overflow: hidden;
    }
    .kyc-btn::after {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(circle at center, rgba(255,255,255,0.2) 0%, transparent 70%);
      opacity: 0;
      transition: opacity 0.3s ease;
    }
    .kyc-btn:hover::after { opacity: 1; }
    .kyc-btn-primary {
      background: linear-gradient(135deg, var(--indigo) 0%, var(--indigo-dark) 100%);
      color: white;
      box-shadow: 0 8px 24px -6px rgba(99, 102, 241, 0.4);
    }
    .kyc-btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 12px 32px -6px rgba(99, 102, 241, 0.5);
    }
    .kyc-btn-primary:active {
      transform: translateY(0) scale(0.98);
    }
    .kyc-btn-primary:disabled {
      opacity: 0.6;
      cursor: not-allowed;
      transform: none;
    }
    .kyc-btn-success {
      background: linear-gradient(135deg, var(--emerald) 0%, #059669 100%);
      color: white;
      box-shadow: 0 8px 24px -6px rgba(16, 185, 129, 0.4);
    }
    .kyc-btn-success:hover {
      transform: translateY(-2px);
      box-shadow: 0 12px 32px -6px rgba(16, 185, 129, 0.5);
    }

    /* ===== SECURITY BADGE ===== */
    .kyc-security {
      display: flex;
      align-items: center;
      gap: 0.875rem;
      padding: 1rem 1.25rem;
      background: linear-gradient(135deg, var(--emerald-50) 0%, rgba(6, 182, 212, 0.04) 100%);
      border: 1px solid var(--emerald-100);
      border-radius: 16px;
      margin-bottom: 1.25rem;
      transition: all 0.3s ease;
    }
    .kyc-security:hover {
      border-color: var(--emerald-200);
      box-shadow: 0 4px 16px -4px rgba(16, 185, 129, 0.1);
    }
    .kyc-security-icon {
      width: 40px;
      height: 40px;
      border-radius: 12px;
      background: linear-gradient(135deg, var(--emerald) 0%, var(--cyan) 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      box-shadow: 0 4px 12px -2px rgba(16, 185, 129, 0.3);
    }
    .kyc-security-icon svg {
      width: 20px;
      height: 20px;
      color: white;
    }
    .kyc-security-text p {
      font-family: var(--font-heading);
      font-weight: 700;
      font-size: 0.85rem;
      color: var(--slate-800);
      line-height: 1.3;
    }
    .kyc-security-text span {
      font-size: 0.75rem;
      color: var(--slate-400);
      font-weight: 500;
    }

    /* ===== FOOTER ===== */
    .kyc-footer {
      text-align: center;
      padding: 1.25rem 1.75rem;
      background: var(--slate-50);
      border-top: 1px solid var(--slate-100);
    }
    .kyc-footer p {
      font-size: 0.75rem;
      color: var(--slate-400);
      font-weight: 500;
    }
    .kyc-footer a {
      color: var(--indigo);
      font-weight: 700;
      text-decoration: none;
      transition: color 0.2s ease;
    }
    .kyc-footer a:hover { color: var(--indigo-dark); }
    .kyc-footer-badges {
      display: flex;
      justify-content: center;
      gap: 1rem;
      margin-top: 0.875rem;
    }
    .kyc-footer-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.375rem;
      font-size: 0.65rem;
      font-weight: 700;
      color: var(--slate-400);
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }
    .kyc-footer-badge svg {
      width: 14px;
      height: 14px;
      color: var(--emerald);
    }

    /* ===== EXPIRY NOTE ===== */
    .kyc-expiry {
      text-align: center;
      margin-bottom: 1rem;
    }
    .kyc-expiry p {
      display: inline-flex;
      align-items: center;
      gap: 0.375rem;
      font-size: 0.7rem;
      font-weight: 600;
      color: var(--slate-400);
      padding: 0.375rem 0.875rem;
      background: var(--slate-100);
      border-radius: 9999px;
    }
    .kyc-expiry svg {
      width: 14px;
      height: 14px;
      color: var(--amber);
    }

    /* ===== NO TOKEN STATE ===== */
    .kyc-no-token {
      text-align: center;
      padding: 4rem 1.5rem;
    }
    .kyc-no-token-icon {
      width: 80px;
      height: 80px;
      margin: 0 auto 1.5rem;
      border-radius: 24px;
      background: linear-gradient(135deg, var(--rose) 0%, #fb7185 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 8px 24px -6px rgba(244, 63, 94, 0.35);
      animation: float 4s ease-in-out infinite;
    }
    .kyc-no-token-icon svg {
      width: 36px;
      height: 36px;
      color: white;
    }
    .kyc-no-token h2 {
      font-family: var(--font-heading);
      font-size: 1.25rem;
      font-weight: 800;
      color: var(--slate-800);
      margin-bottom: 0.5rem;
    }
    .kyc-no-token p {
      font-size: 0.85rem;
      color: var(--slate-500);
      font-weight: 500;
      margin-bottom: 1.5rem;
    }

    /* ===== SUCCESS STATE ===== */
    .kyc-success-icon {
      width: 72px;
      height: 72px;
      margin: 0 auto 1.25rem;
      border-radius: 22px;
      background: linear-gradient(135deg, var(--emerald) 0%, #059669 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 8px 24px -6px rgba(16, 185, 129, 0.35);
      animation: float 4s ease-in-out infinite;
    }
    .kyc-success-icon svg {
      width: 32px;
      height: 32px;
      color: white;
    }

    /* ===== HIDDEN ===== */
    .hidden { display: none !important; }

    /* ===== RESPONSIVE ===== */
    @media (max-width: 480px) {
      .kyc-container { padding: 0 0.75rem 2rem; }
      .kyc-card { border-radius: 22px; }
      .kyc-hero { padding: 2rem 1.25rem 1.5rem; }
      .kyc-hero h1 { font-size: 1.25rem; }
      .kyc-content { padding: 1.25rem 1.25rem 1.5rem; }
      .kyc-steps { padding: 1.25rem 1rem 0.5rem; gap: 0.25rem; }
      .kyc-step-line { width: 24px; }
    }

    /* Touch targets */
    @media (pointer: coarse) {
      .kyc-btn, .kyc-signature-clear, .kyc-checkbox-wrap {
        min-height: 44px;
      }
    }
  </style>
</head>
<body>
