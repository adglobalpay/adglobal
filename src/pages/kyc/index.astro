---
// Página estática para verificación KYC - Wizard por pasos
// Colores originales AD Global Pay: blanco, indigo, cyan
const API_URL = import.meta.env.VITE_API_URL || 'https://backend-global-production.up.railway.app';
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes, viewport-fit=cover">
  <title>Verificación de Identidad — AD Global Pay</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="icon" href="/img/logo.webp" type="image/webp" />
  <script is:inline define:vars={{ API_URL }}>
    window.__ADGLOBAL_API_URL__ = API_URL;
  </script>
  <style>
    :root {
      --font-heading: 'Outfit', sans-serif;
      --font-body: 'DM Sans', sans-serif;
      --font-mono: 'JetBrains Mono', monospace;
      --indigo: #6366f1;
      --indigo-light: #818cf8;
      --indigo-dark: #4f46e5;
      --indigo-50: #eef2ff;
      --indigo-100: #e0e7ff;
      --indigo-200: #c7d2fe;
      --cyan: #06b6d4;
      --emerald: #10b981;
      --emerald-50: #ecfdf5;
      --emerald-100: #d1fae5;
      --rose: #f43f5e;
      --slate-50: #f8fafc;
      --slate-100: #f1f5f9;
      --slate-200: #e2e8f0;
      --slate-300: #cbd5e1;
      --slate-400: #94a3b8;
      --slate-500: #64748b;
      --slate-600: #475569;
      --slate-700: #334155;
      --slate-800: #1e293b;
      --slate-900: #0f172a;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    html, body {
      font-family: var(--font-body);
      background: linear-gradient(160deg, var(--slate-50) 0%, #f0f4ff 40%, #e8f4fd 100%);
      min-height: 100vh;
      color: var(--slate-800);
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      overflow-x: hidden;
    }

    /* ===== ANIMATIONS ===== */
    @keyframes fadeInUp {
      from { opacity: 0; transform: translateY(24px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes fadeInScale {
      from { opacity: 0; transform: scale(0.96); }
      to { opacity: 1; transform: scale(1); }
    }
    @keyframes float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-8px); }
    }
    @keyframes spin {
      from { transform: rotate(0deg); }
      to { transform: rotate(360deg); }
    }

    .anim-fade-up {
      animation: fadeInUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      opacity: 0;
    }
    .anim-scale-in {
      animation: fadeInScale 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      opacity: 0;
    }
    .delay-1 { animation-delay: 0.08s; }
    .delay-2 { animation-delay: 0.16s; }
    .delay-3 { animation-delay: 0.24s; }
    .delay-4 { animation-delay: 0.32s; }
    .delay-5 { animation-delay: 0.40s; }

    /* ===== BACKGROUND ===== */
    .bg-decoration {
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 0;
      overflow: hidden;
    }
    .bg-decoration::before {
      content: '';
      position: absolute;
      top: -20%;
      right: -10%;
      width: 600px;
      height: 600px;
      background: radial-gradient(circle, rgba(99, 102, 241, 0.08) 0%, transparent 70%);
      border-radius: 50%;
    }
    .bg-decoration::after {
      content: '';
      position: absolute;
      bottom: -10%;
      left: -5%;
      width: 500px;
      height: 500px;
      background: radial-gradient(circle, rgba(6, 182, 212, 0.06) 0%, transparent 70%);
      border-radius: 50%;
    }

    /* ===== HEADER ===== */
    .kyc-header {
      position: relative;
      z-index: 10;
      padding: 1.5rem;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .kyc-header-inner {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 0.625rem 1.25rem;
      background: rgba(255, 255, 255, 0.7);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid rgba(226, 232, 240, 0.6);
      border-radius: 9999px;
      box-shadow: 0 4px 20px -4px rgba(15, 23, 42, 0.06);
    }
    .kyc-header-logo {
      width: 32px;
      height: 32px;
      border-radius: 0;
      background: transparent;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      overflow: hidden;
    }
    .kyc-header-logo img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      display: block;
    }
    .kyc-header-title {
      font-family: var(--font-heading);
      font-weight: 700;
      font-size: 0.875rem;
      color: var(--slate-800);
      letter-spacing: -0.01em;
    }
    .kyc-header-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.25rem;
      padding: 0.25rem 0.625rem;
      background: var(--emerald-50);
      border: 1px solid var(--emerald-100);
      border-radius: 9999px;
      font-size: 0.7rem;
      font-weight: 700;
      color: var(--emerald);
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    /* ===== MAIN ===== */
    .kyc-container {
      position: relative;
      z-index: 10;
      max-width: 520px;
      margin: 0 auto;
      padding: 0 1rem 3rem;
      min-height: calc(100vh - 80px);
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    /* ===== PROGRESS ===== */
    .kyc-progress {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.75rem;
      margin-bottom: 2rem;
    }
    .kyc-progress-step {
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }
    .kyc-progress-circle {
      width: 36px;
      height: 36px;
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--font-heading);
      font-size: 0.8rem;
      font-weight: 700;
      flex-shrink: 0;
      transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .kyc-progress-circle.active {
      background: linear-gradient(135deg, var(--indigo) 0%, var(--indigo-dark) 100%);
      color: white;
      box-shadow: 0 4px 12px -2px rgba(99, 102, 241, 0.4);
    }
    .kyc-progress-circle.done {
      background: var(--emerald);
      color: white;
    }
    .kyc-progress-circle.pending {
      background: var(--slate-100);
      color: var(--slate-400);
      border: 2px solid var(--slate-200);
    }
    .kyc-progress-line {
      width: 24px;
      height: 2px;
      background: var(--slate-200);
      border-radius: 1px;
      position: relative;
      overflow: hidden;
    }
    .kyc-progress-line-fill {
      position: absolute;
      inset: 0;
      background: linear-gradient(90deg, var(--indigo) 0%, var(--cyan) 100%);
      width: 0%;
      transition: width 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }

    /* ===== STEP CARD ===== */
    .kyc-step-card {
      background: rgba(255, 255, 255, 0.85);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border: 1px solid rgba(226, 232, 240, 0.7);
      border-radius: 28px;
      box-shadow: 0 20px 60px -16px rgba(15, 23, 42, 0.08), 0 0 0 1px rgba(255, 255, 255, 0.5) inset;
      padding: 2rem 1.75rem;
      transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    /* ===== STEP HEADER ===== */
    .kyc-step-label {
      font-family: var(--font-heading);
      font-size: 0.75rem;
      font-weight: 600;
      color: var(--indigo);
      text-transform: uppercase;
      letter-spacing: 0.1em;
      margin-bottom: 0.5rem;
    }
    .kyc-step-title {
      font-family: var(--font-heading);
      font-size: 1.5rem;
      font-weight: 800;
      color: var(--slate-800);
      line-height: 1.2;
      margin-bottom: 0.5rem;
      letter-spacing: -0.02em;
    }
    .kyc-step-desc {
      font-size: 0.875rem;
      color: var(--slate-500);
      font-weight: 500;
      line-height: 1.5;
      margin-bottom: 1.5rem;
    }

    /* ===== CLIENT INFO ===== */
    .kyc-client-chip {
      display: flex;
      align-items: center;
      gap: 1rem;
      padding: 1rem 1.25rem;
      background: linear-gradient(135deg, var(--indigo-50) 0%, rgba(6, 182, 212, 0.06) 100%);
      border: 1px solid var(--indigo-100);
      border-radius: 18px;
      margin-bottom: 1.5rem;
      transition: all 0.3s ease;
    }
    .kyc-client-chip:hover {
      border-color: var(--indigo-200);
      box-shadow: 0 4px 16px -4px rgba(99, 102, 241, 0.1);
    }
    .kyc-client-chip-avatar {
      width: 44px;
      height: 44px;
      border-radius: 14px;
      background: linear-gradient(135deg, var(--indigo) 0%, var(--cyan) 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      flex-shrink: 0;
    }
    .kyc-client-chip-avatar svg { width: 22px; height: 22px; }
    .kyc-client-chip-name {
      font-family: var(--font-heading);
      font-weight: 700;
      font-size: 0.9rem;
      color: var(--slate-800);
      line-height: 1.3;
    }
    .kyc-client-chip-email {
      font-size: 0.75rem;
      color: var(--slate-400);
      font-weight: 500;
    }

    /* ===== DECLARACIÓN ===== */
    .kyc-declaracion {
      background: var(--slate-50);
      border: 1px solid var(--slate-200);
      border-left: 3px solid var(--indigo);
      border-radius: 18px;
      padding: 1.25rem;
      margin-bottom: 1.5rem;
      transition: all 0.3s ease;
    }
    .kyc-declaracion:hover {
      border-color: var(--indigo-200);
      box-shadow: 0 4px 16px -4px rgba(99, 102, 241, 0.08);
    }
    .kyc-declaracion ul { list-style: none; padding: 0; margin: 0; }
    .kyc-declaracion li {
      position: relative;
      padding-left: 1.5rem;
      font-size: 0.8rem;
      line-height: 1.6;
      color: var(--slate-600);
      margin-bottom: 0.625rem;
    }
    .kyc-declaracion li::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0.4rem;
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--indigo) 0%, var(--cyan) 100%);
    }
    .kyc-declaracion li:last-child { margin-bottom: 0; }
    .kyc-declaracion a {
      color: var(--indigo);
      font-weight: 600;
      text-decoration: none;
      border-bottom: 1px solid var(--indigo-200);
      transition: all 0.2s ease;
    }
    .kyc-declaracion a:hover {
      color: var(--indigo-dark);
      border-bottom-color: var(--indigo);
    }

    /* ===== SIGNATURE ===== */
    .kyc-signature-wrap { margin-bottom: 1.5rem; }
    .kyc-signature-label {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.8rem;
      font-weight: 600;
      color: var(--slate-700);
      margin-bottom: 0.625rem;
    }
    .kyc-signature-label svg { width: 16px; height: 16px; color: var(--indigo); }
    .kyc-signature-box {
      position: relative;
      border: 2px dashed var(--slate-300);
      border-radius: 16px;
      background: white;
      overflow: hidden;
      transition: all 0.3s ease;
    }
    .kyc-signature-box:hover { border-color: var(--indigo-200); }
    .kyc-signature-box.drawing {
      border-color: var(--indigo);
      border-style: solid;
      box-shadow: 0 0 0 4px var(--indigo-50);
    }
    .kyc-signature-canvas {
      width: 100%;
      height: auto;
      max-width: 400px;
      display: block;
      touch-action: none;
      cursor: crosshair;
    }
    .kyc-signature-hint {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      pointer-events: none;
      font-size: 0.75rem;
      color: var(--slate-300);
      font-weight: 500;
      letter-spacing: 0.02em;
    }
    .kyc-signature-actions {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.625rem 0.875rem;
      background: var(--slate-50);
      border-top: 1px solid var(--slate-200);
    }
    .kyc-signature-clear {
      display: inline-flex;
      align-items: center;
      gap: 0.375rem;
      padding: 0.375rem 0.75rem;
      background: transparent;
      border: 1px solid var(--slate-200);
      border-radius: 10px;
      font-family: var(--font-body);
      font-size: 0.75rem;
      font-weight: 600;
      color: var(--slate-500);
      cursor: pointer;
      transition: all 0.2s ease;
    }
    .kyc-signature-clear:hover {
      background: var(--rose);
      color: white;
      border-color: var(--rose);
    }
    .kyc-signature-clear svg { width: 14px; height: 14px; }
    .kyc-signature-hint-text {
      font-size: 0.7rem;
      color: var(--slate-400);
      font-weight: 500;
    }

    /* ===== CHECKBOX ===== */
    .kyc-checkbox-wrap {
      display: flex;
      align-items: flex-start;
      gap: 0.75rem;
      padding: 1rem 1.25rem;
      background: white;
      border: 2px solid var(--slate-200);
      border-radius: 16px;
      cursor: pointer;
      transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
      margin-bottom: 1.5rem;
    }
    .kyc-checkbox-wrap:hover {
      border-color: var(--indigo-200);
      box-shadow: 0 4px 16px -4px rgba(99, 102, 241, 0.08);
    }
    .kyc-checkbox-wrap.checked {
      border-color: var(--indigo);
      background: var(--indigo-50);
      box-shadow: 0 4px 16px -4px rgba(99, 102, 241, 0.12);
    }
    .kyc-checkbox {
      appearance: none;
      -webkit-appearance: none;
      width: 22px;
      height: 22px;
      min-width: 22px;
      border: 2px solid var(--slate-300);
      border-radius: 7px;
      margin-top: 1px;
      cursor: pointer;
      transition: all 0.2s ease;
      position: relative;
      background: white;
    }
    .kyc-checkbox:checked {
      background: linear-gradient(135deg, var(--indigo) 0%, var(--indigo-dark) 100%);
      border-color: var(--indigo);
    }
    .kyc-checkbox:checked::after {
      content: '';
      position: absolute;
      left: 6px;
      top: 2px;
      width: 5px;
      height: 10px;
      border: solid white;
      border-width: 0 2px 2px 0;
      transform: rotate(45deg);
    }
    .kyc-checkbox-label {
      font-size: 0.85rem;
      line-height: 1.5;
      color: var(--slate-700);
      font-weight: 500;
      user-select: none;
    }
    .kyc-checkbox-label strong {
      color: var(--slate-900);
      font-weight: 700;
    }

    /* ===== UPLOAD AREA ===== */
    .kyc-upload-area {
      position: relative;
      text-align: center;
      padding: 2rem 1.5rem;
      background: linear-gradient(135deg, var(--indigo-50) 0%, rgba(6, 182, 212, 0.04) 100%);
      border: 2px dashed var(--indigo-200);
      border-radius: 20px;
      margin-bottom: 1.25rem;
      transition: all 0.3s ease;
      cursor: pointer;
    }
    .kyc-upload-area:hover {
      border-color: var(--indigo);
      background: linear-gradient(135deg, var(--indigo-50) 0%, rgba(6, 182, 212, 0.08) 100%);
    }
    .kyc-upload-area.has-file {
      border-style: solid;
      border-color: var(--emerald);
      background: var(--emerald-50);
    }
    .kyc-upload-icon-main {
      width: 64px;
      height: 64px;
      margin: 0 auto 1rem;
      border-radius: 20px;
      background: linear-gradient(135deg, var(--indigo) 0%, var(--indigo-dark) 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 8px 24px -6px rgba(99, 102, 241, 0.35);
      animation: float 4s ease-in-out infinite;
    }
    .kyc-upload-icon-main svg {
      width: 28px;
      height: 28px;
      color: white;
    }
    .kyc-upload-area h3 {
      font-family: var(--font-heading);
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--slate-800);
      margin-bottom: 0.375rem;
    }
    .kyc-upload-area p {
      font-size: 0.8rem;
      color: var(--slate-500);
      font-weight: 500;
      margin-bottom: 1.25rem;
    }
    .kyc-upload-preview-img {
      width: 100%;
      max-height: 200px;
      object-fit: contain;
      border-radius: 12px;
      margin-bottom: 0.75rem;
    }
    .kyc-upload-file-name {
      font-size: 0.78rem;
      color: var(--emerald);
      font-weight: 700;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.375rem;
    }

    /* ===== BUTTONS ===== */
    .kyc-btn-group {
      display: flex;
      gap: 0.75rem;
      margin-top: 0.5rem;
    }
    .kyc-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      width: 100%;
      padding: 0.875rem 1.5rem;
      font-family: var(--font-heading);
      font-size: 0.9rem;
      font-weight: 700;
      border: none;
      border-radius: 14px;
      cursor: pointer;
      transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
      position: relative;
      overflow: hidden;
    }
    .kyc-btn::after {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(circle at center, rgba(255,255,255,0.2) 0%, transparent 70%);
      opacity: 0;
      transition: opacity 0.3s ease;
    }
    .kyc-btn:hover::after { opacity: 1; }
    .kyc-btn-secondary {
      background: white;
      color: var(--slate-600);
      border: 2px solid var(--slate-200);
    }
    .kyc-btn-secondary:hover {
      border-color: var(--indigo-200);
      color: var(--slate-800);
      background: var(--slate-50);
    }
    .kyc-btn-primary {
      background: linear-gradient(135deg, var(--indigo) 0%, var(--indigo-dark) 100%);
      color: white;
      box-shadow: 0 8px 24px -6px rgba(99, 102, 241, 0.4);
    }
    .kyc-btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 12px 32px -6px rgba(99, 102, 241, 0.5);
    }
    .kyc-btn-primary:active { transform: translateY(0) scale(0.98); }
    .kyc-btn-primary:disabled {
      opacity: 0.6;
      cursor: not-allowed;
      transform: none;
    }
    .kyc-btn-success {
      background: linear-gradient(135deg, var(--emerald) 0%, #059669 100%);
      color: white;
      box-shadow: 0 8px 24px -6px rgba(16, 185, 129, 0.4);
    }
    .kyc-btn-success:hover {
      transform: translateY(-2px);
      box-shadow: 0 12px 32px -6px rgba(16, 185, 129, 0.5);
    }

    /* ===== REVIEW STEP ===== */
    .kyc-review-grid {
      display: grid;
      gap: 0.75rem;
      margin-bottom: 1.5rem;
    }
    .kyc-review-item {
      display: flex;
      align-items: center;
      gap: 1rem;
      padding: 0.875rem 1rem;
      background: white;
      border: 1.5px dashed var(--slate-200);
      border-radius: 16px;
      transition: all 0.3s ease;
    }
    .kyc-review-item:hover { border-color: var(--indigo-200); }
    .kyc-review-item.done {
      border-style: solid;
      border-color: var(--emerald-100);
      background: linear-gradient(135deg, white 0%, var(--emerald-50) 100%);
    }
    .kyc-review-item-icon {
      width: 40px;
      height: 40px;
      border-radius: 12px;
      background: var(--indigo-50);
      color: var(--indigo);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }
    .kyc-review-item-icon svg { width: 20px; height: 20px; }
    .kyc-review-item-icon.done {
      background: var(--emerald);
      color: white;
    }
    .kyc-review-item-text strong {
      display: block;
      font-family: var(--font-heading);
      font-size: 0.9rem;
      font-weight: 700;
      color: var(--slate-800);
    }
    .kyc-review-item-text span {
      font-size: 0.75rem;
      color: var(--slate-500);
      font-weight: 500;
    }

    /* ===== ALERT ===== */
    .kyc-alert {
      padding: 0.875rem 1rem;
      background: #fff7ed;
      border: 1px solid #fed7aa;
      color: #c2410c;
      border-radius: 14px;
      font-size: 0.78rem;
      font-weight: 700;
      line-height: 1.4;
      margin-bottom: 1rem;
    }

    /* ===== SECURITY ===== */
    .kyc-security {
      display: flex;
      align-items: center;
      gap: 0.875rem;
      padding: 1rem 1.25rem;
      background: linear-gradient(135deg, var(--emerald-50) 0%, rgba(6, 182, 212, 0.04) 100%);
      border: 1px solid var(--emerald-100);
      border-radius: 16px;
      margin-bottom: 1.25rem;
      transition: all 0.3s ease;
    }
    .kyc-security:hover {
      border-color: var(--emerald-200);
      box-shadow: 0 4px 16px -4px rgba(16, 185, 129, 0.1);
    }
    .kyc-security-icon {
      width: 40px;
      height: 40px;
      border-radius: 12px;
      background: linear-gradient(135deg, var(--emerald) 0%, var(--cyan) 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      box-shadow: 0 4px 12px -2px rgba(16, 185, 129, 0.3);
    }
    .kyc-security-icon svg { width: 20px; height: 20px; color: white; }
    .kyc-security-text p {
      font-family: var(--font-heading);
      font-weight: 700;
      font-size: 0.85rem;
      color: var(--slate-800);
      line-height: 1.3;
    }
    .kyc-security-text span {
      font-size: 0.75rem;
      color: var(--slate-400);
      font-weight: 500;
    }

    /* ===== LOADING ===== */
    .kyc-loading {
      text-align: center;
      padding: 3rem 1rem;
    }
    .kyc-loading-ring {
      width: 48px;
      height: 48px;
      margin: 0 auto 1.25rem;
      position: relative;
    }
    .kyc-loading-ring::before {
      content: '';
      position: absolute;
      inset: 0;
      border: 3px solid var(--indigo-100);
      border-top-color: var(--indigo);
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
    }
    .kyc-loading p {
      font-size: 0.875rem;
      color: var(--slate-500);
      font-weight: 500;
    }

    /* ===== NO TOKEN ===== */
    .kyc-no-token {
      text-align: center;
      padding: 4rem 1.5rem;
    }
    .kyc-no-token-icon {
      width: 80px;
      height: 80px;
      margin: 0 auto 1.5rem;
      border-radius: 24px;
      background: linear-gradient(135deg, var(--rose) 0%, #fb7185 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 8px 24px -6px rgba(244, 63, 94, 0.35);
      animation: float 4s ease-in-out infinite;
    }
    .kyc-no-token-icon svg { width: 36px; height: 36px; color: white; }
    .kyc-no-token h2 {
      font-family: var(--font-heading);
      font-size: 1.25rem;
      font-weight: 800;
      color: var(--slate-800);
      margin-bottom: 0.5rem;
    }
    .kyc-no-token p {
      font-size: 0.85rem;
      color: var(--slate-500);
      font-weight: 500;
      margin-bottom: 1.5rem;
    }

    /* ===== SUCCESS ===== */
    .kyc-success-icon {
      width: 72px;
      height: 72px;
      margin: 0 auto 1.25rem;
      border-radius: 22px;
      background: linear-gradient(135deg, var(--emerald) 0%, #059669 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 8px 24px -6px rgba(16, 185, 129, 0.35);
      animation: float 4s ease-in-out infinite;
    }
    .kyc-success-icon svg { width: 32px; height: 32px; color: white; }

    /* ===== HIDDEN ===== */
    .hidden { display: none !important; }

    /* ===== RESPONSIVE ===== */
    @media (max-width: 480px) {
      .kyc-container { padding: 0 0.75rem 2rem; }
      .kyc-step-card { padding: 1.5rem 1.25rem; border-radius: 22px; }
      .kyc-step-title { font-size: 1.25rem; }
      .kyc-progress { gap: 0.5rem; }
      .kyc-progress-line { width: 16px; }
      .kyc-btn-group { flex-direction: column; }
    }

    @media (pointer: coarse) {
      .kyc-btn, .kyc-signature-clear, .kyc-checkbox-wrap, .kyc-upload-area {
        min-height: 48px;
      }
    }
  </style>
</head>
<body>
  <div class="bg-decoration"></div>

  <header class="kyc-header anim-fade-up">
    <div class="kyc-header-inner">
      <div class="kyc-header-logo"><img src="/img/logo.webp" alt="AD Global Pay" /></div>
      <span class="kyc-header-title">AD Global Pay</span>
      <span class="kyc-header-badge">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        Seguro
      </span>
    </div>
  </header>

  <main class="kyc-container">
    <div id="noTokenState" class="kyc-step-card hidden anim-scale-in">
      <div class="kyc-no-token">
        <div class="kyc-no-token-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        </div>
        <h2>Link inválido</h2>
        <p>El enlace de verificación no es válido o ha expirado.<br>Solicita uno nuevo desde tu cuenta.</p>
        <a href="/" class="kyc-btn kyc-btn-primary" style="width:auto; display:inline-flex; padding-left:2rem; padding-right:2rem;">Volver al inicio</a>
      </div>
    </div>

    <div id="kycContent" class="hidden">
      <div id="loadingState" class="kyc-loading">
        <div class="kyc-loading-ring"></div>
        <p class="kyc-loading-dots">Cargando verificador</p>
      </div>

      <div id="progressBar" class="kyc-progress hidden">
        <div class="kyc-progress-step">
          <div class="kyc-progress-circle active" id="prog1">1</div>
        </div>
        <div class="kyc-progress-line"><div class="kyc-progress-line-fill" id="progLine1"></div></div>
        <div class="kyc-progress-step">
          <div class="kyc-progress-circle pending" id="prog2">2</div>
        </div>
        <div class="kyc-progress-line"><div class="kyc-progress-line-fill" id="progLine2"></div></div>
        <div class="kyc-progress-step">
          <div class="kyc-progress-circle pending" id="prog3">3</div>
        </div>
        <div class="kyc-progress-line"><div class="kyc-progress-line-fill" id="progLine3"></div></div>
        <div class="kyc-progress-step">
          <div class="kyc-progress-circle pending" id="prog4">4</div>
        </div>
      </div>

      <!-- Step 1: Firma -->
      <div id="step1" class="kyc-step-card anim-scale-in delay-1">
        <div class="kyc-step-label">Paso 1 de 4</div>
        <h1 class="kyc-step-title">Declara y firma</h1>
        <p class="kyc-step-desc">Lee la declaración jurada, acepta los términos y firma digitalmente.</p>

        <div class="kyc-client-chip anim-fade-up delay-2">
          <div class="kyc-client-chip-avatar">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          </div>
          <div>
            <div class="kyc-client-chip-name" id="clientName">Cliente AD Global Pay</div>
            <div class="kyc-client-chip-email" id="clientEmail">Solicitud de verificación</div>
          </div>
        </div>

        <div class="kyc-declaracion anim-fade-up delay-3">
          <ul>
            <li>Los fondos que enviaré a través de AD Global Pay provienen de <strong>actividades lícitas y verificables</strong>.</li>
            <li>No estoy involucrado en actividades de lavado de activos, financiamiento del terrorismo, ni operaciones con personas o entidades sancionadas por OFAC.</li>
            <li>Toda la información proporcionada es <strong>veraz, completa y actualizada</strong>.</li>
            <li>Acepto los <a href="https://www.adglobalpay.com/pdf/terminos.pdf" target="_blank" rel="noopener noreferrer">Términos y Condiciones</a> y la <a href="https://www.adglobalpay.com/pdf/privacidad.pdf" target="_blank" rel="noopener noreferrer">Política de Privacidad</a> de AD Global Services LLC.</li>
          </ul>
        </div>

        <div class="kyc-signature-wrap anim-fade-up delay-4">
          <div class="kyc-signature-label">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
            Firma digital
          </div>
          <div class="kyc-signature-box" id="signatureBox">
            <canvas id="signatureCanvas" width="400" height="150" style="width:100%; height:auto; max-width:400px; touch-action: none; cursor: crosshair;" class="kyc-signature-canvas"></canvas>
            <div class="kyc-signature-hint" id="signatureHint">Toque o deslice para firmar</div>
          </div>
          <div class="kyc-signature-actions">
            <button type="button" id="clearSignature" class="kyc-signature-clear">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
              Limpiar
            </button>
            <span class="kyc-signature-hint-text">Dedo o mouse</span>
          </div>
        </div>

        <label class="kyc-checkbox-wrap anim-fade-up delay-5" id="checkboxWrap">
          <input type="checkbox" id="aceptoTerminos" class="kyc-checkbox">
          <span class="kyc-checkbox-label">He leído y acepto la <strong>Declaración Jurada</strong>, los <strong>Términos y Condiciones</strong> y la <strong>Política de Privacidad</strong> de AD Global Services LLC.</span>
        </label>

        <div id="step1Error" class="kyc-alert hidden"></div>

        <div class="kyc-btn-group">
          <div style="flex:1"></div>
          <button id="btnStep1Next" class="kyc-btn kyc-btn-primary">
            Continuar
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
          </button>
        </div>
      </div>

      <!-- Step 2: Selfie -->
      <div id="step2" class="kyc-step-card hidden">
        <div class="kyc-step-label">Paso 2 de 4</div>
        <h1 class="kyc-step-title">Foto de tu cara</h1>
        <p class="kyc-step-desc">Selfie frontal, con buena luz, sin lentes oscuros ni filtros.</p>

        <div class="kyc-upload-area" id="selfieUploadArea" onclick="document.getElementById('selfieInput').click()">
          <input id="selfieInput" type="file" accept="image/*" capture="user" class="hidden" onchange="handleSelfie(this)">
          <div class="kyc-upload-icon-main" id="selfieIcon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
          </div>
          <h3>Toca para tomar selfie</h3>
          <p>Usa la cámara frontal o selecciona una foto</p>
          <img id="selfiePreviewImg" class="kyc-upload-preview-img hidden" alt="Selfie preview" />
          <div id="selfieFileName" class="kyc-upload-file-name hidden"></div>
        </div>

        <div id="step2Error" class="kyc-alert hidden"></div>

        <div class="kyc-btn-group">
          <button class="kyc-btn kyc-btn-secondary" onclick="goToStep(1)">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
            Atrás
          </button>
          <button id="btnStep2Next" class="kyc-btn kyc-btn-primary" disabled>
            Continuar
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
          </button>
        </div>
      </div>

      <!-- Step 3: Cédula -->
      <div id="step3" class="kyc-step-card hidden">
        <div class="kyc-step-label">Paso 3 de 4</div>
        <h1 class="kyc-step-title">Foto de tu cédula</h1>
        <p class="kyc-step-desc">Documento completo, enfocado, sin reflejos y bien iluminado.</p>

        <div class="kyc-upload-area" id="idUploadArea" onclick="document.getElementById('idFrontInput').click()">
          <input id="idFrontInput" type="file" accept="image/*" capture="environment" class="hidden" onchange="handleIdFront(this)">
          <div class="kyc-upload-icon-main" id="idIcon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="5" rx="2"/><circle cx="8" cy="12" r="2"/><path d="M14 10h4"/><path d="M14 14h4"/></svg>
          </div>
          <h3>Toca para fotografiar cédula</h3>
          <p>Asegúrate que todos los datos sean legibles</p>
          <img id="idPreviewImg" class="kyc-upload-preview-img hidden" alt="ID preview" />
          <div id="idFileName" class="kyc-upload-file-name hidden"></div>
        </div>

        <div id="step3Error" class="kyc-alert hidden"></div>

        <div class="kyc-btn-group">
          <button class="kyc-btn kyc-btn-secondary" onclick="goToStep(2)">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
            Atrás
          </button>
          <button id="btnStep3Next" class="kyc-btn kyc-btn-primary" disabled>
            Continuar
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
          </button>
        </div>
      </div>

      <!-- Step 4: Review & Submit -->
      <div id="step4" class="kyc-step-card hidden">
        <div class="kyc-step-label">Paso 4 de 4</div>
        <h1 class="kyc-step-title">Revisa y envía</h1>
        <p class="kyc-step-desc">Verifica que toda la información esté correcta antes de enviar.</p>

        <div class="kyc-review-grid">
          <div class="kyc-review-item done">
            <div class="kyc-review-item-icon done">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <div class="kyc-review-item-text">
              <strong>Declaración jurada firmada</strong>
              <span>Firma digital registrada</span>
            </div>
          </div>
          <div class="kyc-review-item" id="reviewSelfieItem">
            <div class="kyc-review-item-icon" id="reviewSelfieIcon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
            </div>
            <div class="kyc-review-item-text">
              <strong>Foto de rostro</strong>
              <span id="reviewSelfieStatus">Pendiente</span>
            </div>
          </div>
          <div class="kyc-review-item" id="reviewIdItem">
            <div class="kyc-review-item-icon" id="reviewIdIcon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="5" rx="2"/><circle cx="8" cy="12" r="2"/><path d="M14 10h4"/><path d="M14 14h4"/></svg>
            </div>
            <div class="kyc-review-item-text">
              <strong>Foto de cédula</strong>
              <span id="reviewIdStatus">Pendiente</span>
            </div>
          </div>
        </div>

        <div class="kyc-security">
          <div class="kyc-security-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <div class="kyc-security-text">
            <p>Tu información está segura</p>
            <span>La revisión la realiza manualmente el equipo de AD Global Pay</span>
          </div>
        </div>

        <div id="step4Error" class="kyc-alert hidden"></div>

        <div class="kyc-btn-group">
          <button class="kyc-btn kyc-btn-secondary" onclick="goToStep(3)">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
            Atrás
          </button>
          <button id="btnSubmit" class="kyc-btn kyc-btn-primary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            Enviar para revisión
          </button>
        </div>
      </div>
    </div>
  </main>

  <script is:inline>
    (function() {
      var params = new URLSearchParams(window.location.search);
      var token = params.get('token');
      var API_URL = window.__ADGLOBAL_API_URL__ || 'https://backend-global-production.up.railway.app';

      var noTokenEl = document.getElementById('noTokenState');
      var kycContentEl = document.getElementById('kycContent');
      var loadingEl = document.getElementById('loadingState');
      var progressBar = document.getElementById('progressBar');

      if (!token) {
        if (noTokenEl) noTokenEl.classList.remove('hidden');
        return;
      }

      if (kycContentEl) kycContentEl.classList.remove('hidden');

      var currentStep = 1;
      var signatureIsEmpty = true;
      var signatureData = '';
      var selfieData = '';
      var idFrontData = '';
      var canvas = null;
      var ctx = null;

      function setInvalidState(message) {
        if (kycContentEl) kycContentEl.classList.add('hidden');
        if (noTokenEl) {
          var paragraph = noTokenEl.querySelector('p');
          if (paragraph) paragraph.innerHTML = message || 'El enlace de verificación no es válido o ha expirado. Solicita uno nuevo desde tu cuenta.';
          noTokenEl.classList.remove('hidden');
        }
      }

      function updateProgress(step) {
        for (var i = 1; i <= 4; i++) {
          var circle = document.getElementById('prog' + i);
          var line = document.getElementById('progLine' + i);
          if (!circle) continue;
          if (i < step) {
            circle.className = 'kyc-progress-circle done';
            circle.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
          } else if (i === step) {
            circle.className = 'kyc-progress-circle active';
            circle.textContent = i;
          } else {
            circle.className = 'kyc-progress-circle pending';
            circle.textContent = i;
          }
          if (line) line.style.width = i < step ? '100%' : '0%';
        }
      }

      function goToStep(step) {
        for (var i = 1; i <= 4; i++) {
          var el = document.getElementById('step' + i);
          if (el) el.classList.add('hidden');
        }
        var target = document.getElementById('step' + step);
        if (target) {
          target.classList.remove('hidden');
          target.classList.add('anim-scale-in');
          setTimeout(function() { target.classList.remove('anim-scale-in'); }, 500);
        }
        currentStep = step;
        updateProgress(step);
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }

      function showStepError(stepId, message) {
        var el = document.getElementById(stepId);
        if (!el) return;
        el.textContent = message;
        el.classList.remove('hidden');
      }
      function hideStepError(stepId) {
        var el = document.getElementById(stepId);
        if (!el) return;
        el.classList.add('hidden');
      }

      function showExistingStatus(status) {
        var area = document.getElementById('kycContent');
        if (!area) return;
        var approved = status === 'VERIFIED';
        area.innerHTML =
          '<div class="kyc-step-card anim-scale-in" style="text-align:center; padding: 3rem 1.5rem;">' +
            '<div class="kyc-success-icon">' +
              '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>' +
            '</div>' +
            '<h1 style="font-family:var(--font-heading); font-size:1.5rem; font-weight:800; color:var(--slate-800); margin-bottom:0.5rem;">' + (approved ? 'Identidad verificada' : 'Verificación enviada') + '</h1>' +
            '<p style="font-size:0.9rem; color:var(--slate-500); margin-bottom:2rem; line-height:1.6;">' + (approved ? 'Tu identidad ya fue aprobada por AD Global Pay.' : 'Recibimos tus datos. El equipo revisará tu firma, selfie y cédula manualmente.') + '</p>' +
            '<a href="/kyc/completado?status=' + encodeURIComponent(status) + '" class="kyc-btn kyc-btn-success" style="width:auto; display:inline-flex; padding-left:2rem; padding-right:2rem;">Continuar</a>' +
          '</div>';
      }

      function loadKyc() {
        fetch(API_URL + '/api/kyc/public/' + encodeURIComponent(token))
          .then(function(res) {
            return res.json().then(function(data) {
              if (!res.ok) throw new Error(data && data.error ? data.error : 'No se pudo cargar la solicitud KYC');
              return data;
            });
          })
          .then(function(data) {
            var fullName = [data.client && data.client.firstName, data.client && data.client.lastName].filter(Boolean).join(' ');
            var clientName = document.getElementById('clientName');
            var clientEmail = document.getElementById('clientEmail');
            if (clientName) clientName.textContent = fullName || 'Cliente AD Global Pay';
            if (clientEmail) clientEmail.textContent = (data.client && data.client.email) || 'Solicitud de verificación';
            if (loadingEl) loadingEl.classList.add('hidden');
            if (progressBar) progressBar.classList.remove('hidden');
            if (data.status === 'PROCESSING' || data.status === 'VERIFIED') {
              showExistingStatus(data.status);
            } else {
              goToStep(1);
            }
          })
          .catch(function(err) {
            setInvalidState(err.message);
          });
      }

      // ===================== SIGNATURE =====================
      function initSignatureCanvas() {
        canvas = document.getElementById('signatureCanvas');
        if (!canvas) return;
        ctx = canvas.getContext('2d');
        ctx.strokeStyle = '#1e293b';
        ctx.lineWidth = 2.5;
        ctx.lineCap = 'round';
        ctx.lineJoin = 'round';

        var drawing = false;
        var lastX = 0, lastY = 0;

        function getCoordinates(e) {
          var rect = canvas.getBoundingClientRect();
          var scaleX = canvas.width / rect.width;
          var scaleY = canvas.height / rect.height;
          var clientX, clientY;
          if (e.touches && e.touches.length > 0) {
            clientX = e.touches[0].clientX;
            clientY = e.touches[0].clientY;
          } else {
            clientX = e.clientX;
            clientY = e.clientY;
          }
          var x = (clientX - rect.left) * scaleX;
          var y = (clientY - rect.top) * scaleY;
          return { x: Math.max(0, Math.min(x, canvas.width)), y: Math.max(0, Math.min(y, canvas.height)) };
        }

        function startDrawing(e) {
          e.preventDefault();
          drawing = true;
          var coords = getCoordinates(e);
          lastX = coords.x;
          lastY = coords.y;
          ctx.beginPath();
          ctx.moveTo(lastX, lastY);
          ctx.lineTo(lastX, lastY);
          ctx.stroke();
          signatureIsEmpty = false;
          document.getElementById('signatureBox').classList.add('drawing');
          document.getElementById('signatureHint').style.opacity = '0';
        }
        function draw(e) {
          e.preventDefault();
          if (!drawing) return;
          var coords = getCoordinates(e);
          ctx.beginPath();
          ctx.moveTo(lastX, lastY);
          ctx.lineTo(coords.x, coords.y);
          ctx.stroke();
          lastX = coords.x;
          lastY = coords.y;
        }
        function stopDrawing(e) {
          if (e) e.preventDefault();
          drawing = false;
        }

        canvas.addEventListener('mousedown', startDrawing);
        canvas.addEventListener('mousemove', draw);
        canvas.addEventListener('mouseup', stopDrawing);
        canvas.addEventListener('mouseleave', stopDrawing);
        canvas.addEventListener('touchstart', startDrawing, { passive: false });
        canvas.addEventListener('touchmove', draw, { passive: false });
        canvas.addEventListener('touchend', stopDrawing, { passive: false });
        canvas.addEventListener('touchcancel', stopDrawing, { passive: false });

        var clearBtn = document.getElementById('clearSignature');
        if (clearBtn) {
          clearBtn.addEventListener('click', function() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            ctx.fillStyle = 'white';
            ctx.fillRect(0, 0, canvas.width, canvas.height);
            ctx.strokeStyle = '#1e293b';
            signatureIsEmpty = true;
            document.getElementById('signatureBox').classList.remove('drawing');
            document.getElementById('signatureHint').style.opacity = '1';
          });
        }

        ctx.fillStyle = 'white';
        ctx.fillRect(0, 0, canvas.width, canvas.height);
        ctx.strokeStyle = '#1e293b';
      }

      // Checkbox
      var checkbox = document.getElementById('aceptoTerminos');
      var checkboxWrap = document.getElementById('checkboxWrap');
      if (checkbox && checkboxWrap) {
        checkbox.addEventListener('change', function() {
          checkboxWrap.classList.toggle('checked', this.checked);
        });
      }

      // Step 1 next
      var btnStep1 = document.getElementById('btnStep1Next');
      if (btnStep1) {
        btnStep1.addEventListener('click', function() {
          var acepta = document.getElementById('aceptoTerminos');
          hideStepError('step1Error');
          if (!acepta || !acepta.checked) {
            showStepError('step1Error', 'Debes aceptar los términos y condiciones para continuar.');
            return;
          }
          if (signatureIsEmpty) {
            showStepError('step1Error', 'Debes firmar la declaración jurada para continuar.');
            return;
          }
          signatureData = canvas.toDataURL('image/png');
          goToStep(2);
        });
      }

      // ===================== IMAGE COMPRESSION =====================
      function compressImage(file) {
        return new Promise(function(resolve, reject) {
          if (!file || !file.type || !file.type.startsWith('image/')) {
            reject(new Error('Solo se aceptan imagenes'));
            return;
          }
          var reader = new FileReader();
          reader.onload = function() {
            var img = new Image();
            img.onload = function() {
              var maxSize = 1280;
              var width = img.width;
              var height = img.height;
              if (width > height && width > maxSize) {
                height = Math.round((height * maxSize) / width);
                width = maxSize;
              } else if (height > maxSize) {
                width = Math.round((width * maxSize) / height);
                height = maxSize;
              }
              var out = document.createElement('canvas');
              out.width = width;
              out.height = height;
              var outCtx = out.getContext('2d');
              outCtx.fillStyle = '#fff';
              outCtx.fillRect(0, 0, width, height);
              outCtx.drawImage(img, 0, 0, width, height);
              resolve(out.toDataURL('image/jpeg', 0.84));
            };
            img.onerror = function() { reject(new Error('No se pudo leer la imagen')); };
            img.src = reader.result;
          };
          reader.onerror = function() { reject(new Error('No se pudo leer el archivo')); };
          reader.readAsDataURL(file);
        });
      }

      // ===================== SELFIE =====================
      window.handleSelfie = function(input) {
        hideStepError('step2Error');
        if (!input.files || !input.files[0]) return;
        var file = input.files[0];
        var area = document.getElementById('selfieUploadArea');
        var icon = document.getElementById('selfieIcon');
        var preview = document.getElementById('selfiePreviewImg');
        var fileName = document.getElementById('selfieFileName');
        var btn = document.getElementById('btnStep2Next');

        compressImage(file)
          .then(function(dataUrl) {
            selfieData = dataUrl;
            if (area) area.classList.add('has-file');
            if (icon) icon.classList.add('hidden');
            if (preview) { preview.src = dataUrl; preview.classList.remove('hidden'); }
            if (fileName) { fileName.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> ' + (file.name.length > 25 ? file.name.substring(0, 22) + '...' : file.name); fileName.classList.remove('hidden'); }
            if (btn) btn.disabled = false;
          })
          .catch(function(err) {
            showStepError('step2Error', err.message);
          });
      };

      var btnStep2 = document.getElementById('btnStep2Next');
      if (btnStep2) {
        btnStep2.addEventListener('click', function() {
          if (!selfieData) {
            showStepError('step2Error', 'Debes subir una foto de tu cara.');
            return;
          }
          hideStepError('step2Error');
          goToStep(3);
        });
      }

      // ===================== ID FRONT =====================
      window.handleIdFront = function(input) {
        hideStepError('step3Error');
        if (!input.files || !input.files[0]) return;
        var file = input.files[0];
        var area = document.getElementById('idUploadArea');
        var icon = document.getElementById('idIcon');
        var preview = document.getElementById('idPreviewImg');
        var fileName = document.getElementById('idFileName');
        var btn = document.getElementById('btnStep3Next');

        compressImage(file)
          .then(function(dataUrl) {
            idFrontData = dataUrl;
            if (area) area.classList.add('has-file');
            if (icon) icon.classList.add('hidden');
            if (preview) { preview.src = dataUrl; preview.classList.remove('hidden'); }
            if (fileName) { fileName.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> ' + (file.name.length > 25 ? file.name.substring(0, 22) + '...' : file.name); fileName.classList.remove('hidden'); }
            if (btn) btn.disabled = false;
          })
          .catch(function(err) {
            showStepError('step3Error', err.message);
          });
      };

      var btnStep3 = document.getElementById('btnStep3Next');
      if (btnStep3) {
        btnStep3.addEventListener('click', function() {
          if (!idFrontData) {
            showStepError('step3Error', 'Debes subir una foto de tu cédula.');
            return;
          }
          hideStepError('step3Error');
          var reviewSelfieStatus = document.getElementById('reviewSelfieStatus');
          var reviewIdStatus = document.getElementById('reviewIdStatus');
          var reviewSelfieItem = document.getElementById('reviewSelfieItem');
          var reviewIdItem = document.getElementById('reviewIdItem');
          var reviewSelfieIcon = document.getElementById('reviewSelfieIcon');
          var reviewIdIcon = document.getElementById('reviewIdIcon');
          if (reviewSelfieStatus) reviewSelfieStatus.textContent = 'Listo';
          if (reviewIdStatus) reviewIdStatus.textContent = 'Listo';
          if (reviewSelfieItem) { reviewSelfieItem.classList.add('done'); }
          if (reviewIdItem) { reviewIdItem.classList.add('done'); }
          if (reviewSelfieIcon) {
            reviewSelfieIcon.classList.add('done');
            reviewSelfieIcon.innerHTML = '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
          }
          if (reviewIdIcon) {
            reviewIdIcon.classList.add('done');
            reviewIdIcon.innerHTML = '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
          }
          goToStep(4);
        });
      }

      // ===================== SUBMIT =====================
      var btnSubmit = document.getElementById('btnSubmit');
      if (btnSubmit) {
        btnSubmit.addEventListener('click', function() {
          if (!selfieData || !idFrontData || !signatureData) {
            showStepError('step4Error', 'Faltan datos. Por favor completa todos los pasos.');
            return;
          }
          hideStepError('step4Error');
          btnSubmit.disabled = true;
          btnSubmit.innerHTML = '<div style="width:20px;height:20px;border:2px solid white;border-top-color:transparent;border-radius:50%;animation:spin 1s linear infinite;margin:0 auto;"></div>';

          fetch(API_URL + '/api/kyc/public/' + encodeURIComponent(token) + '/submit', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              acceptedTerms: true,
              signature: signatureData,
              selfie: selfieData,
              idFront: idFrontData
            })
          })
            .then(function(res) {
              return res.json().then(function(data) {
                if (!res.ok) throw new Error(data && data.error ? data.error : 'No se pudo enviar la verificacion');
                return data;
              });
            })
            .then(function() {
              var area = document.getElementById('kycContent');
              if (area) {
                area.innerHTML =
                  '<div class="kyc-step-card anim-scale-in" style="text-align:center; padding: 3rem 1.5rem;">' +
                    '<div class="kyc-success-icon">' +
                      '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>' +
                    '</div>' +
                    '<h1 style="font-family:var(--font-heading); font-size:1.5rem; font-weight:800; color:var(--slate-800); margin-bottom:0.5rem;">¡Verificación enviada!</h1>' +
                    '<p style="font-size:0.9rem; color:var(--slate-500); margin-bottom:2rem; line-height:1.6;">Recibimos tu firma, selfie y cédula. El equipo de AD Global Pay revisará tus datos manualmente.</p>' +
                    '<a href="/kyc/completado?status=PROCESSING" class="kyc-btn kyc-btn-success" style="width:auto; display:inline-flex; padding-left:2rem; padding-right:2rem;">Continuar</a>' +
                  '</div>';
              }
            })
            .catch(function(err) {
              btnSubmit.disabled = false;
              btnSubmit.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Enviar para revisión';
              showStepError('step4Error', err.message);
            });
        });
      }

      window.goToStep = goToStep;

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initSignatureCanvas);
      } else {
        initSignatureCanvas();
      }
      loadKyc();
    })();
  </script>
</body>
</html>
