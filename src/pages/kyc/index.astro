  </main>

  <script is:inline>
    (function() {
      // Read token from query string
      var params = new URLSearchParams(window.location.search);
      var token = params.get('token');

      var noTokenEl = document.getElementById('noTokenState');
      var kycContentEl = document.getElementById('kycContent');

      if (!token) {
        if (noTokenEl) noTokenEl.classList.remove('hidden');
        return;
      }

      if (kycContentEl) kycContentEl.classList.remove('hidden');

      var signatureIsEmpty = true;
      var canvas = null;
      var ctx = null;

      // Loading simulation
      setTimeout(function() {
        var loading = document.getElementById('loadingState');
        var main = document.getElementById('mainContent');
        if (loading) loading.classList.add('hidden');
        if (main) main.classList.remove('hidden');
      }, 1200);

      // Signature canvas
      function initSignatureCanvas() {
        canvas = document.getElementById('signatureCanvas');
        if (!canvas) return;

        ctx = canvas.getContext('2d');
        ctx.strokeStyle = '#1e293b';
        ctx.lineWidth = 2.5;
        ctx.lineCap = 'round';
        ctx.lineJoin = 'round';

        var drawing = false;
        var lastX = 0, lastY = 0;

        function getCoordinates(e) {
          var rect = canvas.getBoundingClientRect();
          var scaleX = canvas.width / rect.width;
          var scaleY = canvas.height / rect.height;

          var clientX, clientY;
          if (e.touches && e.touches.length > 0) {
            clientX = e.touches[0].clientX;
            clientY = e.touches[0].clientY;
          } else {
            clientX = e.clientX;
            clientY = e.clientY;
          }

          var x = (clientX - rect.left) * scaleX;
          var y = (clientY - rect.top) * scaleY;
          if (x < 0) x = 0;
          if (x > canvas.width) x = canvas.width;
          if (y < 0) y = 0;
          if (y > canvas.height) y = canvas.height;
          return { x: x, y: y };
        }

        function startDrawing(e) {
          e.preventDefault();
          drawing = true;
          var coords = getCoordinates(e);
          lastX = coords.x;
          lastY = coords.y;
          ctx.beginPath();
          ctx.moveTo(lastX, lastY);
          ctx.lineTo(lastX, lastY);
          ctx.stroke();
          signatureIsEmpty = false;
          document.getElementById('signatureBox').classList.add('drawing');
          document.getElementById('signatureHint').style.opacity = '0';
        }

        function draw(e) {
          e.preventDefault();
          if (!drawing) return;
          var coords = getCoordinates(e);
          ctx.beginPath();
          ctx.moveTo(lastX, lastY);
          ctx.lineTo(coords.x, coords.y);
          ctx.stroke();
          lastX = coords.x;
          lastY = coords.y;
        }

        function stopDrawing(e) {
          if (e) e.preventDefault();
          drawing = false;
        }

        canvas.addEventListener('mousedown', startDrawing);
        canvas.addEventListener('mousemove', draw);
        canvas.addEventListener('mouseup', stopDrawing);
        canvas.addEventListener('mouseleave', stopDrawing);
        canvas.addEventListener('touchstart', startDrawing, { passive: false });
        canvas.addEventListener('touchmove', draw, { passive: false });
        canvas.addEventListener('touchend', stopDrawing, { passive: false });
        canvas.addEventListener('touchcancel', stopDrawing, { passive: false });

        var clearBtn = document.getElementById('clearSignature');
        if (clearBtn) {
          clearBtn.addEventListener('click', function() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            ctx.fillStyle = 'white';
            ctx.fillRect(0, 0, canvas.width, canvas.height);
            ctx.strokeStyle = '#1e293b';
            signatureIsEmpty = true;
            document.getElementById('signatureBox').classList.remove('drawing');
            document.getElementById('signatureHint').style.opacity = '1';
          });
        }

        ctx.fillStyle = 'white';
        ctx.fillRect(0, 0, canvas.width, canvas.height);
        ctx.strokeStyle = '#1e293b';
      }

      // Checkbox styling
      var checkbox = document.getElementById('aceptoTerminos');
      var checkboxWrap = document.getElementById('checkboxWrap');
      if (checkbox && checkboxWrap) {
        checkbox.addEventListener('change', function() {
          checkboxWrap.classList.toggle('checked', this.checked);
        });
      }

      // Start verification
      var startBtn = document.getElementById('startVerificationBtn');
      if (startBtn) {
        startBtn.addEventListener('click', function() {
          var acepta = document.getElementById('aceptoTerminos');
          var canvasEl = document.getElementById('signatureCanvas');

          if (!acepta || !acepta.checked) {
            alert('Debes aceptar los términos y condiciones y la declaración jurada para continuar.');
            return;
          }

          if (signatureIsEmpty) {
            alert('Debes firmar la declaración jurada para continuar.');
            return;
          }

          var signatureData = canvasEl.toDataURL('image/png');
          console.log('Firma capturada');

          var btn = this;
          var area = document.getElementById('verificationArea');

          btn.disabled = true;
          btn.innerHTML = '<div style="width:20px;height:20px;border:2px solid white;border-top-color:transparent;border-radius:50%;animation:spin 1s linear infinite;margin:0 auto;"></div>';

          // Update step indicators
          document.getElementById('stepCircle1').className = 'kyc-step-circle done';
          document.getElementById('stepCircle1').innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
          document.getElementById('stepLine1').style.width = '100%';
          document.getElementById('stepCircle2').className = 'kyc-step-circle active';
          document.getElementById('stepCircle2').innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
          document.getElementById('stepLine2').style.width = '100%';
          document.getElementById('stepCircle3').className = 'kyc-step-circle active';

          setTimeout(function() {
            area.innerHTML =
              '<div class="kyc-success-icon">' +
                '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>' +
              '</div>' +
              '<h3 style="font-family:var(--font-heading);font-size:1.1rem;font-weight:700;color:var(--slate-800);margin-bottom:0.375rem;">¡Verificación completada!</h3>' +
              '<p style="font-size:0.8rem;color:var(--slate-500);font-weight:500;margin-bottom:1.25rem;">Tu identidad ha sido verificada correctamente.</p>' +
              '<button onclick="window.location.href=\'/kyc/completado\'" class="kyc-btn kyc-btn-success">Continuar</button>';
          }, 2000);
        });
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initSignatureCanvas);
      } else {
        initSignatureCanvas();
      }
    })();
  </script>
</body>
</html>
