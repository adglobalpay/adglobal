---
// Página estática para verificación KYC
// El token se lee del query string con JavaScript del lado del cliente
// Diseño premium alineado con la identidad visual de AD Global Pay
const API_URL = import.meta.env.VITE_API_URL || 'https://backend-global-production.up.railway.app';
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes, viewport-fit=cover">
  <title>Verificación de Identidad — AD Global Pay</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="icon" href="/img/logo.webp" type="image/webp" />
  <script is:inline define:vars={{ API_URL }}>
    window.__ADGLOBAL_API_URL__ = API_URL;
  </script>
  <style>
    :root {
      --font-heading: 'Outfit', sans-serif;
      --font-body: 'DM Sans', sans-serif;
      --font-mono: 'JetBrains Mono', monospace;
      --indigo: #6366f1;
      --indigo-light: #818cf8;
      --indigo-dark: #4f46e5;
      --indigo-50: #eef2ff;
      --indigo-100: #e0e7ff;
      --indigo-200: #c7d2fe;
      --cyan: #06b6d4;
      --emerald: #10b981;
      --emerald-50: #ecfdf5;
      --emerald-100: #d1fae5;
      --amber: #f59e0b;
      --rose: #f43f5e;
      --slate-50: #f8fafc;
      --slate-100: #f1f5f9;
      --slate-200: #e2e8f0;
      --slate-300: #cbd5e1;
      --slate-400: #94a3b8;
      --slate-500: #64748b;
      --slate-600: #475569;
      --slate-700: #334155;
      --slate-800: #1e293b;
      --slate-900: #0f172a;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: var(--font-body);
      background: linear-gradient(160deg, var(--slate-50) 0%, #f0f4ff 40%, #e8f4fd 100%);
      min-height: 100vh;
      color: var(--slate-800);
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      overflow-x: hidden;
    }

    /* ===== ANIMATIONS ===== */
    @keyframes fadeInUp {
      from { opacity: 0; transform: translateY(24px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes fadeInScale {
      from { opacity: 0; transform: scale(0.96); }
      to { opacity: 1; transform: scale(1); }
    }
    @keyframes slideInLeft {
      from { opacity: 0; transform: translateX(-30px); }
      to { opacity: 1; transform: translateX(0); }
    }
    @keyframes slideInRight {
      from { opacity: 0; transform: translateX(30px); }
      to { opacity: 1; transform: translateX(0); }
    }
    @keyframes pulse-ring {
      0% { transform: scale(0.8); opacity: 1; }
      100% { transform: scale(1.6); opacity: 0; }
    }
    @keyframes float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-8px); }
    }
    @keyframes spin {
      from { transform: rotate(0deg); }
      to { transform: rotate(360deg); }
    }
    @keyframes shimmer {
      0% { background-position: -200% 0; }
      100% { background-position: 200% 0; }
    }
    @keyframes drawCheck {
      0% { stroke-dashoffset: 24; }
      100% { stroke-dashoffset: 0; }
    }
    @keyframes progressFill {
      from { width: 0%; }
      to { width: 100%; }
    }
    @keyframes badgePulse {
      0%, 100% { box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.4); }
      50% { box-shadow: 0 0 0 8px rgba(16, 185, 129, 0); }
    }
    @keyframes gradientShift {
      0% { background-position: 0% 50%; }
      50% { background-position: 100% 50%; }
      100% { background-position: 0% 50%; }
    }

    .anim-fade-up {
      animation: fadeInUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      opacity: 0;
    }
    .anim-scale-in {
      animation: fadeInScale 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      opacity: 0;
    }
    .anim-slide-left { animation: slideInLeft 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards; opacity: 0; }
    .anim-slide-right { animation: slideInRight 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards; opacity: 0; }

    .delay-1 { animation-delay: 0.08s; }
    .delay-2 { animation-delay: 0.16s; }
    .delay-3 { animation-delay: 0.24s; }
    .delay-4 { animation-delay: 0.32s; }
    .delay-5 { animation-delay: 0.40s; }
    .delay-6 { animation-delay: 0.48s; }

    /* ===== BACKGROUND DECORATIONS ===== */
    .bg-decoration {
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 0;
      overflow: hidden;
    }
    .bg-decoration::before {
      content: '';
      position: absolute;
      top: -20%;
      right: -10%;
      width: 600px;
      height: 600px;
      background: radial-gradient(circle, rgba(99, 102, 241, 0.08) 0%, transparent 70%);
      border-radius: 50%;
    }
    .bg-decoration::after {
      content: '';
      position: absolute;
      bottom: -10%;
      left: -5%;
      width: 500px;
      height: 500px;
      background: radial-gradient(circle, rgba(6, 182, 212, 0.06) 0%, transparent 70%);
      border-radius: 50%;
    }

    /* ===== HEADER ===== */
    .kyc-header {
      position: relative;
      z-index: 10;
      padding: 1.5rem;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .kyc-header-inner {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 0.625rem 1.25rem;
      background: rgba(255, 255, 255, 0.7);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid rgba(226, 232, 240, 0.6);
      border-radius: 9999px;
      box-shadow: 0 4px 20px -4px rgba(15, 23, 42, 0.06);
    }
    .kyc-header-logo {
      width: 32px;
      height: 32px;
      border-radius: 10px;
      background: linear-gradient(135deg, var(--indigo) 0%, var(--cyan) 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: 14px;
      flex-shrink: 0;
      overflow: hidden;
    }
    .kyc-header-logo img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
    .kyc-header-title {
      font-family: var(--font-heading);
      font-weight: 700;
      font-size: 0.875rem;
      color: var(--slate-800);
      letter-spacing: -0.01em;
    }
    .kyc-header-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.25rem;
      padding: 0.25rem 0.625rem;
      background: var(--emerald-50);
      border: 1px solid var(--emerald-100);
      border-radius: 9999px;
      font-size: 0.7rem;
      font-weight: 700;
      color: var(--emerald);
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    /* ===== MAIN CONTAINER ===== */
    .kyc-container {
      position: relative;
      z-index: 10;
      max-width: 520px;
      margin: 0 auto;
      padding: 0 1rem 3rem;
    }

    /* ===== CARD ===== */
    .kyc-card {
      background: rgba(255, 255, 255, 0.85);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border: 1px solid rgba(226, 232, 240, 0.7);
      border-radius: 28px;
      box-shadow: 0 20px 60px -16px rgba(15, 23, 42, 0.08), 0 0 0 1px rgba(255, 255, 255, 0.5) inset;
      overflow: hidden;
      transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s ease;
    }
    .kyc-card:hover {
      box-shadow: 0 24px 72px -16px rgba(15, 23, 42, 0.12), 0 0 0 1px rgba(255, 255, 255, 0.5) inset;
    }

    /* ===== HERO SECTION ===== */
    .kyc-hero {
      position: relative;
      padding: 2.5rem 1.75rem 2rem;
      text-align: center;
      background: linear-gradient(135deg, var(--indigo) 0%, var(--indigo-dark) 50%, #4338ca 100%);
      background-size: 200% 200%;
      animation: gradientShift 8s ease infinite;
      overflow: hidden;
    }
    .kyc-hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.04'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    }
    .kyc-hero-step {
      position: relative;
      z-index: 2;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.375rem 1rem;
      background: rgba(255, 255, 255, 0.12);
      border: 1px solid rgba(255, 255, 255, 0.15);
      border-radius: 9999px;
      font-family: var(--font-heading);
      font-size: 0.75rem;
      font-weight: 600;
      color: rgba(255, 255, 255, 0.85);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      margin-bottom: 1.25rem;
    }
    .kyc-hero-step-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--emerald);
      animation: badgePulse 2s ease-in-out infinite;
    }
    .kyc-hero-icon-wrap {
      position: relative;
      z-index: 2;
      width: 72px;
      height: 72px;
      margin: 0 auto 1.25rem;
      border-radius: 22px;
      background: rgba(255, 255, 255, 0.1);
      border: 1px solid rgba(255, 255, 255, 0.15);
      backdrop-filter: blur(8px);
      display: flex;
      align-items: center;
      justify-content: center;
      animation: float 5s ease-in-out infinite;
    }
    .kyc-hero-icon-wrap svg {
      width: 32px;
      height: 32px;
      color: white;
    }
    .kyc-hero h1 {
      position: relative;
      z-index: 2;
      font-family: var(--font-heading);
      font-size: 1.5rem;
      font-weight: 800;
      color: white;
      letter-spacing: -0.02em;
      line-height: 1.2;
      margin-bottom: 0.5rem;
    }
    .kyc-hero p {
      position: relative;
      z-index: 2;
      font-size: 0.875rem;
      color: rgba(255, 255, 255, 0.7);
      font-weight: 500;
    }

    /* ===== PROGRESS STEPS ===== */
    .kyc-steps {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      padding: 1.5rem 1.75rem 0.5rem;
    }
    .kyc-step {
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .kyc-step-circle {
      width: 32px;
      height: 32px;
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--font-heading);
      font-size: 0.75rem;
      font-weight: 700;
      flex-shrink: 0;
      transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .kyc-step-circle.active {
      background: linear-gradient(135deg, var(--indigo) 0%, var(--indigo-dark) 100%);
      color: white;
      box-shadow: 0 4px 12px -2px rgba(99, 102, 241, 0.4);
    }
    .kyc-step-circle.pending {
      background: var(--slate-100);
      color: var(--slate-400);
      border: 2px solid var(--slate-200);
    }
    .kyc-step-circle.done {
      background: var(--emerald);
      color: white;
    }
    .kyc-step-line {
      width: 40px;
      height: 2px;
      background: var(--slate-200);
      border-radius: 1px;
      position: relative;
      overflow: hidden;
    }
    .kyc-step-line-fill {
      position: absolute;
      inset: 0;
      background: linear-gradient(90deg, var(--indigo) 0%, var(--cyan) 100%);
      border-radius: 1px;
      width: 0%;
      transition: width 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .kyc-step-label {
      font-size: 0.65rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--slate-400);
      margin-top: 0.25rem;
      text-align: center;
    }
    .step-label-short { display: none; }

    /* ===== CONTENT ===== */
    .kyc-content {
      padding: 1.5rem 1.75rem 2rem;
    }

    /* ===== LOADING STATE ===== */
    .kyc-loading {
      text-align: center;
      padding: 3rem 1rem;
    }
    .kyc-loading-ring {
      width: 48px;
      height: 48px;
      margin: 0 auto 1.25rem;
      position: relative;
    }
    .kyc-loading-ring::before {
      content: '';
      position: absolute;
      inset: 0;
      border: 3px solid var(--indigo-100);
      border-top-color: var(--indigo);
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
    }
    .kyc-loading-ring::after {
      content: '';
      position: absolute;
      inset: 6px;
      border: 2px solid transparent;
      border-top-color: var(--cyan);
      border-radius: 50%;
      animation: spin 1.2s linear infinite reverse;
    }
    .kyc-loading p {
      font-size: 0.875rem;
      color: var(--slate-500);
      font-weight: 500;
    }
    .kyc-loading-dots::after {
      content: '';
      animation: dots 1.5s steps(4, end) infinite;
    }
    @keyframes dots {
      0% { content: ''; }
      25% { content: '.'; }
      50% { content: '..'; }
      75% { content: '...'; }
      100% { content: ''; }
    }

    /* ===== CLIENT INFO CARD ===== */
    .kyc-client-card {
      display: flex;
      align-items: center;
      gap: 1rem;
      padding: 1rem 1.25rem;
      background: linear-gradient(135deg, var(--indigo-50) 0%, rgba(6, 182, 212, 0.06) 100%);
      border: 1px solid var(--indigo-100);
      border-radius: 18px;
      margin-bottom: 1.5rem;
      transition: all 0.3s ease;
    }
    .kyc-client-card:hover {
      border-color: var(--indigo-200);
      box-shadow: 0 4px 16px -4px rgba(99, 102, 241, 0.1);
    }
    .kyc-client-avatar {
      width: 44px;
      height: 44px;
      border-radius: 14px;
      background: linear-gradient(135deg, var(--indigo) 0%, var(--cyan) 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      font-family: var(--font-heading);
      font-weight: 700;
      font-size: 1rem;
      flex-shrink: 0;
    }
    .kyc-client-avatar svg {
      width: 22px;
      height: 22px;
    }
    .kyc-client-info p {
      font-family: var(--font-heading);
      font-weight: 700;
      font-size: 0.9rem;
      color: var(--slate-800);
      line-height: 1.3;
    }
    .kyc-client-info span {
      font-size: 0.75rem;
      color: var(--slate-400);
      font-weight: 500;
    }

    /* ===== SECTION TITLE ===== */
    .kyc-section-title {
      display: flex;
      align-items: center;
      gap: 0.625rem;
      font-family: var(--font-heading);
      font-size: 0.95rem;
      font-weight: 700;
      color: var(--slate-800);
      margin-bottom: 1rem;
    }
    .kyc-section-title svg {
      width: 20px;
      height: 20px;
      color: var(--indigo);
    }

    /* ===== DECLARACIÓN JURADA ===== */
    .kyc-declaracion {
      background: var(--slate-50);
      border: 1px solid var(--slate-200);
      border-left: 3px solid var(--indigo);
      border-radius: 18px;
      padding: 1.25rem;
      margin-bottom: 1.5rem;
      transition: all 0.3s ease;
    }
    .kyc-declaracion:hover {
      border-color: var(--indigo-200);
      box-shadow: 0 4px 16px -4px rgba(99, 102, 241, 0.08);
    }
    .kyc-declaracion ul {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    .kyc-declaracion li {
      position: relative;
      padding-left: 1.5rem;
      font-size: 0.8rem;
      line-height: 1.6;
      color: var(--slate-600);
      margin-bottom: 0.625rem;
    }
    .kyc-declaracion li::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0.4rem;
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--indigo) 0%, var(--cyan) 100%);
    }
    .kyc-declaracion li:last-child { margin-bottom: 0; }
    .kyc-declaracion a {
      color: var(--indigo);
      font-weight: 600;
      text-decoration: none;
      border-bottom: 1px solid var(--indigo-200);
      transition: all 0.2s ease;
    }
    .kyc-declaracion a:hover {
      color: var(--indigo-dark);
      border-bottom-color: var(--indigo);
    }

    /* ===== SIGNATURE ===== */
    .kyc-signature-wrap {
      margin-bottom: 1.5rem;
    }
    .kyc-signature-label {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.8rem;
      font-weight: 600;
      color: var(--slate-700);
      margin-bottom: 0.625rem;
    }
    .kyc-signature-label svg {
      width: 16px;
      height: 16px;
      color: var(--indigo);
    }
    .kyc-signature-box {
      position: relative;
      border: 2px dashed var(--slate-300);
      border-radius: 16px;
      background: white;
      overflow: hidden;
      transition: all 0.3s ease;
    }
    .kyc-signature-box:hover {
      border-color: var(--indigo-200);
    }
    .kyc-signature-box.drawing {
      border-color: var(--indigo);
      border-style: solid;
      box-shadow: 0 0 0 4px var(--indigo-50);
    }
    .kyc-signature-canvas {
      width: 100%;
      height: auto;
      max-width: 400px;
      display: block;
      touch-action: none;
      cursor: crosshair;
    }
    .kyc-signature-hint {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      pointer-events: none;
      font-size: 0.75rem;
      color: var(--slate-300);
      font-weight: 500;
      letter-spacing: 0.02em;
    }
    .kyc-signature-actions {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.625rem 0.875rem;
      background: var(--slate-50);
      border-top: 1px solid var(--slate-200);
    }
    .kyc-signature-clear {
      display: inline-flex;
      align-items: center;
      gap: 0.375rem;
      padding: 0.375rem 0.75rem;
      background: transparent;
      border: 1px solid var(--slate-200);
      border-radius: 10px;
      font-family: var(--font-body);
      font-size: 0.75rem;
      font-weight: 600;
      color: var(--slate-500);
      cursor: pointer;
      transition: all 0.2s ease;
    }
    .kyc-signature-clear:hover {
      background: var(--rose);
      color: white;
      border-color: var(--rose);
    }
    .kyc-signature-clear svg {
      width: 14px;
      height: 14px;
    }
    .kyc-signature-hint-text {
      font-size: 0.7rem;
      color: var(--slate-400);
      font-weight: 500;
    }

    /* ===== CHECKBOX CUSTOM ===== */
    .kyc-checkbox-wrap {
      display: flex;
      align-items: flex-start;
      gap: 0.75rem;
      padding: 1rem 1.25rem;
      background: white;
      border: 2px solid var(--slate-200);
      border-radius: 16px;
      cursor: pointer;
      transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
      margin-bottom: 1.25rem;
    }
    .kyc-checkbox-wrap:hover {
      border-color: var(--indigo-200);
      box-shadow: 0 4px 16px -4px rgba(99, 102, 241, 0.08);
    }
    .kyc-checkbox-wrap.checked {
      border-color: var(--indigo);
      background: var(--indigo-50);
      box-shadow: 0 4px 16px -4px rgba(99, 102, 241, 0.12);
    }
    .kyc-checkbox {
      appearance: none;
      -webkit-appearance: none;
      width: 22px;
      height: 22px;
      min-width: 22px;
      border: 2px solid var(--slate-300);
      border-radius: 7px;
      margin-top: 1px;
      cursor: pointer;
      transition: all 0.2s ease;
      position: relative;
      background: white;
    }
    .kyc-checkbox:checked {
      background: linear-gradient(135deg, var(--indigo) 0%, var(--indigo-dark) 100%);
      border-color: var(--indigo);
    }
    .kyc-checkbox:checked::after {
      content: '';
      position: absolute;
      left: 6px;
      top: 2px;
      width: 5px;
      height: 10px;
      border: solid white;
      border-width: 0 2px 2px 0;
      transform: rotate(45deg);
    }
    .kyc-checkbox-label {
      font-size: 0.85rem;
      line-height: 1.5;
      color: var(--slate-700);
      font-weight: 500;
      user-select: none;
    }
    .kyc-checkbox-label strong {
      color: var(--slate-900);
      font-weight: 700;
    }

    /* ===== VERIFICATION AREA ===== */
    .kyc-verify-area {
      text-align: center;
      padding: 2rem 1.5rem;
      background: linear-gradient(135deg, var(--indigo-50) 0%, rgba(6, 182, 212, 0.04) 100%);
      border: 2px dashed var(--indigo-200);
      border-radius: 20px;
      margin-bottom: 1.25rem;
      transition: all 0.3s ease;
    }
    .kyc-verify-area:hover {
      border-color: var(--indigo);
      background: linear-gradient(135deg, var(--indigo-50) 0%, rgba(6, 182, 212, 0.08) 100%);
    }
    .kyc-verify-icon {
      width: 64px;
      height: 64px;
      margin: 0 auto 1rem;
      border-radius: 20px;
      background: linear-gradient(135deg, var(--indigo) 0%, var(--indigo-dark) 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 8px 24px -6px rgba(99, 102, 241, 0.35);
      animation: float 4s ease-in-out infinite;
    }
    .kyc-verify-icon svg {
      width: 28px;
      height: 28px;
      color: white;
    }
    .kyc-verify-area h3 {
      font-family: var(--font-heading);
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--slate-800);
      margin-bottom: 0.375rem;
    }
    .kyc-verify-area p {
      font-size: 0.8rem;
      color: var(--slate-500);
      font-weight: 500;
      margin-bottom: 1.25rem;
      max-width: 280px;
      margin-left: auto;
      margin-right: auto;
    }

    /* ===== BUTTONS ===== */
    .kyc-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      width: 100%;
      padding: 0.875rem 1.5rem;
      font-family: var(--font-heading);
      font-size: 0.9rem;
      font-weight: 700;
      border: none;
      border-radius: 14px;
      cursor: pointer;
      transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
      position: relative;
      overflow: hidden;
    }
    .kyc-btn::after {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(circle at center, rgba(255,255,255,0.2) 0%, transparent 70%);
      opacity: 0;
      transition: opacity 0.3s ease;
    }
    .kyc-btn:hover::after { opacity: 1; }
    .kyc-btn-primary {
      background: linear-gradient(135deg, var(--indigo) 0%, var(--indigo-dark) 100%);
      color: white;
      box-shadow: 0 8px 24px -6px rgba(99, 102, 241, 0.4);
    }
    .kyc-btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 12px 32px -6px rgba(99, 102, 241, 0.5);
    }
    .kyc-btn-primary:active {
      transform: translateY(0) scale(0.98);
    }
    .kyc-btn-primary:disabled {
      opacity: 0.6;
      cursor: not-allowed;
      transform: none;
    }
    .kyc-btn-success {
      background: linear-gradient(135deg, var(--emerald) 0%, #059669 100%);
      color: white;
      box-shadow: 0 8px 24px -6px rgba(16, 185, 129, 0.4);
    }
    .kyc-btn-success:hover {
      transform: translateY(-2px);
      box-shadow: 0 12px 32px -6px rgba(16, 185, 129, 0.5);
    }

    /* ===== FILE UPLOADS ===== */
    .kyc-upload-grid {
      display: grid;
      gap: 0.875rem;
      margin-bottom: 1.25rem;
    }
    .kyc-upload-card {
      display: grid;
      grid-template-columns: 44px 1fr auto;
      gap: 0.75rem;
      align-items: center;
      padding: 0.875rem 1rem;
      background: white;
      border: 1.5px dashed var(--slate-300);
      border-radius: 16px;
      text-align: left;
      cursor: pointer;
      transition: all 0.25s ease;
      position: relative;
    }
    .kyc-upload-card:hover {
      border-color: var(--indigo);
      background: var(--indigo-50);
      box-shadow: 0 8px 24px -12px rgba(99, 102, 241, 0.2);
      transform: translateY(-1px);
    }
    .kyc-upload-card:active {
      transform: scale(0.99);
    }
    .kyc-upload-card.ready {
      border-style: solid;
      border-color: var(--emerald-200);
      background: linear-gradient(135deg, white 0%, var(--emerald-50) 100%);
    }
    .kyc-upload-icon,
    .kyc-upload-preview {
      width: 44px;
      height: 44px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--indigo-50);
      color: var(--indigo);
      overflow: hidden;
      flex-shrink: 0;
    }
    .kyc-upload-icon svg {
      width: 20px;
      height: 20px;
    }
    .kyc-upload-preview img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .kyc-upload-text {
      display: flex;
      flex-direction: column;
      gap: 0.15rem;
    }
    .kyc-upload-text strong {
      font-family: var(--font-heading);
      font-size: 0.9rem;
      color: var(--slate-800);
      line-height: 1.25;
    }
    .kyc-upload-text span {
      font-size: 0.72rem;
      color: var(--slate-500);
      font-weight: 600;
      line-height: 1.35;
    }
    .kyc-upload-hint {
      display: flex;
      align-items: center;
      gap: 0.25rem;
      font-size: 0.65rem;
      font-weight: 700;
      color: var(--indigo);
      margin-top: 0.2rem;
    }
    .kyc-upload-action {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      background: var(--indigo-50);
      color: var(--indigo);
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.2s ease;
      flex-shrink: 0;
    }
    .kyc-upload-card:hover .kyc-upload-action {
      background: var(--indigo);
      color: white;
    }
    .kyc-upload-action svg {
      width: 16px;
      height: 16px;
    }
    .kyc-upload-card.ready .kyc-upload-action {
      background: var(--emerald);
      color: white;
    }
    .kyc-alert {
      padding: 0.875rem 1rem;
      background: #fff7ed;
      border: 1px solid #fed7aa;
      color: #c2410c;
      border-radius: 14px;
      font-size: 0.78rem;
      font-weight: 700;
      line-height: 1.4;
      margin-bottom: 1rem;
    }

    /* ===== SECURITY BADGE ===== */
    .kyc-security {
      display: flex;
      align-items: center;
      gap: 0.875rem;
      padding: 1rem 1.25rem;
      background: linear-gradient(135deg, var(--emerald-50) 0%, rgba(6, 182, 212, 0.04) 100%);
      border: 1px solid var(--emerald-100);
      border-radius: 16px;
      margin-bottom: 1.25rem;
      transition: all 0.3s ease;
    }
    .kyc-security:hover {
      border-color: var(--emerald-200);
      box-shadow: 0 4px 16px -4px rgba(16, 185, 129, 0.1);
    }
    .kyc-security-icon {
      width: 40px;
      height: 40px;
      border-radius: 12px;
      background: linear-gradient(135deg, var(--emerald) 0%, var(--cyan) 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      box-shadow: 0 4px 12px -2px rgba(16, 185, 129, 0.3);
    }
    .kyc-security-icon svg {
      width: 20px;
      height: 20px;
      color: white;
    }
    .kyc-security-text p {
      font-family: var(--font-heading);
      font-weight: 700;
      font-size: 0.85rem;
      color: var(--slate-800);
      line-height: 1.3;
    }
    .kyc-security-text span {
      font-size: 0.75rem;
      color: var(--slate-400);
      font-weight: 500;
    }

    /* ===== FOOTER ===== */
    .kyc-footer {
      text-align: center;
      padding: 1.25rem 1.75rem;
      background: var(--slate-50);
      border-top: 1px solid var(--slate-100);
    }
    .kyc-footer p {
      font-size: 0.75rem;
      color: var(--slate-400);
      font-weight: 500;
    }
    .kyc-footer a {
      color: var(--indigo);
      font-weight: 700;
      text-decoration: none;
      transition: color 0.2s ease;
    }
    .kyc-footer a:hover { color: var(--indigo-dark); }
    .kyc-footer-badges {
      display: flex;
      justify-content: center;
      gap: 1rem;
      margin-top: 0.875rem;
    }
    .kyc-footer-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.375rem;
      font-size: 0.65rem;
      font-weight: 700;
      color: var(--slate-400);
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }
    .kyc-footer-badge svg {
      width: 14px;
      height: 14px;
      color: var(--emerald);
    }

    /* ===== EXPIRY NOTE ===== */
    .kyc-expiry {
      text-align: center;
      margin-bottom: 1rem;
    }
    .kyc-expiry p {
      display: inline-flex;
      align-items: center;
      gap: 0.375rem;
      font-size: 0.7rem;
      font-weight: 600;
      color: var(--slate-400);
      padding: 0.375rem 0.875rem;
      background: var(--slate-100);
      border-radius: 9999px;
    }
    .kyc-expiry svg {
      width: 14px;
      height: 14px;
      color: var(--amber);
    }

    /* ===== NO TOKEN STATE ===== */
    .kyc-no-token {
      text-align: center;
      padding: 4rem 1.5rem;
    }
    .kyc-no-token-icon {
      width: 80px;
      height: 80px;
      margin: 0 auto 1.5rem;
      border-radius: 24px;
      background: linear-gradient(135deg, var(--rose) 0%, #fb7185 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 8px 24px -6px rgba(244, 63, 94, 0.35);
      animation: float 4s ease-in-out infinite;
    }
    .kyc-no-token-icon svg {
      width: 36px;
      height: 36px;
      color: white;
    }
    .kyc-no-token h2 {
      font-family: var(--font-heading);
      font-size: 1.25rem;
      font-weight: 800;
      color: var(--slate-800);
      margin-bottom: 0.5rem;
    }
    .kyc-no-token p {
      font-size: 0.85rem;
      color: var(--slate-500);
      font-weight: 500;
      margin-bottom: 1.5rem;
    }

    /* ===== SUCCESS STATE ===== */
    .kyc-success-icon {
      width: 72px;
      height: 72px;
      margin: 0 auto 1.25rem;
      border-radius: 22px;
      background: linear-gradient(135deg, var(--emerald) 0%, #059669 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 8px 24px -6px rgba(16, 185, 129, 0.35);
      animation: float 4s ease-in-out infinite;
    }
    .kyc-success-icon svg {
      width: 32px;
      height: 32px;
      color: white;
    }

    /* ===== HIDDEN ===== */
    .hidden { display: none !important; }

    /* ===== RESPONSIVE ===== */
    @media (max-width: 480px) {
      .kyc-container { padding: 0 0.75rem 2rem; }
      .kyc-card { border-radius: 22px; }
      .kyc-hero { padding: 2rem 1.25rem 1.5rem; }
      .kyc-hero h1 { font-size: 1.25rem; }
      .kyc-content { padding: 1.25rem 1.25rem 1.5rem; }
      .kyc-steps { padding: 1.25rem 0.5rem 0.5rem; gap: 0.2rem; justify-content: space-between; }
      .kyc-step { gap: 0.3rem; }
      .kyc-step-circle { width: 26px; height: 26px; border-radius: 8px; font-size: 0.7rem; }
      .kyc-step-line { width: 14px; }
      .kyc-step-label { font-size: 0.55rem; letter-spacing: 0.02em; }
      .step-label-full { display: none; }
      .step-label-short { display: inline; }
    }

    /* Touch targets */
    @media (pointer: coarse) {
      .kyc-btn, .kyc-signature-clear, .kyc-checkbox-wrap {
        min-height: 44px;
      }
    }
  </style>
</head>
<body>
  <!-- Background Decorations -->
  <div class="bg-decoration"></div>

  <!-- Header -->
  <header class="kyc-header anim-fade-up">
    <div class="kyc-header-inner">
      <div class="kyc-header-logo"><img src="/img/logo.webp" alt="AD Global Pay" /></div>
      <span class="kyc-header-title">AD Global Pay</span>
      <span class="kyc-header-badge">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        Seguro
      </span>
    </div>
  </header>

  <!-- Main -->
  <main class="kyc-container">

    <!-- Estado: sin token -->
    <div id="noTokenState" class="kyc-card hidden anim-scale-in">
      <div class="kyc-no-token">
        <div class="kyc-no-token-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        </div>
        <h2>Link inválido</h2>
        <p>El enlace de verificación no es válido o ha expirado.<br>Solicita uno nuevo desde tu cuenta.</p>
        <a href="/" class="kyc-btn kyc-btn-primary" style="width:auto; padding-left:2rem; padding-right:2rem;">Volver al inicio</a>
      </div>
    </div>

    <!-- Estado: con token -->
    <div id="kycContent" class="kyc-card hidden anim-scale-in delay-1">

      <!-- Hero -->
      <div class="kyc-hero">
        <div class="kyc-hero-step">
          <span class="kyc-hero-step-dot"></span>
          <span id="heroStepText">Paso 1 de 3</span>
        </div>
        <div class="kyc-hero-icon-wrap">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
        </div>
        <h1>Verifica tu identidad</h1>
        <p>AD Global Pay · Proceso seguro y rápido</p>
      </div>

      <!-- Steps -->
      <div class="kyc-steps">
        <div class="kyc-step">
          <div class="kyc-step-circle active" id="stepCircle1">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <div>
            <div class="kyc-step-label">
              <span class="step-label-full">Declaración</span>
              <span class="step-label-short">Declara</span>
            </div>
          </div>
        </div>
        <div class="kyc-step-line"><div class="kyc-step-line-fill" id="stepLine1"></div></div>
        <div class="kyc-step">
          <div class="kyc-step-circle pending" id="stepCircle2">2</div>
          <div>
            <div class="kyc-step-label">
              <span class="step-label-full">Verificación</span>
              <span class="step-label-short">Verifica</span>
            </div>
          </div>
        </div>
        <div class="kyc-step-line"><div class="kyc-step-line-fill" id="stepLine2"></div></div>
        <div class="kyc-step">
          <div class="kyc-step-circle pending" id="stepCircle3">3</div>
          <div>
            <div class="kyc-step-label">
              <span class="step-label-full">Confirmación</span>
              <span class="step-label-short">Confirma</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Content -->
      <div class="kyc-content">

        <!-- Loading -->
        <div id="loadingState" class="kyc-loading">
          <div class="kyc-loading-ring"></div>
          <p class="kyc-loading-dots">Cargando verificador</p>
        </div>

        <!-- Main Content -->
        <div id="mainContent" class="hidden">

          <!-- Client Info -->
          <div class="kyc-client-card anim-fade-up delay-1">
            <div class="kyc-client-avatar">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            </div>
            <div class="kyc-client-info">
              <p id="clientName">Cliente AD Global Pay</p>
              <span id="clientEmail">Solicitud de verificación</span>
            </div>
          </div>

          <!-- Declaración Jurada -->
          <div class="kyc-section-title anim-fade-up delay-2">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
            Declaración Jurada
          </div>
          <div class="kyc-declaracion anim-fade-up delay-3">
            <ul>
              <li>Los fondos que enviaré a través de AD Global Pay provienen de <strong>actividades lícitas y verificables</strong>.</li>
              <li>No estoy involucrado en actividades de lavado de activos, financiamiento del terrorismo, ni operaciones con personas o entidades sancionadas por OFAC.</li>
              <li>Toda la información proporcionada es <strong>veraz, completa y actualizada</strong>.</li>
              <li>Acepto los <a href="/terminos" target="_blank">Términos y Condiciones</a> y la <a href="/privacidad" target="_blank">Política de Privacidad</a> de AD Global Services LLC.</li>
            </ul>
          </div>

          <!-- Signature -->
          <div class="kyc-signature-wrap anim-fade-up delay-4">
            <div class="kyc-signature-label">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
              Firma digital
            </div>
            <div class="kyc-signature-box" id="signatureBox">
              <canvas id="signatureCanvas" width="400" height="150" style="width:100%; height:auto; max-width:400px; touch-action: none; cursor: crosshair;" class="kyc-signature-canvas"></canvas>
              <div class="kyc-signature-hint" id="signatureHint">Toque o deslice para firmar</div>
            </div>
            <div class="kyc-signature-actions">
              <button type="button" id="clearSignature" class="kyc-signature-clear">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                Limpiar
              </button>
              <span class="kyc-signature-hint-text">Dedo o mouse</span>
            </div>
          </div>

          <!-- Checkbox -->
          <label class="kyc-checkbox-wrap anim-fade-up delay-5" id="checkboxWrap">
            <input type="checkbox" id="aceptoTerminos" class="kyc-checkbox">
            <span class="kyc-checkbox-label">He leído y acepto la <strong>Declaración Jurada</strong>, los <strong>Términos y Condiciones</strong> y la <strong>Política de Privacidad</strong> de AD Global Services LLC.</span>
          </label>

          <!-- Verification Area -->
          <div id="verificationArea" class="kyc-verify-area anim-fade-up delay-6">
            <div class="kyc-verify-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
            </div>
            <h3>Luego sube tus fotos</h3>
            <p>Primero firma y acepta la declaración. Después tomarás una foto de tu cara y una de tu cédula.</p>
            <button id="startVerificationBtn" class="kyc-btn kyc-btn-primary">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><line x1="9" y1="15" x2="15" y2="15"/></svg>
              Continuar a fotos
            </button>
            <div class="kyc-expiry" style="margin-top:0.875rem; margin-bottom:0;">
              <p>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                Tiempo estimado: 2 minutos
              </p>
            </div>
          </div>

          <!-- Security Badge -->
          <div class="kyc-security anim-fade-up delay-6">
            <div class="kyc-security-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <div class="kyc-security-text">
              <p>Tu información está segura</p>
              <span>La revisión la realiza manualmente el equipo de AD Global Pay</span>
            </div>
          </div>

          <!-- Expiry -->
          <div class="kyc-expiry anim-fade-up delay-6">
            <p>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              Este enlace expira en 7 días
            </p>
          </div>
        </div>
      </div>

      <!-- Footer -->
      <div class="kyc-footer">
        <p>¿Problemas? <a href="mailto:soporte@adglobalpay.com">Contacta soporte</a></p>
        <div class="kyc-footer-badges">
          <span class="kyc-footer-badge">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            Datos encriptados
          </span>
          <span class="kyc-footer-badge">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            Cumple KYC/AML
          </span>
          <span class="kyc-footer-badge">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            Proceso seguro
          </span>
        </div>
      </div>
    </div>

  </main>

  <script is:inline>
    (function() {
      var params = new URLSearchParams(window.location.search);
      var token = params.get('token');
      var API_URL = window.__ADGLOBAL_API_URL__ || 'https://backend-global-production.up.railway.app';

      var noTokenEl = document.getElementById('noTokenState');
      var kycContentEl = document.getElementById('kycContent');
      var loadingEl = document.getElementById('loadingState');
      var mainEl = document.getElementById('mainContent');

      if (!token) {
        if (noTokenEl) noTokenEl.classList.remove('hidden');
        return;
      }

      if (kycContentEl) kycContentEl.classList.remove('hidden');

      var signatureIsEmpty = true;
      var signatureData = '';
      var selfieData = '';
      var idFrontData = '';
      var canvas = null;
      var ctx = null;

      function setInvalidState(message) {
        if (kycContentEl) kycContentEl.classList.add('hidden');
        if (noTokenEl) {
          var paragraph = noTokenEl.querySelector('p');
          if (paragraph) paragraph.textContent = message || 'El enlace de verificación no es válido o ha expirado. Solicita uno nuevo desde tu cuenta.';
          noTokenEl.classList.remove('hidden');
        }
      }

      function setStep(step) {
        var heroText = document.getElementById('heroStepText');
        if (heroText) heroText.textContent = 'Paso ' + step + ' de 3';

        var circle1 = document.getElementById('stepCircle1');
        var circle2 = document.getElementById('stepCircle2');
        var circle3 = document.getElementById('stepCircle3');
        var line1 = document.getElementById('stepLine1');
        var line2 = document.getElementById('stepLine2');
        var check = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';

        if (circle1) {
          circle1.className = step > 1 ? 'kyc-step-circle done' : 'kyc-step-circle active';
          circle1.innerHTML = step > 1 ? check : check;
        }
        if (circle2) {
          circle2.className = step > 2 ? 'kyc-step-circle done' : step === 2 ? 'kyc-step-circle active' : 'kyc-step-circle pending';
          circle2.innerHTML = step > 2 ? check : '2';
        }
        if (circle3) {
          circle3.className = step === 3 ? 'kyc-step-circle active' : 'kyc-step-circle pending';
          circle3.innerHTML = '3';
        }
        if (line1) line1.style.width = step > 1 ? '100%' : '0%';
        if (line2) line2.style.width = step > 2 ? '100%' : '0%';
      }

      function showExistingStatus(status) {
        setStep(3);
        var area = document.getElementById('verificationArea');
        if (!area) return;
        var approved = status === 'VERIFIED';
        area.innerHTML =
          '<div class="kyc-success-icon">' +
            '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>' +
          '</div>' +
          '<h3>' + (approved ? 'Identidad verificada' : 'Verificación enviada') + '</h3>' +
          '<p>' + (approved ? 'Tu identidad ya fue aprobada por AD Global Pay.' : 'Recibimos tus datos. El equipo revisará tu firma, selfie y cédula manualmente.') + '</p>' +
          '<a href="/kyc/completado" class="kyc-btn kyc-btn-success">Continuar</a>';
      }

      function loadKyc() {
        fetch(API_URL + '/api/kyc/public/' + encodeURIComponent(token))
          .then(function(res) {
            return res.json().then(function(data) {
              if (!res.ok) throw new Error(data && data.error ? data.error : 'No se pudo cargar la solicitud KYC');
              return data;
            });
          })
          .then(function(data) {
            var fullName = [data.client && data.client.firstName, data.client && data.client.lastName].filter(Boolean).join(' ');
            var clientName = document.getElementById('clientName');
            var clientEmail = document.getElementById('clientEmail');
            if (clientName) clientName.textContent = fullName || 'Cliente AD Global Pay';
            if (clientEmail) clientEmail.textContent = (data.client && data.client.email) || 'Solicitud de verificación';
            if (loadingEl) loadingEl.classList.add('hidden');
            if (mainEl) mainEl.classList.remove('hidden');
            if (data.status === 'PROCESSING' || data.status === 'VERIFIED') {
              showExistingStatus(data.status);
            }
          })
          .catch(function(err) {
            setInvalidState(err.message);
          });
      }

      function initSignatureCanvas() {
        canvas = document.getElementById('signatureCanvas');
        if (!canvas) return;

        ctx = canvas.getContext('2d');
        ctx.strokeStyle = '#1e293b';
        ctx.lineWidth = 2.5;
        ctx.lineCap = 'round';
        ctx.lineJoin = 'round';

        var drawing = false;
        var lastX = 0, lastY = 0;

        function getCoordinates(e) {
          var rect = canvas.getBoundingClientRect();
          var scaleX = canvas.width / rect.width;
          var scaleY = canvas.height / rect.height;

          var clientX, clientY;
          if (e.touches && e.touches.length > 0) {
            clientX = e.touches[0].clientX;
            clientY = e.touches[0].clientY;
          } else {
            clientX = e.clientX;
            clientY = e.clientY;
          }

          var x = (clientX - rect.left) * scaleX;
          var y = (clientY - rect.top) * scaleY;
          if (x < 0) x = 0;
          if (x > canvas.width) x = canvas.width;
          if (y < 0) y = 0;
          if (y > canvas.height) y = canvas.height;
          return { x: x, y: y };
        }

        function startDrawing(e) {
          e.preventDefault();
          drawing = true;
          var coords = getCoordinates(e);
          lastX = coords.x;
          lastY = coords.y;
          ctx.beginPath();
          ctx.moveTo(lastX, lastY);
          ctx.lineTo(lastX, lastY);
          ctx.stroke();
          signatureIsEmpty = false;
          document.getElementById('signatureBox').classList.add('drawing');
          document.getElementById('signatureHint').style.opacity = '0';
        }

        function draw(e) {
          e.preventDefault();
          if (!drawing) return;
          var coords = getCoordinates(e);
          ctx.beginPath();
          ctx.moveTo(lastX, lastY);
          ctx.lineTo(coords.x, coords.y);
          ctx.stroke();
          lastX = coords.x;
          lastY = coords.y;
        }

        function stopDrawing(e) {
          if (e) e.preventDefault();
          drawing = false;
        }

        canvas.addEventListener('mousedown', startDrawing);
        canvas.addEventListener('mousemove', draw);
        canvas.addEventListener('mouseup', stopDrawing);
        canvas.addEventListener('mouseleave', stopDrawing);
        canvas.addEventListener('touchstart', startDrawing, { passive: false });
        canvas.addEventListener('touchmove', draw, { passive: false });
        canvas.addEventListener('touchend', stopDrawing, { passive: false });
        canvas.addEventListener('touchcancel', stopDrawing, { passive: false });

        var clearBtn = document.getElementById('clearSignature');
        if (clearBtn) {
          clearBtn.addEventListener('click', function() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            ctx.fillStyle = 'white';
            ctx.fillRect(0, 0, canvas.width, canvas.height);
            ctx.strokeStyle = '#1e293b';
            signatureIsEmpty = true;
            document.getElementById('signatureBox').classList.remove('drawing');
            document.getElementById('signatureHint').style.opacity = '1';
          });
        }

        ctx.fillStyle = 'white';
        ctx.fillRect(0, 0, canvas.width, canvas.height);
        ctx.strokeStyle = '#1e293b';
      }

      var checkbox = document.getElementById('aceptoTerminos');
      var checkboxWrap = document.getElementById('checkboxWrap');
      if (checkbox && checkboxWrap) {
        checkbox.addEventListener('change', function() {
          checkboxWrap.classList.toggle('checked', this.checked);
        });
      }

      function compressImage(file) {
        return new Promise(function(resolve, reject) {
          if (!file || !file.type || !file.type.startsWith('image/')) {
            reject(new Error('Solo se aceptan imagenes'));
            return;
          }
          var reader = new FileReader();
          reader.onload = function() {
            var img = new Image();
            img.onload = function() {
              var maxSize = 1280;
              var width = img.width;
              var height = img.height;
              if (width > height && width > maxSize) {
                height = Math.round((height * maxSize) / width);
                width = maxSize;
              } else if (height > maxSize) {
                width = Math.round((width * maxSize) / height);
                height = maxSize;
              }
              var out = document.createElement('canvas');
              out.width = width;
              out.height = height;
              var outCtx = out.getContext('2d');
              outCtx.fillStyle = '#fff';
              outCtx.fillRect(0, 0, width, height);
              outCtx.drawImage(img, 0, 0, width, height);
              resolve(out.toDataURL('image/jpeg', 0.84));
            };
            img.onerror = function() { reject(new Error('No se pudo leer la imagen')); };
            img.src = reader.result;
          };
          reader.onerror = function() { reject(new Error('No se pudo leer el archivo')); };
          reader.readAsDataURL(file);
        });
      }

      function updateUploadCard(cardId, previewId, dataUrl) {
        var card = document.getElementById(cardId);
        var preview = document.getElementById(previewId);
        if (card) card.classList.add('ready');
        if (preview) preview.innerHTML = '<img src="' + dataUrl + '" alt="">';
        var action = card ? card.querySelector('.kyc-upload-action') : null;
        if (action) action.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
      }

      function renderUploadStep() {
        setStep(2);
        var area = document.getElementById('verificationArea');
        if (!area) return;

        area.innerHTML =
          '<div class="kyc-verify-icon">' +
            '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>' +
          '</div>' +
          '<h3>Sube tus fotos</h3>' +
          '<p>Usa buena luz. La cédula debe verse completa y legible.</p>' +
          '<div class="kyc-upload-grid">' +
            '<label class="kyc-upload-card" id="selfieCard">' +
              '<input id="selfieInput" type="file" accept="image/*" capture="user" class="hidden">' +
              '<span class="kyc-upload-preview" id="selfiePreview"><span class="kyc-upload-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h3l2-3h8l2 3h3a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg></span></span>' +
              '<span class="kyc-upload-text" style="display:flex;flex-direction:column;gap:0.15rem;"><strong style="display:block;line-height:1.25;">Foto de tu cara</strong><span style="display:block;line-height:1.35;">Selfie frontal, sin lentes oscuros ni filtros.</span><span class="kyc-upload-hint"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg> Toca para subir</span></span>' +
              '<span class="kyc-upload-action"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg></span>' +
            '</label>' +
            '<label class="kyc-upload-card" id="idCard">' +
              '<input id="idFrontInput" type="file" accept="image/*" capture="environment" class="hidden">' +
              '<span class="kyc-upload-preview" id="idPreview"><span class="kyc-upload-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="5" rx="2"/><circle cx="8" cy="12" r="2"/><path d="M14 10h4"/><path d="M14 14h4"/></svg></span></span>' +
              '<span class="kyc-upload-text" style="display:flex;flex-direction:column;gap:0.15rem;"><strong style="display:block;line-height:1.25;">Foto de tu cédula</strong><span style="display:block;line-height:1.35;">Documento completo, enfocado y sin reflejos.</span><span class="kyc-upload-hint"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg> Toca para subir</span></span>' +
              '<span class="kyc-upload-action"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg></span>' +
            '</label>' +
          '</div>' +
          '<div id="uploadError" class="kyc-alert hidden"></div>' +
          '<button id="submitKycBtn" class="kyc-btn kyc-btn-primary">Enviar para revisión</button>';

        var selfieInput = document.getElementById('selfieInput');
        var idInput = document.getElementById('idFrontInput');
        var submitBtn = document.getElementById('submitKycBtn');
        var uploadError = document.getElementById('uploadError');

        function setUploadError(message) {
          if (!uploadError) return;
          uploadError.textContent = message;
          uploadError.classList.toggle('hidden', !message);
        }

        selfieInput.addEventListener('change', function(e) {
          setUploadError('');
          compressImage(e.target.files[0])
            .then(function(dataUrl) {
              selfieData = dataUrl;
              updateUploadCard('selfieCard', 'selfiePreview', dataUrl);
            })
            .catch(function(err) { setUploadError(err.message); });
        });

        idInput.addEventListener('change', function(e) {
          setUploadError('');
          compressImage(e.target.files[0])
            .then(function(dataUrl) {
              idFrontData = dataUrl;
              updateUploadCard('idCard', 'idPreview', dataUrl);
            })
            .catch(function(err) { setUploadError(err.message); });
        });

        submitBtn.addEventListener('click', function() {
          if (!selfieData || !idFrontData) {
            setUploadError('Debes subir la foto de tu cara y la foto de tu cédula.');
            return;
          }

          submitBtn.disabled = true;
          submitBtn.innerHTML = '<div style="width:20px;height:20px;border:2px solid white;border-top-color:transparent;border-radius:50%;animation:spin 1s linear infinite;margin:0 auto;"></div>';
          setUploadError('');

          fetch(API_URL + '/api/kyc/public/' + encodeURIComponent(token) + '/submit', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              acceptedTerms: true,
              signature: signatureData,
              selfie: selfieData,
              idFront: idFrontData
            })
          })
            .then(function(res) {
              return res.json().then(function(data) {
                if (!res.ok) throw new Error(data && data.error ? data.error : 'No se pudo enviar la verificacion');
                return data;
              });
            })
            .then(function() {
              setStep(3);
              area.innerHTML =
                '<div class="kyc-success-icon">' +
                  '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>' +
                '</div>' +
                '<h3>¡Verificación enviada!</h3>' +
                '<p>Recibimos tu firma, selfie y cédula. El equipo de AD Global Pay revisará tus datos manualmente.</p>' +
                '<a href="/kyc/completado" class="kyc-btn kyc-btn-success">Continuar</a>';
            })
            .catch(function(err) {
              submitBtn.disabled = false;
              submitBtn.textContent = 'Enviar para revisión';
              setUploadError(err.message);
            });
        });
      }

      var startBtn = document.getElementById('startVerificationBtn');
      if (startBtn) {
        startBtn.addEventListener('click', function() {
          var acepta = document.getElementById('aceptoTerminos');
          var canvasEl = document.getElementById('signatureCanvas');

          if (!acepta || !acepta.checked) {
            alert('Debes aceptar los términos y condiciones y la declaración jurada para continuar.');
            return;
          }

          if (signatureIsEmpty) {
            alert('Debes firmar la declaración jurada para continuar.');
            return;
          }

          signatureData = canvasEl.toDataURL('image/png');
          renderUploadStep();
        });
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initSignatureCanvas);
      } else {
        initSignatureCanvas();
      }

      loadKyc();
    })();
  </script>
</body>
</html>
