---
// Página de verificación KYC completada
// Diseño premium alineado con la identidad visual de AD Global Pay
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes, viewport-fit=cover">
  <title>Estado de Verificación — AD Global Pay</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="icon" href="/img/logo.webp" type="image/webp" />
  <style>
    :root {
      --font-heading: 'Outfit', sans-serif;
      --font-body: 'DM Sans', sans-serif;
      --font-mono: 'JetBrains Mono', monospace;
      --indigo: #6366f1;
      --indigo-light: #818cf8;
      --indigo-dark: #4f46e5;
      --indigo-50: #eef2ff;
      --indigo-100: #e0e7ff;
      --indigo-200: #c7d2fe;
      --cyan: #06b6d4;
      --emerald: #10b981;
      --emerald-50: #ecfdf5;
      --emerald-100: #d1fae5;
      --emerald-200: #a7f3d0;
      --slate-50: #f8fafc;
      --slate-100: #f1f5f9;
      --slate-200: #e2e8f0;
      --slate-300: #cbd5e1;
      --slate-400: #94a3b8;
      --slate-500: #64748b;
      --slate-600: #475569;
      --slate-700: #334155;
      --slate-800: #1e293b;
      --slate-900: #0f172a;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: var(--font-body);
      background: linear-gradient(165deg, var(--slate-50) 0%, #f0f4ff 35%, #e8f4fd 70%, #f0fdf4 100%);
      min-height: 100vh;
      color: var(--slate-800);
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      overflow-x: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1.5rem;
      position: relative;
    }

    /* ===== ANIMATIONS ===== */
    @keyframes fadeInUp {
      from { opacity: 0; transform: translateY(28px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes fadeInScale {
      from { opacity: 0; transform: scale(0.92); }
      to { opacity: 1; transform: scale(1); }
    }
    @keyframes gentleFloat {
      0%, 100% { transform: translateY(0px); }
      50% { transform: translateY(-6px); }
    }
    @keyframes drawCheck {
      0% { stroke-dashoffset: 30; }
      100% { stroke-dashoffset: 0; }
    }
    @keyframes shimmer {
      0% { background-position: -200% center; }
      100% { background-position: 200% center; }
    }
    @keyframes orbit {
      0% { transform: rotate(0deg) translateX(120px) rotate(0deg); }
      100% { transform: rotate(360deg) translateX(120px) rotate(-360deg); }
    }
    @keyframes pulse-glow {
      0%, 100% { box-shadow: 0 0 0 0 rgba(255, 255, 255, 0.4); }
      50% { box-shadow: 0 0 0 12px rgba(255, 255, 255, 0); }
    }

    .anim-fade-up {
      animation: fadeInUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      opacity: 0;
    }
    .anim-scale-in {
      animation: fadeInScale 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      opacity: 0;
    }
    .delay-1 { animation-delay: 0.08s; }
    .delay-2 { animation-delay: 0.18s; }
    .delay-3 { animation-delay: 0.30s; }
    .delay-4 { animation-delay: 0.42s; }
    .delay-5 { animation-delay: 0.54s; }
    .delay-6 { animation-delay: 0.66s; }

    /* ===== BACKGROUND ORBS ===== */
    .bg-decoration {
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 0;
      overflow: hidden;
    }
    .orb {
      position: absolute;
      border-radius: 50%;
      filter: blur(80px);
      opacity: 0.5;
      animation: gentleFloat 8s ease-in-out infinite;
    }
    .orb-1 {
      top: -10%;
      right: -5%;
      width: 500px;
      height: 500px;
      background: radial-gradient(circle, rgba(99, 102, 241, 0.18) 0%, transparent 70%);
      animation-delay: 0s;
    }
    .orb-2 {
      bottom: -15%;
      left: -10%;
      width: 450px;
      height: 450px;
      background: radial-gradient(circle, rgba(6, 182, 212, 0.14) 0%, transparent 70%);
      animation-delay: -3s;
    }
    .orb-3 {
      top: 40%;
      left: 50%;
      transform: translateX(-50%);
      width: 300px;
      height: 300px;
      background: radial-gradient(circle, rgba(16, 185, 129, 0.10) 0%, transparent 70%);
      animation-delay: -5s;
    }

    /* ===== NOISE TEXTURE OVERLAY ===== */
    .noise-overlay {
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 1;
      opacity: 0.025;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
      background-repeat: repeat;
      background-size: 256px 256px;
    }

    /* ===== MAIN CARD ===== */
    .kyc-card {
      position: relative;
      z-index: 10;
      max-width: 440px;
      width: 100%;
      background: rgba(255, 255, 255, 0.88);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid rgba(226, 232, 240, 0.65);
      border-radius: 28px;
      box-shadow:
        0 2px 8px rgba(15, 23, 42, 0.04),
        0 8px 24px rgba(15, 23, 42, 0.04),
        0 24px 60px -16px rgba(15, 23, 42, 0.08),
        inset 0 1px 0 rgba(255, 255, 255, 0.6);
      overflow: hidden;
      text-align: center;
    }

    /* ===== HERO SECTION ===== */
    .kyc-hero {
      position: relative;
      padding: 3.5rem 2rem 3rem;
      background: linear-gradient(135deg, var(--indigo) 0%, var(--indigo-dark) 50%, #3730a3 100%);
      overflow: hidden;
    }
    .kyc-hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse 80% 50% at 20% 40%, rgba(255,255,255,0.08) 0%, transparent 50%),
        radial-gradient(ellipse 60% 60% at 80% 20%, rgba(99, 102, 241, 0.3) 0%, transparent 50%);
    }
    .kyc-hero::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
    }
    .kyc-hero.success-state {
      background: linear-gradient(135deg, var(--emerald) 0%, #059669 50%, #047857 100%);
    }
    .kyc-hero.success-state::before {
      background:
        radial-gradient(ellipse 80% 50% at 20% 40%, rgba(255,255,255,0.08) 0%, transparent 50%),
        radial-gradient(ellipse 60% 60% at 80% 20%, rgba(16, 185, 129, 0.3) 0%, transparent 50%);
    }

    /* Floating particles in hero */
    .particle {
      position: absolute;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.1);
      animation: gentleFloat 6s ease-in-out infinite;
    }
    .particle-1 { width: 6px; height: 6px; top: 20%; left: 15%; animation-delay: 0s; }
    .particle-2 { width: 4px; height: 4px; top: 60%; right: 20%; animation-delay: -2s; }
    .particle-3 { width: 8px; height: 8px; top: 30%; right: 30%; animation-delay: -4s; }
    .particle-4 { width: 3px; height: 3px; bottom: 25%; left: 25%; animation-delay: -1s; }

    /* Icon wrap */
    .kyc-icon-wrap {
      position: relative;
      z-index: 2;
      width: 88px;
      height: 88px;
      margin: 0 auto 1.75rem;
      border-radius: 26px;
      background: rgba(255, 255, 255, 0.12);
      border: 1px solid rgba(255, 255, 255, 0.2);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      display: flex;
      align-items: center;
      justify-content: center;
      animation: gentleFloat 5s ease-in-out infinite;
      box-shadow:
        0 8px 32px -8px rgba(0, 0, 0, 0.2),
        inset 0 1px 0 rgba(255, 255, 255, 0.15);
    }
    .kyc-icon-wrap::before {
      content: '';
      position: absolute;
      inset: -5px;
      border-radius: 31px;
      border: 2px solid rgba(255, 255, 255, 0.08);
      animation: pulse-glow 3s ease-out infinite;
    }
    .kyc-icon-wrap svg {
      width: 40px;
      height: 40px;
      color: white;
      stroke-dasharray: 30;
      stroke-dashoffset: 30;
      animation: drawCheck 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.4s forwards;
    }

    /* Hero text */
    .kyc-hero h1 {
      position: relative;
      z-index: 2;
      font-family: var(--font-heading);
      font-size: 1.625rem;
      font-weight: 800;
      color: white;
      letter-spacing: -0.025em;
      line-height: 1.15;
      margin-bottom: 0.625rem;
    }
    .kyc-hero p {
      position: relative;
      z-index: 2;
      font-size: 0.9375rem;
      color: rgba(255, 255, 255, 0.72);
      font-weight: 500;
      line-height: 1.5;
      max-width: 280px;
      margin: 0 auto;
    }

    /* Status badge in hero */
    .hero-status-badge {
      position: relative;
      z-index: 2;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      margin-top: 1.25rem;
      padding: 0.375rem 0.875rem;
      background: rgba(255, 255, 255, 0.1);
      border: 1px solid rgba(255, 255, 255, 0.15);
      border-radius: 999px;
      font-size: 0.75rem;
      font-weight: 700;
      color: rgba(255, 255, 255, 0.9);
      letter-spacing: 0.02em;
      backdrop-filter: blur(8px);
    }
    .hero-status-badge .dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.9);
      box-shadow: 0 0 8px rgba(255, 255, 255, 0.4);
    }
    .hero-status-badge .dot.pulse {
      animation: pulse-glow 2s ease-out infinite;
    }

    /* ===== CONTENT SECTION ===== */
    .kyc-content {
      padding: 2rem 1.75rem 1.75rem;
    }

    /* Progress steps */
    .progress-steps {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0;
      margin-bottom: 1.75rem;
      padding: 0 0.5rem;
    }
    .step {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.375rem;
      flex: 1;
      position: relative;
    }
    .step-circle {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--font-heading);
      font-size: 0.75rem;
      font-weight: 700;
      position: relative;
      z-index: 2;
    }
    .step-circle.completed {
      background: linear-gradient(135deg, var(--emerald) 0%, #059669 100%);
      color: white;
      box-shadow: 0 2px 8px rgba(16, 185, 129, 0.3);
    }
    .step-circle.active {
      background: white;
      border: 2px solid var(--indigo);
      color: var(--indigo);
      box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.1);
    }
    .step-circle.pending {
      background: var(--slate-100);
      border: 2px solid var(--slate-200);
      color: var(--slate-400);
    }
    .step-label {
      font-size: 0.65rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--slate-500);
    }
    .step-label.active { color: var(--indigo); }
    .step-label.completed { color: var(--emerald); }
    .step-connector {
      flex: 1;
      height: 2px;
      background: var(--slate-200);
      margin: 0 0.25rem;
      margin-bottom: 1.25rem;
      position: relative;
      overflow: hidden;
      border-radius: 1px;
    }
    .step-connector.completed {
      background: linear-gradient(90deg, var(--emerald) 0%, #059669 100%);
    }
    .step-connector.active::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(90deg, var(--emerald) 0%, var(--indigo) 100%);
      transform: translateX(-100%);
      animation: shimmer 2s ease-in-out infinite;
    }

    /* ===== DETAIL ITEMS ===== */
    .kyc-details {
      display: flex;
      flex-direction: column;
      gap: 0.875rem;
      margin-bottom: 1.75rem;
    }
    .kyc-detail-item {
      display: flex;
      align-items: flex-start;
      gap: 1rem;
      padding: 1rem 1.125rem;
      background: linear-gradient(135deg, var(--slate-50) 0%, rgba(255,255,255,0.8) 100%);
      border: 1px solid rgba(226, 232, 240, 0.7);
      border-radius: 16px;
      text-align: left;
      transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
      position: relative;
      overflow: hidden;
    }
    .kyc-detail-item::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0;
      bottom: 0;
      width: 3px;
      background: transparent;
      transition: background 0.35s ease;
      border-radius: 0 2px 2px 0;
    }
    .kyc-detail-item:hover {
      border-color: rgba(99, 102, 241, 0.25);
      box-shadow: 0 4px 16px -4px rgba(99, 102, 241, 0.1);
      transform: translateY(-1px);
    }
    .kyc-detail-item:hover::before {
      background: linear-gradient(180deg, var(--indigo) 0%, var(--indigo-light) 100%);
    }
    .kyc-detail-item.success:hover {
      border-color: rgba(16, 185, 129, 0.25);
      box-shadow: 0 4px 16px -4px rgba(16, 185, 129, 0.1);
    }
    .kyc-detail-item.success:hover::before {
      background: linear-gradient(180deg, var(--emerald) 0%, #34d399 100%);
    }

    .kyc-detail-icon {
      width: 40px;
      height: 40px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      position: relative;
    }
    .kyc-detail-icon::after {
      content: '';
      position: absolute;
      inset: -2px;
      border-radius: 14px;
      opacity: 0.15;
      filter: blur(6px);
    }
    .kyc-detail-icon.success {
      background: linear-gradient(135deg, var(--emerald) 0%, #059669 100%);
      box-shadow: 0 4px 12px -2px rgba(16, 185, 129, 0.35);
    }
    .kyc-detail-icon.success::after {
      background: var(--emerald);
    }
    .kyc-detail-icon.review {
      background: linear-gradient(135deg, var(--indigo) 0%, var(--indigo-dark) 100%);
      box-shadow: 0 4px 12px -2px rgba(99, 102, 241, 0.35);
    }
    .kyc-detail-icon.review::after {
      background: var(--indigo);
    }
    .kyc-detail-icon.info {
      background: linear-gradient(135deg, var(--indigo) 0%, var(--indigo-dark) 100%);
      box-shadow: 0 4px 12px -2px rgba(99, 102, 241, 0.35);
    }
    .kyc-detail-icon.info::after {
      background: var(--indigo);
    }
    .kyc-detail-icon svg {
      width: 20px;
      height: 20px;
      color: white;
    }

    .kyc-detail-text {
      flex: 1;
      min-width: 0;
    }
    .kyc-detail-text p {
      font-family: var(--font-heading);
      font-weight: 700;
      font-size: 0.9rem;
      color: var(--slate-800);
      line-height: 1.35;
      margin-bottom: 0.25rem;
    }
    .kyc-detail-text span {
      font-size: 0.8125rem;
      color: var(--slate-500);
      font-weight: 500;
      line-height: 1.4;
      display: block;
    }

    /* ===== BUTTONS ===== */
    .kyc-buttons {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      margin-bottom: 1.5rem;
    }
    .kyc-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      width: 100%;
      padding: 0.9375rem 1.5rem;
      font-family: var(--font-heading);
      font-size: 0.9rem;
      font-weight: 700;
      border: none;
      border-radius: 14px;
      cursor: pointer;
      transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
      position: relative;
      overflow: hidden;
      text-decoration: none;
      letter-spacing: -0.01em;
    }
    .kyc-btn::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.15), transparent);
      transform: translateX(-100%);
      transition: transform 0.6s ease;
    }
    .kyc-btn:hover::before {
      transform: translateX(100%);
    }
    .kyc-btn-primary {
      background: linear-gradient(135deg, var(--indigo) 0%, var(--indigo-dark) 100%);
      color: white;
      box-shadow: 0 4px 16px -4px rgba(99, 102, 241, 0.4), 0 2px 4px -2px rgba(99, 102, 241, 0.2);
    }
    .kyc-btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 24px -4px rgba(99, 102, 241, 0.5), 0 4px 8px -2px rgba(99, 102, 241, 0.25);
    }
    .kyc-btn-primary:active {
      transform: translateY(0);
    }
    .kyc-btn-secondary {
      background: white;
      color: var(--slate-600);
      border: 1.5px solid var(--slate-200);
      box-shadow: 0 1px 3px rgba(15, 23, 42, 0.04);
    }
    .kyc-btn-secondary:hover {
      border-color: var(--slate-300);
      background: var(--slate-50);
      transform: translateY(-1px);
      box-shadow: 0 4px 12px -4px rgba(15, 23, 42, 0.08);
    }
    .kyc-btn svg {
      width: 18px;
      height: 18px;
      flex-shrink: 0;
    }

    /* ===== FOOTER ===== */
    .kyc-footer {
      text-align: center;
      padding-top: 1rem;
      border-top: 1px solid rgba(226, 232, 240, 0.5);
    }
    .kyc-footer p {
      font-size: 0.8125rem;
      color: var(--slate-500);
      font-weight: 500;
      line-height: 1.5;
    }
    .kyc-footer a {
      color: var(--indigo);
      font-weight: 700;
      text-decoration: none;
      position: relative;
      transition: color 0.2s ease;
    }
    .kyc-footer a::after {
      content: '';
      position: absolute;
      bottom: -1px;
      left: 0;
      width: 100%;
      height: 1px;
      background: currentColor;
      transform: scaleX(0);
      transform-origin: right;
      transition: transform 0.3s ease;
    }
    .kyc-footer a:hover {
      color: var(--indigo-dark);
    }
    .kyc-footer a:hover::after {
      transform: scaleX(1);
      transform-origin: left;
    }

    /* ===== SECURITY BADGE ===== */
    .security-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      margin-top: 1rem;
      padding: 0.5rem 1rem;
      background: linear-gradient(135deg, var(--slate-50) 0%, white 100%);
      border: 1px solid rgba(226, 232, 240, 0.7);
      border-radius: 999px;
      font-size: 0.6875rem;
      font-weight: 700;
      color: var(--slate-500);
      letter-spacing: 0.02em;
    }
    .security-badge svg {
      width: 14px;
      height: 14px;
      color: var(--emerald);
    }

    /* ===== RESPONSIVE ===== */
    @media (max-width: 480px) {
      body { padding: 1rem; }
      .kyc-card { border-radius: 24px; }
      .kyc-hero { padding: 2.75rem 1.5rem 2.5rem; }
      .kyc-hero h1 { font-size: 1.375rem; }
      .kyc-hero p { font-size: 0.875rem; }
      .kyc-content { padding: 1.5rem 1.25rem 1.5rem; }
      .kyc-icon-wrap { width: 76px; height: 76px; border-radius: 22px; }
      .kyc-icon-wrap svg { width: 36px; height: 36px; }
      .step-label { font-size: 0.6rem; }
      .step-circle { width: 28px; height: 28px; font-size: 0.7rem; }
    }

    @media (max-width: 360px) {
      .kyc-hero { padding: 2.25rem 1.25rem 2rem; }
      .kyc-content { padding: 1.25rem 1rem 1.25rem; }
      .kyc-hero h1 { font-size: 1.25rem; }
    }
  </style>
</head>
<body>
  <div class="bg-decoration">
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>
  </div>
  <div class="noise-overlay"></div>

  <div class="kyc-card anim-scale-in delay-1">
    <!-- Hero -->
    <div class="kyc-hero" id="heroSection">
      <div class="particle particle-1"></div>
      <div class="particle particle-2"></div>
      <div class="particle particle-3"></div>
      <div class="particle particle-4"></div>

      <div class="kyc-icon-wrap" id="heroIconWrap">
        <svg id="heroIcon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
      </div>
      <h1 id="heroTitle">Verificación en revisión</h1>
      <p id="heroSubtitle">Recibimos tus datos y nuestro equipo los revisará manualmente</p>
      <div class="hero-status-badge" id="heroBadge">
        <span class="dot pulse" id="heroBadgeDot"></span>
        <span id="heroBadgeText">En proceso</span>
      </div>
    </div>

    <!-- Content -->
    <div class="kyc-content">
      <!-- Progress Steps -->
      <div class="progress-steps anim-fade-up delay-2" id="progressSteps">
        <div class="step">
          <div class="step-circle completed" id="step1Circle">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <span class="step-label completed" id="step1Label">Datos</span>
        </div>
        <div class="step-connector completed" id="connector1"></div>
        <div class="step">
          <div class="step-circle active" id="step2Circle">2</div>
          <span class="step-label active" id="step2Label">Revisión</span>
        </div>
        <div class="step-connector" id="connector2"></div>
        <div class="step">
          <div class="step-circle pending" id="step3Circle">3</div>
          <span class="step-label" id="step3Label">Aprobado</span>
        </div>
      </div>

      <!-- Details -->
      <div class="kyc-details">
        <div class="kyc-detail-item anim-fade-up delay-3" id="statusDetailItem">
          <div class="kyc-detail-icon review" id="statusIconBox">
            <svg id="statusIcon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <polyline points="12 6 12 12 16 14"/>
            </svg>
          </div>
          <div class="kyc-detail-text">
            <p id="statusTitle">Verificación en revisión</p>
            <span id="statusDescription">Tu solicitud fue enviada correctamente y está siendo evaluada por nuestro equipo</span>
          </div>
        </div>
        <div class="kyc-detail-item anim-fade-up delay-4">
          <div class="kyc-detail-icon info">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
          </div>
          <div class="kyc-detail-text">
            <p id="emailTitle">Confirmación por email</p>
            <span id="emailDescription">Recibirás una actualización en tu correo electrónico cuando finalice el proceso</span>
          </div>
        </div>
      </div>

      <!-- Buttons -->
      <div class="kyc-buttons">
        <a href="/" class="kyc-btn kyc-btn-primary anim-fade-up delay-5">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
            <polyline points="9 22 9 12 15 12 15 22"/>
          </svg>
          Volver al inicio
        </a>
      </div>

      <!-- Footer -->
      <div class="kyc-footer anim-fade-up delay-6">
        <p>¿Necesitas ayuda? Escríbenos a <a href="mailto:soporte@adglobalpay.com">soporte@adglobalpay.com</a></p>
        <div class="security-badge">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          </svg>
          Verificación segura y encriptada
        </div>
      </div>
    </div>
  </div>

  <script>
    (function() {
      function getStatusConfig() {
        var params = new URLSearchParams(window.location.search);
        var status = (params.get('status') || 'processing').toUpperCase();

        if (status === 'VERIFIED') {
          return {
            title: 'Verificación completada',
            subtitle: 'Tu identidad ha sido verificada correctamente',
            statusTitle: 'Verificación aprobada',
            statusDescription: 'Tu identidad fue confirmada y validada por nuestro equipo',
            emailDescription: 'Recibirás un resumen completo en tu correo electrónico',
            heroClass: 'success',
            badgeText: 'Completado',
            badgeDotClass: '',
            icon: '<polyline points="20 6 9 17 4 12"/>',
            iconViewBox: '0 0 24 24',
            strokeWidth: '2.5',
            step2State: 'completed',
            step3State: 'completed',
            connector2State: 'completed'
          };
        }

        return {
          title: 'Verificación en revisión',
          subtitle: 'Recibimos tus datos y nuestro equipo los revisará manualmente',
          statusTitle: 'Documentos enviados',
          statusDescription: 'Tu solicitud está pendiente de revisión por nuestro equipo de verificación',
          emailDescription: 'Te avisaremos por correo cuando finalice la revisión',
          heroClass: 'review',
          badgeText: 'En proceso',
          badgeDotClass: 'pulse',
          icon: '<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>',
          iconViewBox: '0 0 24 24',
          strokeWidth: '2',
          step2State: 'active',
          step3State: 'pending',
          connector2State: 'active'
        };
      }

      function applyStatusCopy() {
        var config = getStatusConfig();

        // Hero text
        var heroTitle = document.getElementById('heroTitle');
        var heroSubtitle = document.getElementById('heroSubtitle');
        var statusTitle = document.getElementById('statusTitle');
        var statusDescription = document.getElementById('statusDescription');
        var emailDescription = document.getElementById('emailDescription');
        var hero = document.getElementById('heroSection');
        var heroIcon = document.getElementById('heroIcon');
        var statusIcon = document.getElementById('statusIcon');
        var statusIconBox = document.getElementById('statusIconBox');
        var statusDetailItem = document.getElementById('statusDetailItem');
        var heroBadgeText = document.getElementById('heroBadgeText');
        var heroBadgeDot = document.getElementById('heroBadgeDot');

        if (heroTitle) heroTitle.textContent = config.title;
        if (heroSubtitle) heroSubtitle.textContent = config.subtitle;
        if (statusTitle) statusTitle.textContent = config.statusTitle;
        if (statusDescription) statusDescription.textContent = config.statusDescription;
        if (emailDescription) emailDescription.textContent = config.emailDescription;
        if (heroBadgeText) heroBadgeText.textContent = config.badgeText;
        if (heroBadgeDot) {
          heroBadgeDot.className = 'dot ' + config.badgeDotClass;
          if (config.heroClass === 'success') {
            heroBadgeDot.style.background = 'rgba(255,255,255,0.9)';
            heroBadgeDot.style.boxShadow = '0 0 8px rgba(255,255,255,0.4)';
          }
        }

        // Hero gradient
        if (hero) {
          if (config.heroClass === 'success') {
            hero.classList.add('success-state');
          }
        }

        // Status detail item accent
        if (statusDetailItem) {
          if (config.heroClass === 'success') {
            statusDetailItem.classList.add('success');
          }
        }

        // Icons
        if (statusIconBox) {
          statusIconBox.classList.remove('success', 'review');
          statusIconBox.classList.add(config.heroClass);
        }

        if (heroIcon) {
          heroIcon.setAttribute('viewBox', config.iconViewBox);
          heroIcon.setAttribute('stroke-width', config.strokeWidth);
          heroIcon.innerHTML = config.icon;
        }

        if (statusIcon) {
          statusIcon.setAttribute('viewBox', config.iconViewBox);
          statusIcon.setAttribute('stroke-width', config.strokeWidth);
          statusIcon.innerHTML = config.icon;
        }

        // Progress steps
        var step2Circle = document.getElementById('step2Circle');
        var step2Label = document.getElementById('step2Label');
        var step3Circle = document.getElementById('step3Circle');
        var step3Label = document.getElementById('step3Label');
        var connector2 = document.getElementById('connector2');

        if (config.step2State === 'completed' && step2Circle) {
          step2Circle.className = 'step-circle completed';
          step2Circle.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
          if (step2Label) step2Label.className = 'step-label completed';
        }

        if (config.step3State === 'completed' && step3Circle) {
          step3Circle.className = 'step-circle completed';
          step3Circle.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
          if (step3Label) step3Label.className = 'step-label completed';
        }

        if (config.connector2State === 'completed' && connector2) {
          connector2.classList.add('completed');
          connector2.classList.remove('active');
        }
      }

      applyStatusCopy();
    })();
  </script>
</body>
</html>
