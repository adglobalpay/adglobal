---
const whatsappNumber = "14482045984";
const whatsappMessage = encodeURIComponent(
  "🌐 Hola Global Team me gustaria enviar transferir"
);
const waLink = `https://wa.me/${whatsappNumber}?text=${whatsappMessage}`;

const faqs = [
  {
    question: "¿Qué es PayPal?",
    answer: `PayPal es una <strong>plataforma de pagos en línea</strong> que permite <a href="https://www.paypal.com/" target="_blank" rel="noopener" class="underline">enviar y recibir dinero</a> de forma rápida y segura. Es ampliamente utilizada para <strong>compras y servicios internacionales</strong>, así como para transferencias entre particulares.`
  },
  
  {
    question: "¿Qué es Zelle?",
    answer: `<a href="https://www.zellepay.com/" target="_blank" rel="noopener" class="underline">Zelle</a> es un <strong>servicio de transferencia de dinero</strong> rápido y seguro que permite <strong>enviar y recibir fondos</strong> directamente entre cuentas bancarias en <strong>Estados Unidos</strong>.`
  },
  
  {
    question: "¿Qué métodos de pago aceptan?",
    answer: `<strong>Paypal</strong>, <strong>Zelle</strong>, <strong>ACH</strong>, <strong>Wire</strong>, <strong>depósitos bancarios</strong> y mas. Siempre te confirmamos antes de procesar cualquier transacción para garantizar seguridad y precisión en el pago.`
  },
  {
    question: "¿Cuánto tarda una operación?",
    answer: `Las operaciones suelen completarse en <strong>pocos minutos</strong> tras la confirmación, aunque pueden demorar más dependiendo del <strong>método de pago</strong>.`
  }
];
---

<!-- Encabezado con gradiente limitado -->
<section class="relative overflow-hidden text-white">
  <div class="mx-auto max-w-6xl px-4">
    <div class="rounded-2xl bg-gradient-to-r from-[#3227B5] via-[#4B44E7] to-[#5A4CF1] px-6 py-10 text-center">
      <h2 class="text-3xl sm:text-4xl font-extrabold tracking-tight">Preguntas frecuentes</h2>
      <p class="mt-3 text-blue-100">
        Dudas generales del servicio de <strong>cambios</strong>. Si tienes alguna pregunta adicional,
        <a href={waLink} target="_blank" rel="noopener" class="font-semibold underline">contáctanos por WhatsApp</a>.
      </p>
    </div>
  </div>
</section>

<!-- Cuerpo FAQs -->
<section class="bg-gray-50 py-12" id="preguntas-frecuentes">
  <div class="mx-auto max-w-5xl px-4">
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {faqs.map((faq) => (
        <details class="group bg-white rounded-2xl border border-slate-200 shadow-sm transition hover:bg-indigo-50/40 hover:shadow-md">
          <summary class="cursor-pointer select-none px-6 py-4 font-medium text-slate-800 flex justify-between items-center">
            <span class="pr-4">{faq.question}</span>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-slate-500 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <p class="px-6 pb-5 text-slate-600 leading-relaxed" set:html={faq.answer}></p>
          <div class="px-6 pb-5">
            <a href={waLink} target="_blank" rel="noopener" class="inline-flex items-center rounded-full bg-green-600 px-4 py-2 text-white text-xs font-semibold hover:opacity-90 transition">
              💬 Empezar
            </a>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
