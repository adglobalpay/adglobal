---
// src/layouts/AdminLayout.astro
import Sidebar from '../components/admin/Sidebar';
import ToastProvider from '../components/admin/ToastProvider';
import CustomSelectInit from '../components/CustomSelectInit.astro';

const API_URL = import.meta.env.VITE_API_URL || 'https://backend-global-production.up.railway.app';
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
  
  <link rel="icon" href="/img/logo.webp" type="image/webp" />
  
  <title>AD Global Pay - Panel</title>

  <script is:inline define:vars={{ API_URL }}>
    window.__ADGLOBAL_API_URL__ = API_URL;
  </script>

  <style is:global>
    :root {
      --font-body: 'DM Sans', sans-serif;
      --font-heading: 'Outfit', sans-serif;
      --font-mono: 'JetBrains Mono', monospace;
      
      --color-bg: #f6f8fb;
      --color-surface: #ffffff;
      --color-surface-elevated: #ffffff;
      --color-border: rgba(226, 232, 240, 0.8);
      --color-text-primary: #0f172a;
      --color-text-secondary: #64748b;
      --color-text-muted: #94a3b8;
      --color-indigo: #6366f1;
      --color-indigo-light: #818cf8;
      --color-indigo-dark: #4f46e5;
      --color-emerald: #10b981;
      --color-amber: #f59e0b;
      --color-rose: #f43f5e;
      --color-cyan: #06b6d4;
    }

    body {
      font-family: var(--font-body);
      background-color: var(--color-bg);
      -webkit-tap-highlight-color: transparent;
    }
    h1, h2, h3, h4, h5, h6 {
      font-family: var(--font-heading);
    }

    /* ===== ANIMACIONES GLOBALES ===== */
    @keyframes fadeInUp {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes fadeInDown {
      from { opacity: 0; transform: translateY(-15px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes fadeInScale {
      from { opacity: 0; transform: scale(0.96); }
      to { opacity: 1; transform: scale(1); }
    }
    @keyframes slideInLeft {
      from { opacity: 0; transform: translateX(-20px); }
      to { opacity: 1; transform: translateX(0); }
    }
    @keyframes slideInRight {
      from { opacity: 0; transform: translateX(20px); }
      to { opacity: 1; transform: translateX(0); }
    }
    @keyframes shimmer {
      0% { background-position: -200% 0; }
      100% { background-position: 200% 0; }
    }
    @keyframes float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-6px); }
    }
    @keyframes pulse-soft {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.6; }
    }
    @keyframes countUp {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes barGrow {
      from { transform: scaleY(0); }
      to { transform: scaleY(1); }
    }
    @keyframes borderGlow {
      0%, 100% { border-color: rgba(99, 102, 241, 0.15); }
      50% { border-color: rgba(99, 102, 241, 0.4); }
    }
    @keyframes gradientShift {
      0% { background-position: 0% 50%; }
      50% { background-position: 100% 50%; }
      100% { background-position: 0% 50%; }
    }
    @keyframes modalIn {
      from { opacity: 0; transform: scale(0.95) translateY(10px); }
      to { opacity: 1; transform: scale(1) translateY(0); }
    }
    @keyframes overlayIn {
      from { opacity: 0; }
      to { opacity: 1; }
    }
    @keyframes spin-slow {
      from { transform: rotate(0deg); }
      to { transform: rotate(360deg); }
    }
    @keyframes drawerIn {
      from { transform: translateX(-100%); }
      to { transform: translateX(0); }
    }
    @keyframes drawerOverlayIn {
      from { opacity: 0; }
      to { opacity: 1; }
    }

    .anim-fade-in { animation: fadeInUp 0.5s ease-out forwards; opacity: 0; }
    .anim-fade-in-fast { animation: fadeInUp 0.35s ease-out forwards; opacity: 0; }
    .anim-slide-left { animation: slideInLeft 0.5s ease-out forwards; opacity: 0; }
    .anim-slide-right { animation: slideInRight 0.5s ease-out forwards; opacity: 0; }
    .anim-scale-in { animation: fadeInScale 0.4s ease-out forwards; opacity: 0; }
    .anim-modal { animation: modalIn 0.3s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
    .anim-overlay { animation: overlayIn 0.2s ease-out forwards; }
    .anim-drawer { animation: drawerIn 0.35s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
    .anim-drawer-overlay { animation: drawerOverlayIn 0.2s ease-out forwards; }

    .stagger-1 { animation-delay: 0.05s; }
    .stagger-2 { animation-delay: 0.1s; }
    .stagger-3 { animation-delay: 0.15s; }
    .stagger-4 { animation-delay: 0.2s; }
    .stagger-5 { animation-delay: 0.25s; }
    .stagger-6 { animation-delay: 0.3s; }
    .stagger-7 { animation-delay: 0.35s; }
    .stagger-8 { animation-delay: 0.4s; }

    /* Card hover lifts */
    .card-hover {
      transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.3s ease, border-color 0.3s ease;
    }
    .card-hover:hover {
      transform: translateY(-4px);
      box-shadow: 0 20px 40px -12px rgba(15, 23, 42, 0.12);
    }
    @media (max-width: 768px) {
      .card-hover:hover { transform: translateY(-2px); }
    }

    /* Button micro-interactions */
    .btn-interactive {
      transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
      position: relative;
      overflow: hidden;
    }
    .btn-interactive::after {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(circle at center, rgba(255,255,255,0.2) 0%, transparent 70%);
      opacity: 0;
      transition: opacity 0.3s ease;
    }
    .btn-interactive:hover::after { opacity: 1; }
    .btn-interactive:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 24px -6px rgba(99, 102, 241, 0.35);
    }
    .btn-interactive:active {
      transform: translateY(0) scale(0.98);
    }
    @media (max-width: 768px) {
      .btn-interactive:hover {
        transform: translateY(-1px);
        box-shadow: 0 4px 12px -4px rgba(99, 102, 241, 0.3);
      }
    }

    /* Table row animations */
    .table-row-anim {
      transition: background-color 0.2s ease, transform 0.2s ease;
    }
    .table-row-anim:hover {
      background-color: rgba(99, 102, 241, 0.03);
      transform: translateX(2px);
    }
    @media (max-width: 768px) {
      .table-row-anim:hover { transform: none; }
    }

    /* Shimmer loading effect */
    .shimmer {
      background: linear-gradient(90deg, #f1f5f9 25%, #e2e8f0 50%, #f1f5f9 75%);
      background-size: 200% 100%;
      animation: shimmer 1.5s infinite;
    }

    /* Floating animation for decorative elements */
    .float-anim {
      animation: float 4s ease-in-out infinite;
    }

    /* Smooth scrollbar */
    ::-webkit-scrollbar { width: 6px; height: 6px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 3px; }
    ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }

    /* Input focus animations */
    input, select, textarea {
      transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.15s ease;
    }
    input:focus, select:focus, textarea:focus {
      transform: translateY(-1px);
    }
    @media (max-width: 768px) {
      input:focus, select:focus, textarea:focus { transform: none; }
    }

    /* Badge pulse for alerts */
    .badge-pulse {
      animation: pulse-soft 2s ease-in-out infinite;
    }

    /* Progress bar animation */
    .progress-anim {
      transition: width 1.2s cubic-bezier(0.16, 1, 0.3, 1);
    }

    /* Gradient text */
    .gradient-text {
      background: linear-gradient(135deg, #6366f1 0%, #06b6d4 50%, #10b981 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    /* Glass effect */
    .glass {
      background: rgba(255, 255, 255, 0.7);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
    }

    /* Number counter animation helper */
    .count-up {
      animation: countUp 0.6s ease-out forwards;
      opacity: 0;
    }

    /* Link underline animation */
    .link-anim {
      position: relative;
    }
    .link-anim::after {
      content: '';
      position: absolute;
      bottom: -2px;
      left: 0;
      width: 0;
      height: 2px;
      background: var(--color-indigo);
      transition: width 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .link-anim:hover::after {
      width: 100%;
    }

    /* Icon spin on hover */
    .icon-spin-hover:hover svg {
      animation: spin-slow 0.6s ease-out;
    }

    /* Page transition */
    main {
      animation: fadeInUp 0.4s ease-out;
    }

    /* Mobile-specific utilities */
    @media (max-width: 768px) {
      .mobile-full { width: 100vw; max-width: 100vw; }
      .mobile-p-4 { padding: 1rem; }
      .mobile-p-0 { padding: 0; }
      .mobile-text-sm { font-size: 0.875rem; }
      .mobile-hidden { display: none; }
    }
    @media (min-width: 769px) {
      .desktop-hidden { display: none; }
    }

    /* Touch-friendly tap targets */
    @media (pointer: coarse) {
      button, a, select, input[type="checkbox"], input[type="radio"] {
        min-height: 44px;
        min-width: 44px;
      }
    }

    /* Prevent text selection on UI elements */
    .no-select {
      -webkit-user-select: none;
      user-select: none;
    }
  </style>
</head>
<body class="text-slate-800 antialiased selection:bg-indigo-500 selection:text-white overflow-x-hidden">
  <div class="h-screen overflow-hidden bg-slate-50 lg:flex" id="appRoot">
    <Sidebar client:load />
    <main class="flex-1 overflow-y-auto overflow-x-hidden w-full relative min-w-0 h-full">
      <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] opacity-[0.015] pointer-events-none"></div>
      <div class="max-w-7xl mx-auto p-4 pt-[4.5rem] sm:p-6 sm:pt-[4.5rem] lg:p-10 lg:pt-10 relative z-10">
        <slot />
      </div>
    </main>
  </div>

  <ToastProvider client:load />
  <CustomSelectInit />

  <script is:inline>
    // Proteccion de rutas admin: redirigir a login si no hay token
    (function() {
      var token = localStorage.getItem('adglobal_token');
      if (!token) {
        window.location.replace('/admin/login');
      }
    })();

    // Interceptar alert() y convertir en toast
    (function() {
      var originalAlert = window.alert;
      window.alert = function(message) {
        window.dispatchEvent(new CustomEvent('show-toast', {
          detail: { type: 'info', message: message }
        }));
      };
    })();
  </script>
</body>
</html>
